#!/usr/bin/env node
// codex-relay-forward — VPS TCP CONNECT forwarder.
// Listens for HTTP CONNECT requests and forwards them through an upstream
// static proxy. Designed to run on a VPS reachable via Tailscale/WireGuard.
// Requires Node.js >= 18 (no npm dependencies).
//
// Usage:
//   codex-relay-forward                             # reads proxy from config.json
//   codex-relay-forward <vps-tailscale-ip>:8443         # custom listen addr
//   codex-relay-forward 0.0.0.0:8443 http://proxy:8080  # full custom
//
// Env vars:
//   FORWARD_LISTEN   listen address (default 127.0.0.1:8443)
//   FORWARD_PROXY    upstream proxy URL (overrides config.json)
//   FORWARD_ALLOW    comma-separated CONNECT targets (default OpenAI hosts)

const net = require("net");
const fs = require("fs");
const path = require("path");
const os = require("os");

// ── config ─────────────────────────────────────────────────────────────────

const CONFIG_FILE = path.join(os.homedir(), ".codex-relay", "config.json");
function loadConfig() {
  try {
    return JSON.parse(fs.readFileSync(CONFIG_FILE, "utf8"));
  } catch (e) {
    if (e.code === "ENOENT") return {};
    console.error(`error: invalid config file ${CONFIG_FILE}: ${e.message}`);
    process.exit(1);
  }
}

const LISTEN = process.argv[2] || process.env.FORWARD_LISTEN || "127.0.0.1:8443";
const PROXY_URL = process.argv[3] || process.env.FORWARD_PROXY ||
                  loadConfig().https || loadConfig().http;
const DEFAULT_ALLOW = "api.openai.com:443,chatgpt.com:443,auth.openai.com:443,cdn.openai.com:443";
const ALLOW = (process.env.FORWARD_ALLOW || DEFAULT_ALLOW).split(",").map((v) => v.trim()).filter(Boolean);
const HEADER_LIMIT = 16 * 1024;
const IDLE_TIMEOUT_MS = 30000;

if (!PROXY_URL) {
  console.error("error: no upstream proxy configured. Set FORWARD_PROXY env var,");
  console.error("  pass as CLI arg, or configure http/https in " + CONFIG_FILE);
  process.exit(1);
}

// ── helpers ────────────────────────────────────────────────────────────────

function parseAddr(val) {
  const m = String(val).match(/^\[([^\]]+)\]:(\d+)$/);
  if (m) return { host: m[1], port: parseInt(m[2], 10) };
  const i = String(val).lastIndexOf(":");
  if (i <= 0) return { host: "127.0.0.1", port: parseInt(val, 10) || 8443 };
  return { host: val.slice(0, i), port: parseInt(val.slice(i + 1), 10) || 8443 };
}

function parseProxy(url) {
  const u = new URL(url);
  if (u.protocol !== "http:") throw new Error("only http upstream proxies are supported");
  const auth = u.username || u.password ? `${decodeURIComponent(u.username)}:${decodeURIComponent(u.password)}` : "";
  return {
    host: u.hostname,
    port: parseInt(u.port || "8080", 10),
    b64: auth ? Buffer.from(auth).toString("base64") : "",
  };
}

function redactUrl(value) {
  try {
    const u = new URL(value);
    if (u.username || u.password) {
      u.username = "***";
      u.password = "";
    }
    return u.toString().replace("%2A%2A%2A", "***");
  } catch {
    return String(value).replace(/\/\/[^/@\s]+@/, "//***@");
  }
}

function isAllowedTarget(host, port) {
  const target = `${host}:${port}`.toLowerCase();
  return ALLOW.some((entry) => {
    const item = entry.toLowerCase();
    if (item === target) return true;
    if (item.startsWith("*.")) {
      const suffix = item.slice(1);
      return target.endsWith(suffix);
    }
    return false;
  });
}

const addr = parseAddr(LISTEN);
let proxy;
try {
  proxy = parseProxy(PROXY_URL);
} catch (e) {
  console.error(`error: invalid upstream proxy: ${e.message}`);
  process.exit(1);
}
const REDACTED = redactUrl(PROXY_URL);

// ── server ─────────────────────────────────────────────────────────────────

const server = net.createServer((client) => {
  client.setNoDelay(true);
  client.setTimeout(IDLE_TIMEOUT_MS, () => client.destroy());
  client.once("data", (buf) => {
    if (buf.length > HEADER_LIMIT) { client.end("HTTP/1.1 431 Request Header Fields Too Large\r\n\r\n"); return; }
    const head = buf.toString();
    const m = head.match(/^CONNECT\s+(\S+):(\d+)\s+HTTP\//i);
    if (!m) { client.end("HTTP/1.1 400 Bad Request\r\n\r\n"); return; }

    const targetHost = m[1].toLowerCase();
    const targetPort = parseInt(m[2], 10);
    if (!isAllowedTarget(targetHost, targetPort)) {
      client.end("HTTP/1.1 403 Forbidden\r\n\r\n");
      return;
    }

    const target = `${targetHost}:${targetPort}`;
    const upstream = net.connect(proxy.port, proxy.host, () => {
      let req = `CONNECT ${target} HTTP/1.1\r\nHost: ${target}\r\n`;
      if (proxy.b64) req += `Proxy-Authorization: Basic ${proxy.b64}\r\n`;
      req += "\r\n";
      upstream.write(req);
    });
    upstream.setNoDelay(true);
    upstream.setTimeout(IDLE_TIMEOUT_MS, () => upstream.destroy());

    let resp = Buffer.alloc(0);
    let done = false;
    upstream.on("data", (d) => {
      if (done) return;
      resp = Buffer.concat([resp, d]);
      if (resp.length > HEADER_LIMIT) {
        client.end("HTTP/1.1 502 Bad Gateway\r\n\r\n");
        upstream.destroy();
        return;
      }
      const eoh = resp.indexOf("\r\n\r\n");
      if (eoh === -1) return;
      done = true;
      upstream.removeAllListeners("data");

      const status = resp.toString("utf8", 0, resp.indexOf("\r\n"));
      if (!/^HTTP\/\d(?:\.\d)? 200\b/.test(status)) {
        client.end("HTTP/1.1 502 Bad Gateway\r\n\r\n");
        upstream.destroy();
        return;
      }

      client.write("HTTP/1.1 200 Connection Established\r\n\r\n");
      const leftover = resp.slice(eoh + 4);
      if (leftover.length) upstream.unshift(leftover);
      // Tunnel established — disable idle timeouts for long-lived streaming
      client.setTimeout(0);
      upstream.setTimeout(0);
      client.pipe(upstream);
      upstream.pipe(client);
    });
    upstream.on("error", () => { try { client.destroy(); } catch {} });
    client.on("error", () => { try { upstream.destroy(); } catch {} });
  });
  client.on("error", () => {});
});

server.on("error", (e) => {
  if (e.code === "EADDRINUSE") {
    console.error(`port ${addr.port} in use, retrying in 1s...`);
    setTimeout(() => { server.close(); server.listen(addr.port, addr.host, () => { console.error(`[codex-relay-forward] ${addr.host}:${addr.port} → ${REDACTED}`); }); }, 1000);
    return;
  }
  console.error("server error:", e.message);
  process.exit(1);
});

server.listen(addr.port, addr.host, () => {
  console.error(`[codex-relay-forward] ${addr.host}:${addr.port} → ${REDACTED}`);
});
