#!/usr/bin/env node
// codex-relay — Node.js wrapper for OpenAI Codex CLI with proxy support.
// Requires Node.js >= 18 (built-in fetch, no npm dependencies).

const net = require("net");
const tls = require("tls");
const dns = require("dns").promises;
const fs = require("fs");
const path = require("path");
const os = require("os");
const crypto = require("crypto");
const { spawn, execSync } = require("child_process");

// ── config ─────────────────────────────────────────────────────────────────

const NAME = "codex-relay";
const VERSION = "0.2.0";

// When running via sudo, use the original user's home, not /var/root
const SUDO_USER = process.env.SUDO_USER;
const REAL_HOME = (() => {
  if (!SUDO_USER) return os.homedir();
  try {
    const info = require("os").userInfo({ encoding: "utf8" });
    // macOS: userInfo doesn't take options; try to resolve from /Users or /home
  } catch {}
  // Heuristic: check common home dir patterns
  for (const prefix of ["/Users", "/home"]) {
    const candidate = path.join(prefix, SUDO_USER);
    try { if (fs.statSync(candidate).isDirectory()) return candidate; } catch {}
  }
  return os.homedir();
})();
const CONFIG_DIR = path.join(REAL_HOME, ".codex-relay");
const CONFIG_FILE = path.join(CONFIG_DIR, "config.json");
const DNS_CACHE_FILE = path.join(CONFIG_DIR, "dns.json");
const PID_FILE = path.join(CONFIG_DIR, "proxy.pid");
const PORT_FILE = path.join(CONFIG_DIR, "proxy.port");
const BYPASS_PID_FILE = path.join(CONFIG_DIR, "bypass.pid");
const CHAIN_PID_FILE = path.join(CONFIG_DIR, "chain.pid");
const CHAIN_HEARTBEAT_FILE = path.join(CONFIG_DIR, "chain.heartbeat");
const LOG_FILE = path.join(CONFIG_DIR, "proxy.log");
const CHAIN_LOG_FILE = path.join(CONFIG_DIR, "chain.log");
const MAX_LOG_LINES = 500;

function proxyLog(msg) {
  appendLog(LOG_FILE, msg);
}

function chainLog(msg) {
  appendLog(CHAIN_LOG_FILE, msg);
}

function appendLog(file, msg) {
  const ts = new Date().toISOString();
  const line = `${ts} ${msg}\n`;
  try {
    fs.appendFileSync(file, line);
    // Rotate if too large
    const lines = fs.readFileSync(file, "utf8").split("\n");
    if (lines.length > MAX_LOG_LINES + 50) {
      fs.writeFileSync(file, lines.slice(-MAX_LOG_LINES).join("\n"));
    }
  } catch {}
}

// Resolve script path (handle relative paths for sudo)
const SCRIPT_PATH = (() => {
  try { return fs.realpathSync(process.argv[1]); } catch { return process.argv[1]; }
})();

const BYPASS_HOSTS = [
  { host: "chatgpt.com", alias: "127.0.0.1" },
];

const OPENAI_DOMAINS = [
  "api.openai.com",
  "auth.openai.com",
  "chatgpt.com",
  "platform.openai.com",
  "developers.openai.com",
];

// ── helpers ────────────────────────────────────────────────────────────────

function die(msg) {
  console.error(`error: ${msg}`);
  process.exit(1);
}
function info(msg) {
  console.error(`[${NAME}] ${msg}`);
}

function loadConfig() {
  try { return JSON.parse(fs.readFileSync(CONFIG_FILE, "utf8")); } catch { return {}; }
}
function saveConfig(cfg) {
  fs.mkdirSync(CONFIG_DIR, { recursive: true });
  fs.writeFileSync(CONFIG_FILE, JSON.stringify(cfg, null, 2));
}
function generateToken() {
  return crypto.randomBytes(24).toString("base64url");
}
function hashToken(token) {
  return "sha256:" + crypto.createHash("sha256").update(token).digest("hex");
}
function tokenMatches(token, hash) {
  if (!hash) return false;
  if (hash.startsWith("sha256:")) return hashToken(token) === hash;
  return token === hash;
}

function findCodex() {
  try { return execSync("which codex", { encoding: "utf8" }).trim(); } catch { return null; }
}
function codexVersion() {
  const bin = findCodex();
  if (!bin) return null;
  try { return execSync(`"${bin}" --version`, { encoding: "utf8", timeout: 5000 }).trim(); } catch { return null; }
}

// ── DNS resolution ─────────────────────────────────────────────────────────

async function resolveAllIPs(host) {
  try { return await dns.resolve4(host); } catch { return []; }
}

// In-memory cache to reduce disk I/O on every CONNECT
let _dnsMemCache = null;
let _dnsMemCacheTs = 0;
const DNS_MEM_CACHE_TTL = 30000; // 30 seconds before re-reading from disk

function loadDnsCache() {
  const now = Date.now();
  if (_dnsMemCache && (now - _dnsMemCacheTs) < DNS_MEM_CACHE_TTL) return _dnsMemCache;
  try {
    const raw = JSON.parse(fs.readFileSync(DNS_CACHE_FILE, "utf8"));
    for (const [host, entry] of Object.entries(raw)) {
      if (entry.ip && !entry.ips) {
        raw[host] = { ips: [{ ip: entry.ip, ok: null, testedAt: null }], ts: entry.ts || 0 };
      }
    }
    _dnsMemCache = raw;
    _dnsMemCacheTs = now;
    return raw;
  } catch { return {}; }
}
function saveDnsCache(cache) {
  fs.mkdirSync(CONFIG_DIR, { recursive: true });
  fs.writeFileSync(DNS_CACHE_FILE, JSON.stringify(cache, null, 2));
  _dnsMemCache = cache;
  _dnsMemCacheTs = Date.now();
}

function getBestIp(host) {
  const cache = loadDnsCache();
  const entry = cache[host];
  if (!entry || !entry.ips?.length) return null;
  // Priority: ok:true > ok:null (untested) > skip ok:false
  const good = entry.ips.filter((e) => e.ok === true);
  const untested = entry.ips.filter((e) => e.ok === null || e.ok === undefined);
  const pool = good.length > 0 ? good : untested.length > 0 ? untested : entry.ips;
  // Random within same priority tier
  return pool[Math.floor(Math.random() * pool.length)]?.ip || null;
}

function markIpResult(host, ip, ok) {
  const cache = loadDnsCache();
  const entry = cache[host];
  if (!entry || !entry.ips) return;
  for (const e of entry.ips) {
    if (e.ip === ip) { e.ok = ok; e.testedAt = Date.now(); break; }
  }
  // If none matched, add it
  if (!entry.ips.some((e) => e.ip === ip)) {
    entry.ips.push({ ip, ok, testedAt: Date.now() });
  }
  saveDnsCache(cache);
}

function upsertCacheIPs(host, ips) {
  const cache = loadDnsCache();
  const entry = cache[host] || { ips: [], ts: 0 };
  const existing = new Map(entry.ips.map((e) => [e.ip, e]));
  entry.ips = ips.map((ip) => {
    const old = existing.get(ip);
    return old || { ip, ok: null, testedAt: null };
  });
  entry.ts = Date.now();
  cache[host] = entry;
  saveDnsCache(cache);
}

// Test one IP through the upstream proxy by checking CONNECT response
async function testIp(ip, host, port, upstreamUrl) {
  const { auth } = parseProxyUrl(upstreamUrl);
  return new Promise((resolve) => {
    const sock = connectProxySocket(upstreamUrl, () => {
      let req = `CONNECT ${ip}:${port || 443} HTTP/1.1\r\nHost: ${host}:${port || 443}\r\n`;
      if (auth) req += `Proxy-Authorization: Basic ${auth}\r\n`;
      req += "\r\n";
      sock.write(req);
      sock.once("data", (data) => {
        const ok = data.toString().startsWith("HTTP/1.1 200") || data.toString().startsWith("HTTP/1.0 200");
        sock.destroy();
        resolve(ok);
      });
    });
    sock.setTimeout(3000);
    sock.on("error", () => resolve(false));
    sock.on("timeout", () => { sock.destroy(); resolve(false); });
  });
}

async function refreshDnsCache(domains = OPENAI_DOMAINS, proxyUrl, logCb) {
  const log = logCb || ((...a) => console.log(...a));
  if (!proxyUrl) {
    const cfg = loadConfig();
    proxyUrl = cfg.https || cfg.http;
  }
  for (const host of domains) {
    const ips = await resolveAllIPs(host);
    if (ips.length > 0) {
      upsertCacheIPs(host, ips);
      if (proxyUrl) {
        const results = [];
        for (const ip of ips) {
          const ok = await testIp(ip, host, 443, proxyUrl);
          results.push(ok ? "✓" : "✗");
          markIpResult(host, ip, ok);
        }
        log(`  ${host.padEnd(30)} → ${ips.join(", ")}  [${results.join(" ")}]`);
      } else {
        log(`  ${host.padEnd(30)} → ${ips.join(", ")}  (no proxy to test)`);
      }
    } else {
      log(`  ${host.padEnd(30)} → FAILED`);
    }
  }
  return loadDnsCache();
}

// Parse proxy URL: http://[user:pass@]host:port
function parseProxyUrl(url) {
  const schemeMatch = String(url).match(/^(https?):\/\//);
  const scheme = schemeMatch ? schemeMatch[1] : "http";
  const noScheme = String(url).replace(/^https?:\/\//, "");
  const atIdx = noScheme.lastIndexOf("@");
  const authPart = atIdx >= 0 ? noScheme.slice(0, atIdx) : "";
  const hostPort = atIdx >= 0 ? noScheme.slice(atIdx + 1) : noScheme;
  const colonIdx = hostPort.lastIndexOf(":");
  const host = colonIdx >= 0 ? hostPort.slice(0, colonIdx) : hostPort;
  const port = colonIdx >= 0 ? parseInt(hostPort.slice(colonIdx + 1), 10) : (scheme === "https" ? 443 : 80);
  const userColon = authPart.indexOf(":");
  const user = userColon >= 0 ? authPart.slice(0, userColon) : (authPart || "");
  const pass = userColon >= 0 ? authPart.slice(userColon + 1) : "";
  const auth = user ? Buffer.from(`${user}:${pass}`).toString("base64") : "";
  return { scheme, host, port, user, pass, auth };
}

function connectProxySocket(proxyUrl, onConnect) {
  const { scheme, host, port } = parseProxyUrl(proxyUrl);
  const sock = scheme === "https"
    ? tls.connect({ host, port, servername: host, rejectUnauthorized: false }, onConnect)
    : net.connect(port, host, onConnect);
  return sock;
}

function parseListenAddr(value) {
  const input = value || "127.0.0.1:8080";
  const idx = input.lastIndexOf(":");
  if (idx < 0) return { host: input, port: 8080 };
  const host = input.slice(0, idx) || "0.0.0.0";
  const port = parseInt(input.slice(idx + 1), 10);
  if (!port) die(`invalid listen address: ${input}`);
  return { host, port };
}

function stripProxyAuthorization(headStr) {
  return headStr.replace(/^Proxy-Authorization:.*\r\n/gim, "");
}

function addProxyAuthorization(headStr, auth) {
  const stripped = stripProxyAuthorization(headStr);
  if (!auth) return stripped;
  return stripped.replace(
    /\r\n\r\n$/,
    `\r\nProxy-Authorization: Basic ${auth}\r\n\r\n`
  );
}

function addInternalHostHeader(headStr, host) {
  return headStr.replace(/^X-Codex-Relay-Host:.*\r\n/gim, "").replace(
    /\r\n\r\n$/,
    `\r\nX-Codex-Relay-Host: ${host}\r\n\r\n`
  );
}

function stripInternalHeaders(headStr) {
  return headStr.replace(/^X-Codex-Relay-Host:.*\r\n/gim, "");
}

function internalHost(headStr) {
  const m = headStr.match(/^X-Codex-Relay-Host:\s*([^\r\n]+)\s*$/im);
  return m ? m[1].trim() : "";
}

function proxyAuthToken(headStr) {
  const m = headStr.match(/^Proxy-Authorization:\s*Basic\s+([A-Za-z0-9+/=]+)\s*$/im);
  if (!m) return "";
  try {
    const decoded = Buffer.from(m[1], "base64").toString("utf8");
    const colon = decoded.indexOf(":");
    return colon >= 0 ? decoded.slice(0, colon) : decoded;
  } catch {
    return "";
  }
}

// ── local forward proxy ────────────────────────────────────────────────────

function startLocalProxy(upstreamUrl, port = 0) {
  return new Promise((resolve, reject) => {
    const server = net.createServer();
    server.on("error", reject);

    server.listen(port, "127.0.0.1", () => {
      // Replace startup-only error handler with persistent one
      server.removeListener("error", reject);
      server.on("error", (e) => {
        proxyLog(`server error: ${e.message}`);
      });
      const addr = server.address();
      resolve({ server, port: addr.port });
    });

    server.on("connection", (clientSocket) => {
      clientSocket.once("data", (head) => {
        handleRequest(clientSocket, head, upstreamUrl);
      });
      clientSocket.on("error", () => {}); // prevent crash on client errors
    });
  });
}

async function handleRequest(clientSocket, head, upstreamUrl) {
  try {
    const headStr = head.toString();
    const connectMatch = headStr.match(/^CONNECT (.+):(\d+)/m);

    if (!connectMatch) {
      forwardHttp(clientSocket, head, upstreamUrl);
      return;
    }

    const host = connectMatch[1];
    const port = parseInt(connectMatch[2], 10);

        // Resolve all IPs and cache if not already cached
        let entry = loadDnsCache()[host];
        if (!entry || !entry.ips?.length) {
          const ips = await resolveAllIPs(host);
          if (ips.length > 0) { upsertCacheIPs(host, ips); entry = loadDnsCache()[host]; }
        }

        // Parse proxy URL: http(s)://[user:pass@]host:port
        const { auth } = parseProxyUrl(upstreamUrl);

        // Try up to 3 IPs
        const triedIps = [];
        let connected = false;
        const MAX_TRIES = 2; // 2 attempts; WebSocket has tight timeouts

        for (let attempt = 0; attempt < MAX_TRIES && !connected; attempt++) {
          const ip = getBestIp(host);
          if (!ip) break;
          if (triedIps.includes(ip)) break;
          triedIps.push(ip);

          const target = ip || host;
          let modified = headStr.replace(
            /^CONNECT .+:\d+/m,
            `CONNECT ${target}:${port}`
          );
          modified = addInternalHostHeader(modified, host);
          if (auth) modified = addProxyAuthorization(modified, auth);

          await new Promise((resolve) => {
            let upstreamSocket;
            // TCP connect timeout: 3s to reach upstream proxy
            const connTimer = setTimeout(() => {
              markIpResult(host, ip, false);
              proxyLog(`CONNECT ${host}:${port} → ${ip} connect timeout`);
              try { upstreamSocket.destroy(); } catch {}
              resolve(); // try next IP
            }, 3000);
            upstreamSocket = connectProxySocket(upstreamUrl, () => {
              clearTimeout(connTimer);
              // Response timeout: 3s for upstream to reply to CONNECT
              upstreamSocket.setTimeout(3000);
              upstreamSocket.on("timeout", () => {
                markIpResult(host, ip, false);
                proxyLog(`CONNECT ${host}:${port} → ${ip} response timeout`);
                try { clientSocket.write("HTTP/1.1 504 Gateway Timeout\r\n\r\n"); clientSocket.end(); } catch {}
                try { upstreamSocket.destroy(); } catch {}
                connected = true;
                resolve();
              });
              upstreamSocket.write(modified);
              // Buffer entire upstream HTTP response to avoid TLS stream corruption
              let respBuf = Buffer.alloc(0);
              const onData = (chunk) => {
                respBuf = Buffer.concat([respBuf, chunk]);
                const headerEnd = respBuf.indexOf("\r\n\r\n");
                if (headerEnd < 0) return; // need more data
                upstreamSocket.removeListener("data", onData);

                const respStr = respBuf.toString("utf8", 0, headerEnd + 4);
                if (respStr.startsWith("HTTP/1.1 200") || respStr.startsWith("HTTP/1.0 200")) {
                  markIpResult(host, ip, true);
                  proxyLog(`CONNECT ${host}:${port} → ${ip} OK`);
                  upstreamSocket.setTimeout(0);
                  upstreamSocket.removeAllListeners("timeout");
                  // TCP keepalive to prevent upstream proxy idle timeout
                  upstreamSocket.setKeepAlive(true, 30000);
                  clientSocket.setKeepAlive(true, 30000);
                  clientSocket.write("HTTP/1.1 200 Connection Established\r\n\r\n");
                  const leftover = respBuf.slice(headerEnd + 4);
                  if (leftover.length > 0) clientSocket.write(leftover);
                  clientSocket.pipe(upstreamSocket);
                  upstreamSocket.pipe(clientSocket);
                  connected = true;
                } else {
                  markIpResult(host, ip, false);
                  proxyLog(`CONNECT ${host}:${port} → ${ip} rejected: ${respStr.split("\r\n")[0]}`);
                  try { clientSocket.write(respStr); } catch {}
                  upstreamSocket.destroy();
                }
                resolve();
              };
              upstreamSocket.on("data", onData);
            });
            upstreamSocket.on("error", () => {
              if (connected) return;
              clearTimeout(connTimer);
              markIpResult(host, ip, false);
              try { upstreamSocket.destroy(); } catch {}
              resolve(); // try next IP
            });
            clientSocket.on("error", () => {
              clearTimeout(connTimer);
              try { upstreamSocket.destroy(); } catch {}
              resolve();
            });
          });
        }

        if (!connected) {
          proxyLog(`CONNECT ${host}:${port} FAIL all IPs tried: ${triedIps.join(", ")}`);
          try { clientSocket.write("HTTP/1.1 502 Bad Gateway\r\n\r\n"); clientSocket.end(); } catch {}
        }
  } catch (e) {
    proxyLog(`request error: ${e.message}`);
    try { clientSocket.end(); } catch {}
  }
}

async function forwardHttp(clientSocket, head, upstreamUrl) {
  const headStr = head.toString();

  // Parse target host from HTTP request line: GET http://host/path HTTP/1.1
  const reqMatch = headStr.match(/^([A-Z]+) http:\/\/([^/:]+)(:\d+)?(\/[^\s]*)? HTTP\/[0-9.]+\r\n/m);
  let modifiedHead = headStr;

  if (reqMatch) {
    const host = reqMatch[2];
    let ip = getBestIp(host);
    if (!ip) {
      const ips = await resolveAllIPs(host);
      if (ips.length > 0) { upsertCacheIPs(host, ips); ip = getBestIp(host); }
    }
    if (ip) {
      // Rewrite request URL to use IP so upstream proxy doesn't need DNS
      const portSuffix = reqMatch[3] || "";
      const path = reqMatch[4] || "/";
      modifiedHead = headStr.replace(
        `http://${host}${portSuffix}${path}`,
        `http://${ip}${portSuffix}${path}`
      );
    }
    modifiedHead = addInternalHostHeader(modifiedHead, host);
  }

  const { auth } = parseProxyUrl(upstreamUrl);

  // Inject Proxy-Authorization if upstream needs it and request lacks it
  if (auth) modifiedHead = addProxyAuthorization(modifiedHead, auth);

  const upstream = connectProxySocket(upstreamUrl, () => {
    upstream.setKeepAlive(true, 30000);
    clientSocket.setKeepAlive(true, 30000);
    upstream.write(modifiedHead);
    clientSocket.pipe(upstream);
    upstream.pipe(clientSocket);
  });
  upstream.setTimeout(10000);
  upstream.on("timeout", () => {
    try { clientSocket.end(); } catch {}
    try { upstream.destroy(); } catch {}
  });
  upstream.on("error", () => { try { clientSocket.end(); } catch {} });
  clientSocket.on("error", () => { try { upstream.end(); } catch {} });
}

function chainUpstreams(input) {
  if (Array.isArray(input)) return input.filter(Boolean);
  return String(input || "").split(",").map((s) => s.trim()).filter(Boolean);
}

function redactProxyUrl(url) {
  return String(url).replace(/\/\/[^@/]+@/, "//***@");
}

function connectTargetFromHead(headStr) {
  const connectMatch = headStr.match(/^CONNECT (.+):(\d+)/m);
  if (connectMatch) return { mode: "connect", host: connectMatch[1], port: parseInt(connectMatch[2], 10) };
  const reqMatch = headStr.match(/^([A-Z]+) http:\/\/([^/:]+)(:\d+)?(\/[^\s]*)? HTTP\/[0-9.]+\r\n/m);
  if (!reqMatch) return null;
  return {
    mode: "http",
    host: reqMatch[2],
    port: reqMatch[3] ? parseInt(reqMatch[3].slice(1), 10) : 80,
    method: reqMatch[1],
    path: reqMatch[4] || "/",
  };
}

function ipv4ToInt(ip) {
  const parts = ip.split(".").map((p) => parseInt(p, 10));
  if (parts.length !== 4 || parts.some((p) => Number.isNaN(p) || p < 0 || p > 255)) return null;
  return (((parts[0] << 24) >>> 0) + (parts[1] << 16) + (parts[2] << 8) + parts[3]) >>> 0;
}

function cidrContains(cidr, ip) {
  const [base, bitsStr] = cidr.split("/");
  const bits = parseInt(bitsStr, 10);
  const baseInt = ipv4ToInt(base);
  const ipInt = ipv4ToInt(ip);
  if (baseInt === null || ipInt === null || Number.isNaN(bits) || bits < 0 || bits > 32) return false;
  const mask = bits === 0 ? 0 : (0xffffffff << (32 - bits)) >>> 0;
  return (baseInt & mask) === (ipInt & mask);
}

function isIpv4(host) {
  return ipv4ToInt(host) !== null;
}

function allowedChainTarget(headStr, allowList) {
  if (!allowList || allowList.length === 0) return true;
  const originalHost = internalHost(headStr);
  const target = connectTargetFromHead(headStr);
  const candidates = [originalHost, target?.host].filter(Boolean);
  return candidates.some((host) => allowList.some((allow) => {
    if (allow === "*") return true;
    if (allow.includes("/")) return cidrContains(allow, host);
    if (allow.startsWith(".")) return host.endsWith(allow);
    return host === allow;
  }));
}

async function prepareChainTarget(headStr, target, reqId) {
  const originalHost = internalHost(headStr) || target.host;
  let resolvedHost = target.host;
  let nextHead = addInternalHostHeader(headStr, originalHost);

  if (target.host && !isIpv4(target.host)) {
    let ip = getBestIp(target.host);
    if (!ip) {
      const ips = await resolveAllIPs(target.host);
      if (ips.length > 0) {
        upsertCacheIPs(target.host, ips);
        ip = getBestIp(target.host);
      }
    }
    if (ip) {
      resolvedHost = ip;
      chainLog(`${reqId} resolve ${target.host} -> ${ip}`);
      if (target.mode === "connect") {
        nextHead = nextHead.replace(/^CONNECT .+:\d+/m, `CONNECT ${ip}:${target.port}`);
      } else {
        const portSuffix = target.port && target.port !== 80 ? `:${target.port}` : "";
        nextHead = nextHead.replace(
          `http://${target.host}${portSuffix}${target.path}`,
          `http://${ip}${portSuffix}${target.path}`
        );
      }
    } else {
      chainLog(`${reqId} resolve ${target.host} failed; forwarding hostname`);
    }
  }

  return {
    headStr: nextHead,
    target: { ...target, host: resolvedHost, originalHost },
  };
}

function tryChainUpstream(clientSocket, headStr, upstreamUrl, target, reqId, timeoutMs) {
  return new Promise((resolve) => {
    if (upstreamUrl === "direct") {
      const direct = net.connect(target.port, target.host);
      const timer = setTimeout(() => {
        chainLog(`${reqId} direct ${target.host}:${target.port} connect timeout`);
        try { direct.destroy(); } catch {}
        resolve(false);
      }, timeoutMs);
      direct.once("connect", () => {
        clearTimeout(timer);
        chainLog(`${reqId} direct ${target.host}:${target.port} OK`);
        direct.setKeepAlive(true, 30000);
        clientSocket.setKeepAlive(true, 30000);
        if (target.mode === "connect") {
          clientSocket.write("HTTP/1.1 200 Connection Established\r\n\r\n");
        } else {
          const originHead = stripInternalHeaders(stripProxyAuthorization(headStr))
            .replace(/^([A-Z]+) http:\/\/[^/\s]+([^\s]*) HTTP\/([0-9.]+)/m, `$1 ${target.path} HTTP/$3`);
          direct.write(originHead);
        }
        clientSocket.pipe(direct);
        direct.pipe(clientSocket);
        resolve(true);
      });
      direct.once("error", (e) => {
        clearTimeout(timer);
        chainLog(`${reqId} direct ${target.host}:${target.port} error: ${e.message}`);
        resolve(false);
      });
      clientSocket.once("error", () => { try { direct.destroy(); } catch {} resolve(true); });
      return;
    }

    const { auth } = parseProxyUrl(upstreamUrl);
    const upstreamHead = addProxyAuthorization(stripInternalHeaders(headStr), auth);
    const upstream = connectProxySocket(upstreamUrl, () => {
      upstream.write(upstreamHead);
      if (target.mode !== "connect") {
        chainLog(`${reqId} upstream ${redactProxyUrl(upstreamUrl)} HTTP forward`);
        upstream.setKeepAlive(true, 30000);
        clientSocket.setKeepAlive(true, 30000);
        clientSocket.pipe(upstream);
        upstream.pipe(clientSocket);
        clearTimeout(timer);
        resolve(true);
      }
    });
    let respBuf = Buffer.alloc(0);
    const timer = setTimeout(() => {
      chainLog(`${reqId} upstream ${redactProxyUrl(upstreamUrl)} timeout`);
      try { upstream.destroy(); } catch {}
      resolve(false);
    }, timeoutMs);
    upstream.on("data", (chunk) => {
      if (target.mode !== "connect") return;
      respBuf = Buffer.concat([respBuf, chunk]);
      const headerEnd = respBuf.indexOf("\r\n\r\n");
      if (headerEnd < 0) return;
      clearTimeout(timer);
      const respStr = respBuf.toString("utf8", 0, headerEnd + 4);
      const status = respStr.split("\r\n")[0];
      upstream.removeAllListeners("data");
      if (respStr.startsWith("HTTP/1.1 200") || respStr.startsWith("HTTP/1.0 200")) {
        chainLog(`${reqId} upstream ${redactProxyUrl(upstreamUrl)} OK`);
        upstream.setKeepAlive(true, 30000);
        clientSocket.setKeepAlive(true, 30000);
        clientSocket.write(respStr);
        const leftover = respBuf.slice(headerEnd + 4);
        if (leftover.length > 0) clientSocket.write(leftover);
        clientSocket.pipe(upstream);
        upstream.pipe(clientSocket);
        resolve(true);
      } else {
        chainLog(`${reqId} upstream ${redactProxyUrl(upstreamUrl)} rejected: ${status}`);
        try { upstream.destroy(); } catch {}
        resolve(false);
      }
    });
    upstream.once("error", (e) => {
      clearTimeout(timer);
      chainLog(`${reqId} upstream ${redactProxyUrl(upstreamUrl)} error: ${e.message}`);
      resolve(false);
    });
    clientSocket.once("error", () => { try { upstream.destroy(); } catch {} resolve(true); });
  });
}

function startChainRelay({ listen, upstreamUrl, upstreams, token, tokenHash, allow = [], tlsCert, tlsKey }) {
  const { host: listenHost, port: listenPort } = parseListenAddr(listen);
  const upstreamList = chainUpstreams(upstreams || upstreamUrl);
  if (upstreamList.length === 0) die("chain relay requires at least one upstream or direct");
  const timeoutMs = 10000;

  const handle = (clientSocket) => {
    const reqId = crypto.randomBytes(4).toString("hex");
    clientSocket.once("data", async (head) => {
      const headStr = head.toString();
      const presentedToken = proxyAuthToken(headStr);
      if ((tokenHash && !tokenMatches(presentedToken, tokenHash)) || (token && presentedToken !== token)) {
        try {
          clientSocket.write("HTTP/1.1 407 Proxy Authentication Required\r\nProxy-Authenticate: Basic realm=\"codex-relay-chain\"\r\n\r\n");
          clientSocket.end();
        } catch {}
        chainLog(`${reqId} auth failed`);
        return;
      }
      if (!allowedChainTarget(headStr, allow)) {
        const target = connectTargetFromHead(headStr);
        chainLog(`${reqId} ACL denied: ${internalHost(headStr) || target?.host || "unknown"}`);
        try { clientSocket.write("HTTP/1.1 403 Forbidden\r\n\r\n"); clientSocket.end(); } catch {}
        return;
      }

      const target = connectTargetFromHead(headStr);
      if (!target) {
        chainLog(`${reqId} bad request`);
        try { clientSocket.write("HTTP/1.1 400 Bad Request\r\n\r\n"); clientSocket.end(); } catch {}
        return;
      }

      const prepared = await prepareChainTarget(headStr, target, reqId);
      const preparedHead = prepared.headStr;
      const preparedTarget = prepared.target;

      chainLog(`${reqId} ${preparedTarget.mode.toUpperCase()} ${preparedTarget.originalHost}:${preparedTarget.port} via ${preparedTarget.host}`);
      for (const upstream of upstreamList) {
        const ok = await tryChainUpstream(clientSocket, preparedHead, upstream, preparedTarget, reqId, timeoutMs);
        if (ok) return;
      }
      chainLog(`${reqId} all upstreams failed`);
      try { clientSocket.write("HTTP/1.1 502 Bad Gateway\r\n\r\n"); clientSocket.end(); } catch {}
    });
    clientSocket.on("error", () => {});
  };

  const server = (tlsCert && tlsKey)
    ? tls.createServer({ cert: fs.readFileSync(tlsCert), key: fs.readFileSync(tlsKey) }, handle)
    : net.createServer(handle);
  server.on("error", (e) => die(`chain relay failed: ${e.message}`));
  server.listen(listenPort, listenHost, () => {
    chainLog(`chain relay listening on ${listenHost}:${listenPort}`);
    info(`chain relay listening on ${listenHost}:${listenPort}${tlsCert ? " (TLS)" : ""}`);
    info(`upstreams: ${upstreamList.map(redactProxyUrl).join(", ")}`);
    if (allow.length > 0) info(`ACL: ${allow.join(", ")}`);
    if (token || tokenHash) info("client auth: enabled");
    else info("client auth: disabled");
  });
  return server;
}

