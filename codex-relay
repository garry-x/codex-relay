async function cmdInstall(opts = {}) {
  // Apply proxy
  const cfg = loadConfig();
  const proxyUrl = cfg.https || cfg.http;
  const env = { ...process.env };
  if (proxyUrl) {
    env.HTTP_PROXY = proxyUrl;
    env.HTTPS_PROXY = proxyUrl;
    env.http_proxy = proxyUrl;
    env.https_proxy = proxyUrl;
    env.NO_PROXY = "localhost,127.0.0.1,::1,.local";
    env.no_proxy = "localhost,127.0.0.1,::1,.local";
  }

  // Explicit flags — do exactly what was asked
  if (opts.update) {
    await cmdUpdateCodex(env);
    return;
  }
  if (opts.version) {
    await cmdInstallCodex(env, opts.version);
    return;
  }

  // Default: install both codex-relay + codex CLI
  info("step 1/2: installing codex-relay ...");
  try {
    await cmdInstallSelf(opts);
  } catch (e) {
    if (opts.force) die(e.message);
    info(`codex-relay self-install skipped (${e.message})`);
  }

  info("step 2/2: checking Codex CLI ...");
  if (findCodex()) {
    info(`codex already installed (${codexVersion() || "unknown"})`);
  } else {
    await cmdInstallCodex(env);
  }

  info("install complete.");
}

function cmdRun(args) {
  const codexBin = findCodex() || die("'codex' not found. Install with: codex-relay install");

  // Set up proxy for codex
  const env = { ...process.env };

  // Prefer local forward proxy if running
  const noProxy = "localhost,127.0.0.1,::1,.local";

  const localPort = getLocalProxyPort();
  if (localPort) {
    env.HTTP_PROXY = `http://127.0.0.1:${localPort}`;
    env.HTTPS_PROXY = `http://127.0.0.1:${localPort}`;
    env.http_proxy = `http://127.0.0.1:${localPort}`;
    env.https_proxy = `http://127.0.0.1:${localPort}`;
    env.WS_PROXY = `http://127.0.0.1:${localPort}`;
    env.WSS_PROXY = `http://127.0.0.1:${localPort}`;
    env.NO_PROXY = noProxy;
    env.no_proxy = noProxy;
    info(`using local forward proxy: 127.0.0.1:${localPort}`);
  } else {
    const cfg = loadConfig();
    const proxyUrl = cfg.https || cfg.http;
    if (proxyUrl) {
      env.HTTP_PROXY = proxyUrl;
      env.HTTPS_PROXY = proxyUrl;
      env.http_proxy = proxyUrl;
      env.https_proxy = proxyUrl;
      env.WS_PROXY = proxyUrl;
      env.WSS_PROXY = proxyUrl;
      env.NO_PROXY = noProxy;
      env.no_proxy = noProxy;
      info(`using proxy: ${proxyUrl}`);
    }
  }

  const proc = spawn(codexBin, args, { env, stdio: "inherit" });
  proc.on("close", (code) => process.exit(code || 0));
  proc.on("error", () => process.exit(1));
}

