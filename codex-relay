#!/usr/bin/env node
// codex-relay — Node.js wrapper for OpenAI Codex CLI with proxy support.
// Requires Node.js >= 18 (built-in fetch, no npm dependencies).

const net = require("net");
const tls = require("tls");
const fs = require("fs");
const path = require("path");
const os = require("os");
const crypto = require("crypto");
const { spawn, execSync } = require("child_process");

// ── config ─────────────────────────────────────────────────────────────────

const NAME = "codex-relay";
const VERSION = "0.2.0";

// When running via sudo, use the original user's home, not /var/root
const SUDO_USER = process.env.SUDO_USER;
const REAL_HOME = (() => {
  if (!SUDO_USER) return os.homedir();
  try {
    const info = require("os").userInfo({ encoding: "utf8" });
    // macOS: userInfo doesn't take options; try to resolve from /Users or /home
  } catch {}
  // Heuristic: check common home dir patterns
  for (const prefix of ["/Users", "/home"]) {
    const candidate = path.join(prefix, SUDO_USER);
    try { if (fs.statSync(candidate).isDirectory()) return candidate; } catch {}
  }
  return os.homedir();
})();
const CONFIG_DIR = path.join(REAL_HOME, ".codex-relay");
const CONFIG_FILE = path.join(CONFIG_DIR, "config.json");
const CERT_DIR = path.join(CONFIG_DIR, "certs");
const SPLIT_EDGE_PID_FILE = path.join(CONFIG_DIR, "split-edge.pid");
const SPLIT_EDGE_HB_FILE = path.join(CONFIG_DIR, "split-edge.heartbeat");
const SPLIT_LOCAL_PID_FILE = path.join(CONFIG_DIR, "split-local.pid");
const SPLIT_LOCAL_HB_FILE = path.join(CONFIG_DIR, "split-local.heartbeat");
const SPLIT_TUNNEL_PID_FILE = path.join(CONFIG_DIR, "split-tunnel.pid");
// Resolve script path (handle relative paths for sudo)
const SCRIPT_PATH = (() => {
  try { return fs.realpathSync(process.argv[1]); } catch { return process.argv[1]; }
})();

// ── helpers ────────────────────────────────────────────────────────────────

function die(msg) {
  console.error(`error: ${msg}`);
  process.exit(1);
}
function info(msg) {
  console.error(`[${NAME}] ${msg}`);
}

function loadConfig() {
  try { return JSON.parse(fs.readFileSync(CONFIG_FILE, "utf8")); } catch { return {}; }
}
function saveConfig(cfg) {
  fs.mkdirSync(CONFIG_DIR, { recursive: true });
  fs.writeFileSync(CONFIG_FILE, JSON.stringify(cfg, null, 2));
}
// ── split proxy: certificate management ────────────────────────────────────

function shorthash(s) {
  return crypto.createHash("sha256").update(s).digest("hex").slice(0, 16);
}

function ensureSplitCACert() {
  fs.mkdirSync(CERT_DIR, { recursive: true });
  const caKeyPath = path.join(CERT_DIR, "ca-key.pem");
  const caCertPath = path.join(CERT_DIR, "ca-cert.pem");
  if (fs.existsSync(caKeyPath) && fs.existsSync(caCertPath)) {
    return { key: fs.readFileSync(caKeyPath, "utf8"), cert: fs.readFileSync(caCertPath, "utf8"), certPath: caCertPath };
  }
  if (!shutil("openssl")) die("openssl is required for split proxy mode. Install: apt install openssl");
  execSync(
    `openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 ` +
    `-days 3650 -nodes -keyout '${caKeyPath}' -out '${caCertPath}' ` +
    `-subj '/CN=CodexRelayLocalCA' 2>/dev/null`,
    { encoding: "utf8", timeout: 10000 }
  );
  // Verify generation
  try { execSync(`openssl verify -CAfile '${caCertPath}' '${caCertPath}' 2>/dev/null`, { encoding: "utf8" }); } catch {
    die("openssl CA cert generation failed — check openssl installation");
  }
  info(`split proxy CA generated at ${caCertPath}`);
  return { key: fs.readFileSync(caKeyPath, "utf8"), cert: fs.readFileSync(caCertPath, "utf8"), certPath: caCertPath };
}

function getSplitDomainCert(hostname) {
  const domainDir = path.join(CERT_DIR, shorthash(hostname));
  const keyPath = path.join(domainDir, "key.pem");
  const certPath = path.join(domainDir, "cert.pem");
  if (fs.existsSync(keyPath) && fs.existsSync(certPath)) {
    return { key: fs.readFileSync(keyPath, "utf8"), cert: fs.readFileSync(certPath, "utf8") };
  }
  fs.mkdirSync(domainDir, { recursive: true });
  const ca = ensureSplitCACert();
  // Write CA files to domain dir for openssl (needs file paths)
  const caKeyPath = path.join(CERT_DIR, "ca-key.pem");
  const caCertPath = path.join(CERT_DIR, "ca-cert.pem");
  // Generate domain key
  execSync(
    `openssl ecparam -genkey -name prime256v1 -noout -out '${keyPath}' 2>/dev/null`,
    { encoding: "utf8", timeout: 5000 }
  );
  // Generate CSR with SAN
  const csrPath = path.join(domainDir, "domain.csr");
  execSync(
    `openssl req -new -key '${keyPath}' -out '${csrPath}' ` +
    `-subj "/CN=${hostname}" -addext "subjectAltName=DNS:${hostname}" 2>/dev/null`,
    { encoding: "utf8", timeout: 5000 }
  );
  // Sign with CA
  execSync(
    `openssl x509 -req -in '${csrPath}' ` +
    `-CA '${caCertPath}' -CAkey '${caKeyPath}' -CAcreateserial ` +
    `-out '${certPath}' -days 365 -sha256 ` +
    `-extfile <(printf "subjectAltName=DNS:${hostname}\\n") 2>/dev/null`,
    { encoding: "utf8", shell: "/bin/bash", timeout: 5000 }
  );
  // Clean up CSR
  try { fs.unlinkSync(csrPath); } catch {}
  return { key: fs.readFileSync(keyPath, "utf8"), cert: fs.readFileSync(certPath, "utf8") };
}

const _splitCtxCache = new Map();
function getSplitSecureContext(hostname) {
  let ctx = _splitCtxCache.get(hostname);
  if (ctx) return ctx;
  const { key, cert } = getSplitDomainCert(hostname);
  ctx = tls.createSecureContext({ key, cert });
  _splitCtxCache.set(hostname, ctx);
  return ctx;
}

function findCodex() {
  try { return execSync("which codex", { encoding: "utf8" }).trim(); } catch { return null; }
}
function codexVersion() {
  const bin = findCodex();
  if (!bin) return null;
  try { return execSync(`"${bin}" --version`, { encoding: "utf8", timeout: 5000 }).trim(); } catch { return null; }
}

// Detect the shell config file for PATH setup.
// Returns { rc: absolute path, name: display name, home: user home dir }.
function detectShellRc() {
  let shell = process.env.SHELL || "";
  let home = os.homedir();

  // When running via sudo, resolve the original user's data
  if (SUDO_USER) {
    for (const prefix of ["/Users", "/home"]) {
      const candidate = path.join(prefix, SUDO_USER);
      try { if (fs.statSync(candidate).isDirectory()) { home = candidate; break; } } catch {}
    }
    // Get original user's shell
    try {
      if (process.platform === "darwin") {
        const out = execSync(`dscl . -read /Users/${SUDO_USER} UserShell 2>/dev/null`, { encoding: "utf8", timeout: 2000 });
        const m = out.match(/UserShell:\s*(\S+)/);
        if (m) shell = m[1];
      } else {
        shell = execSync(`getent passwd ${SUDO_USER} 2>/dev/null | cut -d: -f7`, { encoding: "utf8", timeout: 2000 }).trim() || shell;
      }
    } catch {}
  }

  const isBash = shell.includes("bash");
  const isZsh = shell.includes("zsh");

  if (isZsh) {
    return { rc: path.join(home, ".zshrc"), name: "~/.zshrc", home };
  }
  if (isBash) {
    // macOS bash sources .bash_profile for login shells; Linux uses .bashrc
    const bashProfile = path.join(home, ".bash_profile");
    if (fs.existsSync(bashProfile) || process.platform === "darwin") {
      return { rc: bashProfile, name: "~/.bash_profile", home };
    }
    return { rc: path.join(home, ".bashrc"), name: "~/.bashrc", home };
  }
  return { rc: path.join(home, ".profile"), name: "~/.profile", home };
}

function parseListenAddr(value) {
  const input = value || "127.0.0.1:8080";
  const idx = input.lastIndexOf(":");
  if (idx < 0) return { host: input, port: 8080 };
  const host = input.slice(0, idx) || "0.0.0.0";
  const port = parseInt(input.slice(idx + 1), 10);
  if (!port) die(`invalid listen address: ${input}`);
  return { host, port };
}

function connectTargetFromHead(headStr) {
  const firstSpace = headStr.indexOf(" ");
  if (firstSpace === -1) return null;
  const method = headStr.slice(0, firstSpace);

  if (method === "CONNECT") {
    const hostStart = firstSpace + 1;
    const hostEnd = headStr.indexOf(" ", hostStart);
    if (hostEnd === -1) return null;
    const hostPort = headStr.slice(hostStart, hostEnd);
    const colonIdx = hostPort.lastIndexOf(":");
    if (colonIdx === -1) return null;
    return {
      mode: "connect",
      host: hostPort.slice(0, colonIdx),
      port: parseInt(hostPort.slice(colonIdx + 1), 10),
    };
  }

  const urlStart = firstSpace + 1;
  const urlEnd = headStr.indexOf(" ", urlStart);
  if (urlEnd === -1) return null;
  const url = headStr.slice(urlStart, urlEnd);
  if (!url.startsWith("http://")) return null;

  const hostStart = 7;
  const pathStart = url.indexOf("/", hostStart);
  const hostPortPart = pathStart === -1 ? url.slice(hostStart) : url.slice(hostStart, pathStart);
  const colonIdx = hostPortPart.indexOf(":");
  const host2 = colonIdx === -1 ? hostPortPart : hostPortPart.slice(0, colonIdx);
  const port = colonIdx === -1 ? 80 : parseInt(hostPortPart.slice(colonIdx + 1), 10);
  const path = pathStart === -1 ? "/" : url.slice(pathStart);

  return { mode: "http", host: host2, port, method, path };
}

// ── split proxy: edge server (VPS side) ────────────────────────────────────

function handleSplitEdgeConnection(socket) {
  socket.setNoDelay(true);
  socket.setKeepAlive(true, 30000);
  let buf = Buffer.alloc(0);
  let targetSocket = null;

  socket.on("data", (chunk) => {
    if (targetSocket) {
      targetSocket.write(chunk);
      return;
    }
    buf = Buffer.concat([buf, chunk]);
    const metaEnd = buf.indexOf("\r\n\r\n");
    if (metaEnd === -1) return;
    const metaStr = buf.toString("utf8", 0, metaEnd);
    const m = metaStr.match(/^X-Target:\s*(.+):(\d+)\s*$/im);
    if (!m) {
      try { socket.write("HTTP/1.1 400 Bad Request\r\n\r\n"); socket.end(); } catch {}
      return;
    }
    const host = m[1].trim();
    const port = parseInt(m[2], 10);
    const remaining = buf.slice(metaEnd + 4);
    buf = null;
    const tlsSock = tls.connect({ host, port, servername: host, rejectUnauthorized: false }, () => {
      tlsSock.setNoDelay(true);
      tlsSock.setKeepAlive(true, 30000);
      targetSocket = tlsSock;
      if (remaining.length > 0) tlsSock.write(remaining);
      socket.pipe(tlsSock);
      tlsSock.pipe(socket);
      tlsSock.on("end", () => { try { socket.end(); } catch {} });
    });
    tlsSock.once("error", () => {
      try { socket.write("HTTP/1.1 502 Bad Gateway\r\n\r\n"); socket.end(); } catch {}
    });
  });

  socket.on("error", () => { try { targetSocket?.destroy(); } catch {} });
  socket.on("end", () => { try { targetSocket?.end(); } catch {} });
}

function startSplitEdge(opts) {
  const { host, port } = parseListenAddr(opts.listen || "127.0.0.1:19090");
  const server = net.createServer(handleSplitEdgeConnection);
  server.on("error", (e) => die(`split edge failed: ${e.message}`));
  server.listen(port, host, () => {
    info(`split edge listening on ${host}:${port}`);
    info("no token auth — use SSH tunnel or firewall for security");
  });
  return server;
}

// ── split proxy: local server (client side) ────────────────────────────────

function handleSplitLocalConnection(clientSocket, edgeHost, edgePort) {
  clientSocket.setNoDelay(true);
  clientSocket.once("data", (head) => {
    const headStr = head.toString();
    const target = connectTargetFromHead(headStr);
    if (!target) {
      try { clientSocket.write("HTTP/1.1 400 Bad Request\r\n\r\n"); clientSocket.end(); } catch {}
      return;
    }
    try {
      const ctx = getSplitSecureContext(target.host);
      clientSocket.write("HTTP/1.1 200 Connection Established\r\n\r\n");
      const tlsSocket = new tls.TLSSocket(clientSocket, {
        isServer: true,
        secureContext: ctx,
        ALPNProtocols: ["http/1.1"],
      });
      let pending = [];
      tlsSocket.on("data", (d) => { pending.push(d); });
      tlsSocket.once("error", () => { try { edgeSocket?.destroy(); } catch {} });

      const meta = `X-Target: ${target.host}:${target.port}\r\n\r\n`;
      const edgeSocket = net.connect(edgePort, edgeHost, () => {
        edgeSocket.setNoDelay(true);
        edgeSocket.setKeepAlive(true, 30000);
        edgeSocket.write(meta);
        // Flush buffered data from codex (arrived during TLS handshake)
        for (const p of pending) edgeSocket.write(p);
        pending = null;
        tlsSocket.removeAllListeners("data");
        tlsSocket.pipe(edgeSocket);
        edgeSocket.pipe(tlsSocket);
      });
      edgeSocket.once("error", () => { try { tlsSocket.destroy(); } catch {} });
    } catch (e) {
      try { clientSocket.write("HTTP/1.1 500 Internal Server Error\r\n\r\n"); clientSocket.end(); } catch {}
    }
  });
  clientSocket.on("error", () => {});
}

function startSplitLocal(opts) {
  const { host, port } = parseListenAddr(opts.listen || "127.0.0.1:18443");
  // Ensure CA certs exist before accepting connections
  const ca = ensureSplitCACert();
  info(`split local CA: ${ca.certPath}`);
  info(`install CA cert on this machine: NODE_EXTRA_CA_CERTS=${ca.certPath}`);
  const server = net.createServer((socket) => handleSplitLocalConnection(socket, opts.edgeHost, opts.edgePort));
  server.on("error", (e) => die(`split local failed: ${e.message}`));
  server.listen(port, host, () => {
    info(`split local listening on ${host}:${port}`);
    info(`edge: ${opts.edgeHost}:${opts.edgePort}`);
  });
  return server;
}

// ── split proxy: daemon management ─────────────────────────────────────────

function isSplitEdgeRunning() {
  try { process.kill(parseInt(fs.readFileSync(SPLIT_EDGE_PID_FILE, "utf8").trim(), 10), 0); return true; } catch { return false; }
}
function isSplitLocalRunning() {
  try { process.kill(parseInt(fs.readFileSync(SPLIT_LOCAL_PID_FILE, "utf8").trim(), 10), 0); return true; } catch { return false; }
}

function runSplitEdgeDaemon() {
  process.title = "codex-relay-split-edge";
  const cfg = loadConfig();
  const listen = cfg.split?.edge_listen || "127.0.0.1:19090";
  process.on("uncaughtException", (e) => { try { fs.unlinkSync(SPLIT_EDGE_PID_FILE); } catch {} process.exit(1); });
  const hbInterval = setInterval(() => { try { fs.writeFileSync(SPLIT_EDGE_HB_FILE, String(Date.now())); } catch {} }, 60000);
  const server = startSplitEdge({ listen });
  fs.writeFileSync(SPLIT_EDGE_PID_FILE, String(process.pid));
  try { process.stdin.destroy(); } catch {}
  try { process.stdout.destroy(); } catch {}
  try { process.stderr.destroy(); } catch {}
  try { fs.closeSync(0); } catch {}
  try { fs.closeSync(1); } catch {}
  try { fs.closeSync(2); } catch {}
  const cleanup = () => {
    clearInterval(hbInterval);
    try { server.close(); } catch {}
    try { fs.unlinkSync(SPLIT_EDGE_PID_FILE); } catch {}
    try { fs.unlinkSync(SPLIT_EDGE_HB_FILE); } catch {}
    process.exit(0);
  };
  process.on("SIGTERM", cleanup);
  process.on("SIGINT", cleanup);
}

function runSplitLocalDaemon() {
  process.title = "codex-relay-split-local";
  const cfg = loadConfig();
  const edgePort = parseListenAddr(cfg.split?.edge_listen || "127.0.0.1:19090").port;
  const listen = cfg.split?.local_listen || "127.0.0.1:18443";
  process.on("uncaughtException", (e) => { try { fs.unlinkSync(SPLIT_LOCAL_PID_FILE); } catch {} process.exit(1); });
  const hbInterval = setInterval(() => { try { fs.writeFileSync(SPLIT_LOCAL_HB_FILE, String(Date.now())); } catch {} }, 60000);
  const server = startSplitLocal({ listen, edgeHost: "127.0.0.1", edgePort });

  // Tunnel watchdog: check every 30s, re-establish if died
  const tunnelWatchdog = setInterval(() => {
    if (!_tunnelPidAlive()) {
      try {
        const cfg2 = loadConfig();
        if (cfg2.split?.ssh) {
          info("SSH tunnel died — re-establishing...");
          try { fs.unlinkSync(SPLIT_TUNNEL_PID_FILE); } catch {}
          const ep = parseListenAddr(cfg2.split.edge_listen || "127.0.0.1:19090").port;
          _ensureSshTunnel(cfg2.split.ssh, ep, cfg2.split.ssh_key);
        }
      } catch (e) {
        // Keep retrying on next interval — don't crash the daemon
      }
    }
  }, 30000);

  fs.writeFileSync(SPLIT_LOCAL_PID_FILE, String(process.pid));
  try { process.stdin.destroy(); } catch {}
  try { process.stdout.destroy(); } catch {}
  try { process.stderr.destroy(); } catch {}
  try { fs.closeSync(0); } catch {}
  try { fs.closeSync(1); } catch {}
  try { fs.closeSync(2); } catch {}
  const cleanup = () => {
    clearInterval(tunnelWatchdog);
    clearInterval(hbInterval);
    try { server.close(); } catch {}
    try { fs.unlinkSync(SPLIT_LOCAL_PID_FILE); } catch {}
    try { fs.unlinkSync(SPLIT_LOCAL_HB_FILE); } catch {}
    _cleanupSplitTunnel();
    process.exit(0);
  };
  process.on("SIGTERM", cleanup);
  process.on("SIGINT", cleanup);
}

// ── CLI handlers ───────────────────────────────────────────────────────────

function cmdProxySet(url) {
  if (!url) die(`usage: ${NAME} proxy set <url>`);
  const cfg = loadConfig();
  cfg.http = url;
  cfg.https = url;
  saveConfig(cfg);
  info(`proxy set to: ${url}`);
}

function cmdProxyShow() {
  const cfg = loadConfig();

  if (process.env.HTTP_PROXY) console.log(`env proxy:       ${process.env.HTTP_PROXY}`);
  else if (process.env.http_proxy) console.log(`env proxy:       ${process.env.http_proxy}`);
  if (cfg.http) console.log(`config proxy:    ${cfg.http}`);
  if (cfg.http || process.env.HTTP_PROXY || process.env.http_proxy) {
    console.log(`effective proxy: ${cfg.http || process.env.HTTP_PROXY || process.env.http_proxy}`);
  } else {
    console.log(`effective proxy: none`);
  }

}

function cmdProxyUnset() {
  const cfg = loadConfig();
  delete cfg.http;
  delete cfg.https;
  saveConfig(cfg);
  info("proxy configuration cleared.");
}

function _splitDaemonStart(kind, spawnArgs) {
  const checkFn = kind === "edge" ? isSplitEdgeRunning : isSplitLocalRunning;
  const pidFile = kind === "edge" ? SPLIT_EDGE_PID_FILE : SPLIT_LOCAL_PID_FILE;
  if (checkFn()) {
    info(`split ${kind} already running (pid ${fs.readFileSync(pidFile, "utf8").trim()})`);
    return;
  }
  const child = spawn(process.execPath, spawnArgs, { detached: true, stdio: ["ignore", "ignore", "pipe"] });
  let errBuf = "";
  child.stderr.on("data", (c) => { errBuf += c.toString(); });
  child.unref();
  for (let i = 0; i < 20; i++) {
    if (checkFn()) break;
    execSync("sleep 0.1", { stdio: "ignore" });
  }
  if (!checkFn()) die(`failed to start split ${kind} daemon${errBuf ? ":\n" + errBuf.trim() : ""}`);
  info(`split ${kind} started (pid ${fs.readFileSync(pidFile, "utf8").trim()})`);
}

function _cleanupSplitTunnel() {
  try {
    const pid = parseInt(fs.readFileSync(SPLIT_TUNNEL_PID_FILE, "utf8").trim(), 10);
    if (pid) { process.kill(pid, "SIGTERM"); }
  } catch {}
  try { fs.unlinkSync(SPLIT_TUNNEL_PID_FILE); } catch {}
}

function _splitDaemonStop(kind) {
  const pidFile = kind === "edge" ? SPLIT_EDGE_PID_FILE : SPLIT_LOCAL_PID_FILE;
  const hbFile = kind === "edge" ? SPLIT_EDGE_HB_FILE : SPLIT_LOCAL_HB_FILE;
  const checkFn = kind === "edge" ? isSplitEdgeRunning : isSplitLocalRunning;
  if (!checkFn()) { info(`split ${kind} not running.`); return; }
  const pid = parseInt(fs.readFileSync(pidFile, "utf8").trim(), 10);
  try { process.kill(pid, "SIGTERM"); } catch {}
  try { fs.unlinkSync(pidFile); } catch {}
  try { fs.unlinkSync(hbFile); } catch {}
  if (kind === "local") _cleanupSplitTunnel();
  info(`split ${kind} stopped.`);
}

function _splitDaemonStatus(kind) {
  const pidFile = kind === "edge" ? SPLIT_EDGE_PID_FILE : SPLIT_LOCAL_PID_FILE;
  const hbFile = kind === "edge" ? SPLIT_EDGE_HB_FILE : SPLIT_LOCAL_HB_FILE;
  const checkFn = kind === "edge" ? isSplitEdgeRunning : isSplitLocalRunning;
  if (!checkFn()) { console.log(`split ${kind}:  stopped`); return; }
  const pid = fs.readFileSync(pidFile, "utf8").trim();
  const hbAge = (() => {
    try { return `${Math.round((Date.now() - parseInt(fs.readFileSync(hbFile, "utf8"), 10)) / 1000)}s ago`; }
    catch { return "N/A"; }
  })();
  console.log(`split ${kind}:  running (pid ${pid})`);
  console.log(`  heartbeat:   ${hbAge}`);
}

function _tunnelPidAlive() {
  try {
    const pid = parseInt(fs.readFileSync(SPLIT_TUNNEL_PID_FILE, "utf8").trim(), 10);
    if (!pid) return false;
    process.kill(pid, 0);
    return true;
  } catch { return false; }
}

// Parse SSH connection string: user@host
function _parseSsh(s) {
  const atIdx = s.indexOf("@");
  if (atIdx < 0) return { user: "root", host: s };
  return { user: s.slice(0, atIdx), host: s.slice(atIdx + 1) };
}

function _ensureSshTunnel(sshTarget, edgePort, sshKey) {
  if (_tunnelPidAlive()) return;
  try { fs.unlinkSync(SPLIT_TUNNEL_PID_FILE); } catch {}

  const { user, host } = _parseSsh(sshTarget);
  const keyArg = sshKey ? ["-i", sshKey] : [];
  const sshArgs = [
    "-o", "StrictHostKeyChecking=no",
    "-o", "ExitOnForwardFailure=yes",
    "-o", "ServerAliveInterval=30",
    "-o", "ServerAliveCountMax=3",
    "-o", "TCPKeepAlive=yes",
    "-N", "-f",
    "-L", `${edgePort}:127.0.0.1:${edgePort}`,
    ...keyArg,
    `${user}@${host}`,
  ];

  function trySsh() {
    execSync(`ssh ${sshArgs.map((a) => `'${a}'`).join(" ")} 2>&1`, { encoding: "utf8", timeout: 15000, stdio: "pipe" });
  }

  info(`establishing SSH tunnel: 127.0.0.1:${edgePort} → ${host}:${edgePort}`);
  try {
    trySsh();
  } catch (e) {
    const msg = (e.stderr || e.stdout || e.message || "").toString();
    if (msg.includes("ddress already in use") || msg.includes("bind")) {
      info(`port ${edgePort} in use — freeing and retrying...`);
      try { execSync(`fuser -k ${edgePort}/tcp 2>/dev/null`, { encoding: "utf8", timeout: 3000 }); } catch {}
      execSync("sleep 0.5", { stdio: "ignore" });
      try {
        trySsh();
      } catch (e2) {
        const msg2 = (e2.stderr || e2.stdout || e2.message || "").toString();
        if (msg2.includes("ddress already in use") || msg2.includes("bind")) {
          let who = "";
          try { who = execSync(`fuser -v ${edgePort}/tcp 2>&1`, { encoding: "utf8", timeout: 2000 }).trim(); } catch {}
          if (!who) {
            try { who = execSync(`ss -tlnp 'sport = :${edgePort}' 2>&1`, { encoding: "utf8", timeout: 2000 }).trim(); } catch {}
          }
          throw new Error(`port ${edgePort} is in use by another process:\n${who || "  (try: sudo fuser -v " + edgePort + "/tcp)"}\n  Free it (sudo fuser -k ${edgePort}/tcp) or use a different port.`);
        }
        throw new Error(`ssh tunnel failed: ${msg2.trim()}`);
      }
    } else {
      throw new Error(`ssh tunnel failed: ${msg.trim()}`);
    }
  }

  for (let i = 0; i < 20; i++) {
    execSync("sleep 0.15", { stdio: "ignore" });
    try {
      const out = execSync(`fuser ${edgePort}/tcp 2>/dev/null`, { encoding: "utf8", timeout: 2000 }).trim();
      const pid = out.split(/\s+/).filter(Boolean).pop();
      if (pid) {
        fs.writeFileSync(SPLIT_TUNNEL_PID_FILE, pid);
        info(`SSH tunnel up (pid ${pid})`);
        return;
      }
    } catch {}
  }
  throw new Error(`SSH tunnel not reachable on port ${edgePort} after 3s`);
}

function cmdSplit(args) {
  const action = args[0];
  const opts = parseArgs(args.slice(1));

  switch (action) {
    case "start": {
      const isEdge = opts.edge;
      const hasSsh = opts.ssh;

      if (isEdge) {
        // Edge mode: listen on this machine for incoming local proxies
        const cfg = loadConfig();
        const listen = opts.listen || cfg.split?.edge_listen || "127.0.0.1:19090";
        cfg.split = cfg.split || {};
        cfg.split.edge_listen = listen;
        saveConfig(cfg);
        _splitDaemonStart("edge", [SCRIPT_PATH, "--_split-edge-daemon"]);
        return;
      }

      if (hasSsh) {
        // Local mode: start local proxy with SSH tunnel to VPS edge
        const cfg = loadConfig();
        cfg.split = cfg.split || {};
        cfg.split.ssh = hasSsh;
        if (opts["ssh-key"]) cfg.split.ssh_key = opts["ssh-key"];
        if (opts.listen) cfg.split.local_listen = opts.listen;
        saveConfig(cfg);
        const edgePort = parseListenAddr(cfg.split.edge_listen || "127.0.0.1:19090").port;
        try { _ensureSshTunnel(hasSsh, edgePort, opts["ssh-key"]); }
        catch (e) { die(e.message); }
        _splitDaemonStart("local", [SCRIPT_PATH, "--_split-local-daemon"]);
        return;
      }

      // No flags: try saved config
      const cfg = loadConfig();
      if (cfg.split?.ssh) {
        // Auto-start local with saved SSH config
        const edgePort = parseListenAddr(cfg.split.edge_listen || "127.0.0.1:19090").port;
        try { _ensureSshTunnel(cfg.split.ssh, edgePort, cfg.split.ssh_key); }
        catch (e) { die(e.message); }
        _splitDaemonStart("local", [SCRIPT_PATH, "--_split-local-daemon"]);
        return;
      }
      die(`usage: ${NAME} split start [--edge] [--ssh user@host] [--listen addr]\n` +
          `  --edge             start VPS edge daemon\n` +
          `  --ssh user@host    start local daemon with SSH tunnel`);
    }

    case "stop":
      _splitDaemonStop("local");
      _splitDaemonStop("edge");
      break;

    case "status":
      _splitDaemonStatus("local");
      console.log(""); // blank line between local and edge
      _splitDaemonStatus("edge");
      // Show SSH tunnel status if present
      if (_tunnelPidAlive()) {
        try {
          const pid = fs.readFileSync(SPLIT_TUNNEL_PID_FILE, "utf8").trim();
          console.log(`ssh tunnel:   running (pid ${pid})`);
        } catch {}
      }
      break;

    case "check":
      cmdSplitCheck(opts);
      break;

    default:
      die(`usage: ${NAME} split {start|stop|status|check}`);
  }
}

function cmdProxyCheck(opts = {}) {
  const testUrl = opts.url || "https://api.openai.com";
  const timeout = opts.timeout || 10;

  const issues = [];
  const ok = [];

  const check = (label, condition, detail) => {
    if (condition) {
      ok.push(label + (detail ? ` (${detail})` : ""));
    } else {
      issues.push(label + (detail ? ` — ${detail}` : ""));
    }
  };

  // 1. Proxy config
  const cfg = loadConfig();
  const proxyUrl = process.env.HTTPS_PROXY || process.env.https_proxy ||
                   process.env.HTTP_PROXY || process.env.http_proxy ||
                   cfg.https || cfg.http;
  check("proxy config", !!proxyUrl, proxyUrl || "not configured — run: proxy set <url>");

  // 2. curl available
  const haveCurl = !!shutil("curl");
  check("curl", haveCurl, haveCurl ? "available" : "not found — required for proxy check");

  // 3. Proxy connectivity
  if (proxyUrl && haveCurl) {
    const start = Date.now();
    try {
      const out = execSync(
        `curl -s -o /dev/null -w '%{http_code}' --proxy '${proxyUrl}' --connect-timeout ${timeout} --max-time ${timeout} '${testUrl}'`,
        { encoding: "utf8", timeout: (timeout + 5) * 1000 }
      ).trim();
      const latency = Date.now() - start;
      const code = parseInt(out, 10);
      check("proxy connectivity", code >= 200 && code < 500, `HTTP ${out}, ${latency}ms → ${testUrl}`);
    } catch {
      check("proxy connectivity", false, `connection failed → ${testUrl}`);
    }
  } else if (!haveCurl) {
    check("proxy connectivity", false, "curl not available");
  } else {
    check("proxy connectivity", false, "no proxy configured");
  }

  // 4. npm available
  const haveNpm = !!shutil("npm");
  check("npm", haveNpm, haveNpm ? "available" : "not found — needed for codex install");

  // 5. codex binary
  const codexBin = findCodex();
  check("codex CLI", !!codexBin, codexBin ? codexVersion() : "not installed — run: install");

  // ── Results ──
  console.log("codex-relay proxy check\n");
  for (const item of ok) {
    console.log(`  ✓ ${item}`);
  }
  if (issues.length > 0) {
    console.log("");
    for (const item of issues) {
      console.log(`  ✗ ${item}`);
    }
  }
  console.log("");
  console.log(`${ok.length} OK, ${issues.length} issue${issues.length !== 1 ? "s" : ""}`);

  if (issues.length > 0) process.exit(1);
}

function cmdSplitCheck(opts = {}) {
  const testUrl = opts.url || "https://api.openai.com";
  const timeout = opts.timeout || 10;
  const edgeAddr = opts.edge || "127.0.0.1:19090";

  const issues = [];
  const ok = [];

  const check = (label, condition, detail) => {
    if (condition) ok.push(label + (detail ? ` (${detail})` : ""));
    else issues.push(label + (detail ? ` — ${detail}` : ""));
  };

  // 1. openssl
  const haveOpenssl = !!shutil("openssl");
  check("openssl", haveOpenssl, haveOpenssl ? "available" : "not found — required for local TLS termination");

  // 2. CA cert
  const caCertPath = path.join(CERT_DIR, "ca-cert.pem");
  const haveCACert = fs.existsSync(caCertPath);
  check("CA certificate", haveCACert, haveCACert ? caCertPath : "not found — run: split local (generates on first start)");

  // 3. curl
  const haveCurl = !!shutil("curl");
  check("curl", haveCurl, haveCurl ? "available" : "not found — required for connectivity test");

  // 4. Edge proxy reachable
  if (haveCurl) {
    const { host: edgeHost, port: edgePort } = parseListenAddr(edgeAddr);
    const edgeReachable = (() => {
      try {
        execSync(`timeout 2 bash -c 'echo >/dev/tcp/${edgeHost}/${edgePort}' 2>/dev/null`, { timeout: 3000 });
        return true;
      } catch { return false; }
    })();
    check("edge proxy", edgeReachable, `TCP ${edgeAddr}` + (edgeReachable ? " open" : " unreachable — check SSH tunnel or edge server"));

    // 5. Full split proxy chain
    if (edgeReachable && haveCACert && haveCurl) {
      const tempListen = "127.0.0.1:18448";
      const tempAddr = parseListenAddr(tempListen);
      // Spawn a temporary local proxy as a subprocess (avoids event-loop blocking)
      const tempProc = spawn(process.execPath, [SCRIPT_PATH, "split", "local", "--edge", edgeAddr, "--listen", tempListen], {
        stdio: "ignore",
        detached: true,
      });
      // Wait for it to start listening
      for (let i = 0; i < 20; i++) {
        execSync("sleep 0.1", { stdio: "ignore" });
        try { const s = net.connect(tempAddr.port, tempAddr.host); s.destroy(); break; } catch {}
      }
      const start = Date.now();
      try {
        const out = execSync(
          `curl -s -S -o /dev/null -w '%{http_code}' --cacert '${caCertPath}' --proxy 'http://${tempListen}' --connect-timeout ${timeout} --max-time ${timeout} '${testUrl}' 2>&1`,
          { encoding: "utf8", timeout: (timeout + 5) * 1000 }
        ).trim();
        const latency = Date.now() - start;
        const code = parseInt(out, 10);
        check("split proxy chain", code >= 200 && code < 500, `HTTP ${out}, ${latency}ms → ${testUrl}`);
      } catch (e) {
        const latency = Date.now() - start;
        const cause = e.stderr ? e.stderr.toString().trim().slice(0, 80) : (e.message || "").slice(0, 80);
        check("split proxy chain", false, `failed after ${latency}ms: ${cause} → ${testUrl}`);
      }
      try { process.kill(tempProc.pid, "SIGTERM"); } catch {}
    }
  } else {
    check("edge proxy", false, "curl not available");
    check("split proxy chain", false, "curl not available");
  }

  // ── Results ──
  console.log("codex-relay split check\n");
  for (const item of ok) console.log(`  ✓ ${item}`);
  if (issues.length > 0) {
    console.log("");
    for (const item of issues) console.log(`  ✗ ${item}`);
  }
  console.log("");
  console.log(`${ok.length} OK, ${issues.length} issue${issues.length !== 1 ? "s" : ""}`);

  if (issues.length > 0) process.exit(1);
}

function shutil(name) {
  try { execSync(`which ${name}`, { encoding: "utf8", stdio: "ignore" }); return true; } catch { return false; }
}

async function cmdInstallSelf(opts = {}) {
  const isRoot = process.getuid && process.getuid() === 0;

  // Candidate install directories: first writable one wins
  const candidates = [
    "/usr/local/bin",
    ...(isRoot ? ["/usr/local/sbin"] : []),
    path.join(os.homedir(), ".local", "bin"),
    path.join(os.homedir(), "bin"),
  ];

  let binDir = null;
  let dest = null;

  for (const dir of candidates) {
    dest = path.join(dir, NAME);
    try {
      fs.mkdirSync(dir, { recursive: true });
      const testFile = path.join(dir, `.${NAME}.write-test`);
      fs.writeFileSync(testFile, "", { mode: 0o644 });
      fs.unlinkSync(testFile);
      binDir = dir;
      break;
    } catch {
      continue;
    }
  }

  if (!binDir) {
    throw new Error(
      `no writable bin directory found. Tried: ${candidates.join(", ")}.\n` +
      `  Run with sudo or create a directory: mkdir -p ~/.local/bin && export PATH="$HOME/.local/bin:$PATH"`
    );
  }

  let scriptContent;
  if (opts.url) {
    info(`downloading from ${opts.url} ...`);
    const resp = await fetch(opts.url);
    if (!resp.ok) die(`download failed: ${resp.status}`);
    scriptContent = await resp.text();
  } else {
    scriptContent = fs.readFileSync(SCRIPT_PATH, "utf8");
  }

  // Check if already installed — prompt unless --force
  if (dest && fs.existsSync(dest) && !opts.force) {
    const readline = require("readline");
    const rl = readline.createInterface({ input: process.stdin, output: process.stderr });
    const answer = await new Promise((res) => {
      rl.question(`  ${NAME} already exists at ${dest}. Overwrite? [y/N] `, (a) => {
        rl.close();
        res(a.trim().toLowerCase());
      });
    });
    if (answer !== "y" && answer !== "yes") {
      info("skipped.");
      return;
    }
  }

  // Write to bin directory
  try {
    fs.writeFileSync(dest, scriptContent, { mode: 0o755 });

    // Check if the binary is findable right now
    const inPath = process.env.PATH.split(":").some((p) => path.resolve(p) === path.resolve(binDir));
    let findable = false;
    try {
      execSync(`command -v ${NAME}`, { encoding: "utf8", timeout: 2000 }).trim();
      findable = true;
    } catch {}

    const { rc, name: shellRc, home } = detectShellRc();

    if (findable && !SUDO_USER) {
      info(`installed to ${dest}`);
      info(`  ✓ on PATH — run: ${NAME} --help`);
    } else if (findable && SUDO_USER) {
      info(`installed to ${dest} (system-wide)`);
    } else if (inPath) {
      info(`installed to ${dest}`);
      info(`  hint: refresh shell cache — run: hash -r`);
    } else {
      // Not on PATH — provide exact setup instructions
      const exportLine = `export PATH="${binDir}:\\$PATH"`;

      info(`installed to ${dest}`);
      info(`  bin directory ${binDir} is not on PATH. To add it:`);
      info(``);
      info(`    echo '${exportLine}' >> ${shellRc}`);
      info(`    source ${shellRc}`);
      info(``);

      // For macOS bash users, also mention sourcing from .bash_profile
      if (shellRc.endsWith(".bashrc") && !fs.existsSync(rc)) {
        const bp = path.join(home, ".bash_profile");
        if (fs.existsSync(bp)) {
          info(`  note: macOS bash loads ~/.bash_profile. Make sure it sources ~/.bashrc:`);
          info(`    echo '[ -f ~/.bashrc ] && source ~/.bashrc' >> ~/.bash_profile`);
        }
      }

      // When running via sudo, remind about the original user
      if (SUDO_USER) {
        info(`  note: the PATH change above applies to user ${SUDO_USER}, not root`);
      }

      if (SUDO_USER) {
        info(`  After setup, run as ${SUDO_USER}: ${NAME} --help`);
      } else {
        info(`  Then: ${NAME} --help`);
      }
    }
  } catch (e) {
    throw e;
  }
}

async function cmdInstallCodex(env, version) {
  const npm = "npm";
  try { execSync("which npm", { encoding: "utf8" }); } catch { die("npm not found. Install Node.js: https://nodejs.org"); }

  let pkg = "@openai/codex";
  if (version) pkg += `@${version}`;
  info(`installing ${pkg} ...`);
  const proc = spawn(npm, ["install", "-g", pkg], { env, stdio: "inherit" });
  await new Promise((res) => proc.on("close", res));
  const ver = codexVersion();
  info(`installed: ${ver || "latest"}`);
}

async function cmdUpdateCodex(env) {
  const npm = "npm";
  try { execSync("which npm", { encoding: "utf8" }); } catch { die("npm not found. Install Node.js: https://nodejs.org"); }
  info("updating @openai/codex ...");
  const proc = spawn(npm, ["update", "-g", "@openai/codex"], { env, stdio: "inherit" });
  await new Promise((res) => proc.on("close", res));
  const ver = codexVersion();
  info(`updated: ${ver || "latest"}`);
}

async function cmdInstall(opts = {}) {
  // Apply proxy
  const cfg = loadConfig();
  const proxyUrl = cfg.https || cfg.http;
  const env = { ...process.env };
  if (proxyUrl) {
    env.HTTP_PROXY = proxyUrl;
    env.HTTPS_PROXY = proxyUrl;
    env.http_proxy = proxyUrl;
    env.https_proxy = proxyUrl;
    env.NO_PROXY = "localhost,127.0.0.1,::1,.local";
    env.no_proxy = "localhost,127.0.0.1,::1,.local";
  }

  // Explicit flags — do exactly what was asked
  if (opts.update) {
    await cmdUpdateCodex(env);
    return;
  }
  if (opts.version) {
    await cmdInstallCodex(env, opts.version);
    return;
  }

  // Default: install both codex-relay + codex CLI
  info("step 1/2: installing codex-relay ...");
  try {
    await cmdInstallSelf(opts);
  } catch (e) {
    if (opts.force) die(e.message);
    info(`codex-relay self-install skipped (${e.message})`);
  }

  info("step 2/2: checking Codex CLI ...");
  if (findCodex()) {
    info(`codex already installed (${codexVersion() || "unknown"})`);
  } else {
    await cmdInstallCodex(env);
  }

  info("install complete.");
}

function cmdRun(args) {
  const codexBin = findCodex() || die("'codex' not found. Install with: codex-relay install");

  // Set up proxy for codex
  const env = { ...process.env };
  const noProxy = "localhost,127.0.0.1,::1,.local";

  const cfg = loadConfig();
  const proxyUrl = process.env.HTTPS_PROXY || process.env.https_proxy ||
                   process.env.HTTP_PROXY || process.env.http_proxy ||
                   cfg.https || cfg.http;
  if (proxyUrl) {
    env.HTTP_PROXY = proxyUrl;
    env.HTTPS_PROXY = proxyUrl;
    env.http_proxy = proxyUrl;
    env.https_proxy = proxyUrl;
    env.WS_PROXY = proxyUrl;
    env.WSS_PROXY = proxyUrl;
    env.NO_PROXY = noProxy;
    env.no_proxy = noProxy;
    info(`using proxy: ${proxyUrl}`);
  }

  // Split proxy mode: inject local CA cert so codex trusts TLS-terminated connections
  const caCertPath = path.join(CERT_DIR, "ca-cert.pem");
  if (proxyUrl && (proxyUrl.includes("127.0.0.1") || proxyUrl.includes("localhost")) && fs.existsSync(caCertPath)) {
    env.NODE_EXTRA_CA_CERTS = caCertPath;
  }

  const proc = spawn(codexBin, args, { env, stdio: "inherit" });
  proc.on("close", (code) => process.exit(code || 0));
  proc.on("error", () => process.exit(1));
}

