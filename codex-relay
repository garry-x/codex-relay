function startChainRelay({ listen, upstreamUrl, upstreams, token, tokenHash, tlsCert, tlsKey }) {
  const { host: listenHost, port: listenPort } = parseListenAddr(listen);
  const upstreamList = chainUpstreams(upstreams || upstreamUrl);
  const upstreamAuths = upstreamList.map(u => u === "direct" ? "" : parseProxyUrl(u).auth);
  if (upstreamList.length === 0) die("chain relay requires at least one upstream or direct");
  if (!tokenHash && !token) die("chain relay requires token authentication");
  const timeoutMs = 10000;

  const handle = (clientSocket) => {
    clientSocket.setNoDelay(true);
    clientSocket.setKeepAlive(true, 30000);
    const reqId = crypto.randomBytes(4).toString("hex");
    clientSocket.once("data", async (head) => {
      const headStr = head.toString();
      const presentedToken = proxyAuthToken(headStr);
      if (!tokenMatches(presentedToken, tokenHash || token)) {
        try {
          clientSocket.write("HTTP/1.1 407 Proxy Authentication Required\r\nProxy-Authenticate: Basic realm=\"codex-relay-chain\"\r\n\r\n");
          clientSocket.end();
        } catch {}
        chainLog(`${reqId} auth failed`);
        return;
      }
      const target = connectTargetFromHead(headStr);
      if (!target) {
        chainLog(`${reqId} bad request`);
        try { clientSocket.write("HTTP/1.1 400 Bad Request\r\n\r\n"); clientSocket.end(); } catch {}
        return;
      }

      const prepared = prepareChainTarget(headStr, target, reqId);
      const preparedHead = prepared.headStr;
      const preparedTarget = prepared.target;

      chainLog(`${reqId} ${preparedTarget.mode.toUpperCase()} ${preparedTarget.originalHost}:${preparedTarget.port} via ${preparedTarget.host}`);
      for (let i = 0; i < upstreamList.length; i++) {
        const ok = await tryChainUpstream(clientSocket, preparedHead, upstreamList[i], upstreamAuths[i], preparedTarget, reqId, timeoutMs);
        if (ok) return;
      }
      chainLog(`${reqId} all upstreams failed`);
      try { clientSocket.write("HTTP/1.1 502 Bad Gateway\r\n\r\n"); clientSocket.end(); } catch {}
    });
    clientSocket.on("error", () => {});
  };

  const server = (tlsCert && tlsKey)
    ? tls.createServer({ cert: fs.readFileSync(tlsCert), key: fs.readFileSync(tlsKey) }, handle)
    : net.createServer(handle);
  server.on("error", (e) => die(`chain relay failed: ${e.message}`));
  server.listen(listenPort, listenHost, () => {
    chainLog(`chain relay listening on ${listenHost}:${listenPort}`);
    info(`chain relay listening on ${listenHost}:${listenPort}${tlsCert ? " (TLS)" : ""}`);
    info(`upstreams: ${upstreamList.map(redactProxyUrl).join(", ")}`);
    info("client auth: enabled");
  });
  return server;
}

