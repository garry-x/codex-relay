#!/usr/bin/env node
// codex-relay — Node.js wrapper for OpenAI Codex CLI with proxy support.
// Requires Node.js >= 18 (built-in fetch, no npm dependencies).

const fs = require("fs");
const path = require("path");
const os = require("os");
const { spawn, execSync } = require("child_process");

// ═══════════════════════════════════════════════════════════════════════════
// config
// ═══════════════════════════════════════════════════════════════════════════

const NAME = "codex-relay";
const VERSION = "0.4.0";

// When running via sudo, use the original user's home, not /var/root
const SUDO_USER = process.env.SUDO_USER;
const REAL_HOME = (() => {
  if (!SUDO_USER) return os.homedir();
  for (const prefix of ["/Users", "/home"]) {
    const candidate = path.join(prefix, SUDO_USER);
    try { if (fs.statSync(candidate).isDirectory()) return candidate; } catch {}
  }
  return os.homedir();
})();
const CONFIG_DIR = path.join(REAL_HOME, ".codex-relay");
const CONFIG_FILE = path.join(CONFIG_DIR, "config.json");

// Resolve script path (handle relative paths for sudo)
const SCRIPT_PATH = (() => {
  try { return fs.realpathSync(process.argv[1]); } catch { return process.argv[1]; }
})();

// ═══════════════════════════════════════════════════════════════════════════
// helpers
// ═══════════════════════════════════════════════════════════════════════════

function die(msg) {
  console.error(`error: ${msg}`);
  process.exit(1);
}
function info(msg) {
  console.error(`[${NAME}] ${msg}`);
}

function loadConfig() {
  try { return JSON.parse(fs.readFileSync(CONFIG_FILE, "utf8")); } catch { return {}; }
}
function saveConfig(cfg) {
  fs.mkdirSync(CONFIG_DIR, { recursive: true });
  fs.writeFileSync(CONFIG_FILE, JSON.stringify(cfg, null, 2));
}

function findCodex() {
  try { return execSync("which codex", { encoding: "utf8" }).trim(); } catch { return null; }
}
function codexVersion() {
  const bin = findCodex();
  if (!bin) return null;
  try { return execSync(`"${bin}" --version`, { encoding: "utf8", timeout: 5000 }).trim(); } catch { return null; }
}

function shutil(name) {
  try { execSync(`which ${name}`, { encoding: "utf8", stdio: "ignore" }); return true; } catch { return false; }
}

// Detect the shell config file for PATH setup.
function detectShellRc() {
  let shell = process.env.SHELL || "";
  let home = os.homedir();

  if (SUDO_USER) {
    for (const prefix of ["/Users", "/home"]) {
      const candidate = path.join(prefix, SUDO_USER);
      try { if (fs.statSync(candidate).isDirectory()) { home = candidate; break; } } catch {}
    }
    try {
      if (process.platform === "darwin") {
        const out = execSync(`dscl . -read /Users/${SUDO_USER} UserShell 2>/dev/null`, { encoding: "utf8", timeout: 2000 });
        const m = out.match(/UserShell:\s*(\S+)/);
        if (m) shell = m[1];
      } else {
        shell = execSync(`getent passwd ${SUDO_USER} 2>/dev/null | cut -d: -f7`, { encoding: "utf8", timeout: 2000 }).trim() || shell;
      }
    } catch {}
  }

  const isBash = shell.includes("bash");
  const isZsh = shell.includes("zsh");
  if (isZsh) return { rc: path.join(home, ".zshrc"), name: "~/.zshrc", home };
  if (isBash) {
    const bashProfile = path.join(home, ".bash_profile");
    if (fs.existsSync(bashProfile) || process.platform === "darwin") {
      return { rc: bashProfile, name: "~/.bash_profile", home };
    }
    return { rc: path.join(home, ".bashrc"), name: "~/.bashrc", home };
  }
  return { rc: path.join(home, ".profile"), name: "~/.profile", home };
}

// ═══════════════════════════════════════════════════════════════════════════
// CLI: proxy
// ═══════════════════════════════════════════════════════════════════════════

function cmdProxySet(url) {
  if (!url) die(`usage: ${NAME} proxy set <url>`);
  const cfg = loadConfig();
  cfg.http = url;
  cfg.https = url;
  saveConfig(cfg);
  info(`proxy set to: ${url}`);
}

function cmdProxyShow() {
  const cfg = loadConfig();
  if (process.env.HTTP_PROXY) console.log(`env proxy:       ${process.env.HTTP_PROXY}`);
  else if (process.env.http_proxy) console.log(`env proxy:       ${process.env.http_proxy}`);
  if (cfg.http) console.log(`config proxy:    ${cfg.http}`);
  if (cfg.http || process.env.HTTP_PROXY || process.env.http_proxy) {
    console.log(`effective proxy: ${cfg.http || process.env.HTTP_PROXY || process.env.http_proxy}`);
  } else {
    console.log("effective proxy: none");
  }
}

function cmdProxyUnset() {
  const cfg = loadConfig();
  delete cfg.http;
  delete cfg.https;
  saveConfig(cfg);
  info("proxy configuration cleared.");
}

function cmdProxyCheck(opts = {}) {
  const testUrl = opts.url || "https://api.openai.com";
  const timeout = opts.timeout || 10;

  const issues = [];
  const ok = [];

  const check = (label, condition, detail) => {
    if (condition) ok.push(label + (detail ? ` (${detail})` : ""));
    else issues.push(label + (detail ? ` — ${detail}` : ""));
  };

  const cfg = loadConfig();
  const proxyUrl = process.env.HTTPS_PROXY || process.env.https_proxy ||
                   process.env.HTTP_PROXY || process.env.http_proxy ||
                   cfg.https || cfg.http;
  check("proxy config", !!proxyUrl, proxyUrl || "not configured — run: proxy set <url>");

  const haveCurl = !!shutil("curl");
  check("curl", haveCurl, haveCurl ? "available" : "not found — required for proxy check");

  if (proxyUrl && haveCurl) {
    const start = Date.now();
    try {
      const out = execSync(
        `curl -s -o /dev/null -w '%{http_code}' --proxy '${proxyUrl}' --connect-timeout ${timeout} --max-time ${timeout} '${testUrl}'`,
        { encoding: "utf8", timeout: (timeout + 5) * 1000 }
      ).trim();
      const latency = Date.now() - start;
      const code = parseInt(out, 10);
      check("proxy connectivity", code >= 200 && code < 500, `HTTP ${out}, ${latency}ms → ${testUrl}`);
    } catch {
      check("proxy connectivity", false, `connection failed → ${testUrl}`);
    }
  } else if (!haveCurl) {
    check("proxy connectivity", false, "curl not available");
  } else {
    check("proxy connectivity", false, "no proxy configured");
  }

  const haveNpm = !!shutil("npm");
  check("npm", haveNpm, haveNpm ? "available" : "not found — needed for codex install");

  const codexBin = findCodex();
  check("codex CLI", !!codexBin, codexBin ? codexVersion() : "not installed — run: install");

  // 6. VPS forwarder status (if configured)
  if (cfg.vps?.ssh) {
    try {
      const out = _vpsExecNoFail("ss -tlnp | grep 8443");
      check("vps forwarder", !!out.trim(), out.trim() || "not running — run: codex-relay vps start");
    } catch {
      check("vps forwarder", false, "SSH unreachable");
    }
  }

  console.log("codex-relay proxy check\n");
  for (const item of ok) console.log(`  ✓ ${item}`);
  if (issues.length > 0) {
    console.log("");
    for (const item of issues) console.log(`  ✗ ${item}`);
  }
  console.log("");
  console.log(`${ok.length} OK, ${issues.length} issue${issues.length !== 1 ? "s" : ""}`);
  if (issues.length > 0) process.exit(1);
}

// ═══════════════════════════════════════════════════════════════════════════
// CLI: install
// ═══════════════════════════════════════════════════════════════════════════

async function cmdInstallSelf(opts = {}) {
  const isRoot = process.getuid && process.getuid() === 0;

  const candidates = [
    "/usr/local/bin",
    ...(isRoot ? ["/usr/local/sbin"] : []),
    path.join(os.homedir(), ".local", "bin"),
    path.join(os.homedir(), "bin"),
  ];

  let binDir = null;
  let dest = null;

  for (const dir of candidates) {
    dest = path.join(dir, NAME);
    try {
      fs.mkdirSync(dir, { recursive: true });
      const testFile = path.join(dir, `.${NAME}.write-test`);
      fs.writeFileSync(testFile, "", { mode: 0o644 });
      fs.unlinkSync(testFile);
      binDir = dir;
      break;
    } catch { continue; }
  }

  if (!binDir) {
    throw new Error(
      `no writable bin directory found. Tried: ${candidates.join(", ")}.\n` +
      `  Run with sudo or create a directory: mkdir -p ~/.local/bin && export PATH="$HOME/.local/bin:$PATH"`
    );
  }

  let scriptContent;
  if (opts.url) {
    info(`downloading from ${opts.url} ...`);
    const resp = await fetch(opts.url);
    if (!resp.ok) die(`download failed: ${resp.status}`);
    scriptContent = await resp.text();
  } else {
    scriptContent = fs.readFileSync(SCRIPT_PATH, "utf8");
  }

  if (dest && fs.existsSync(dest) && !opts.force) {
    const readline = require("readline");
    const rl = readline.createInterface({ input: process.stdin, output: process.stderr });
    const answer = await new Promise((res) => {
      rl.question(`  ${NAME} already exists at ${dest}. Overwrite? [y/N] `, (a) => {
        rl.close();
        res(a.trim().toLowerCase());
      });
    });
    if (answer !== "y" && answer !== "yes") { info("skipped."); return; }
  }

  try {
    fs.writeFileSync(dest, scriptContent, { mode: 0o755 });

    // Also install codex-relay-forward if available
    const forwarderSrc = path.join(path.dirname(SCRIPT_PATH), "codex-relay-forward");
    if (fs.existsSync(forwarderSrc)) {
      fs.writeFileSync(path.join(binDir, "codex-relay-forward"), fs.readFileSync(forwarderSrc), { mode: 0o755 });
    }

    const inPath = process.env.PATH.split(":").some((p) => path.resolve(p) === path.resolve(binDir));
    let findable = false;
    try {
      execSync(`command -v ${NAME}`, { encoding: "utf8", timeout: 2000 }).trim();
      findable = true;
    } catch {}

    const { rc, name: shellRc, home } = detectShellRc();

    if (findable && !SUDO_USER) {
      info(`installed to ${dest}`);
      info(`  ✓ on PATH — run: ${NAME} --help`);
    } else if (findable && SUDO_USER) {
      info(`installed to ${dest} (system-wide)`);
    } else if (inPath) {
      info(`installed to ${dest}`);
      info(`  hint: refresh shell cache — run: hash -r`);
    } else {
      const exportLine = `export PATH="${binDir}:\\$PATH"`;
      info(`installed to ${dest}`);
      info(`  bin directory ${binDir} is not on PATH. To add it:`);
      info(``);
      info(`    echo '${exportLine}' >> ${shellRc}`);
      info(`    source ${shellRc}`);
      info(``);
      if (shellRc.endsWith(".bashrc") && !fs.existsSync(rc)) {
        const bp = path.join(home, ".bash_profile");
        if (fs.existsSync(bp)) {
          info(`  note: macOS bash loads ~/.bash_profile. Make sure it sources ~/.bashrc:`);
          info(`    echo '[ -f ~/.bashrc ] && source ~/.bashrc' >> ~/.bash_profile`);
        }
      }
      if (SUDO_USER) info(`  note: the PATH change above applies to user ${SUDO_USER}, not root`);
      if (SUDO_USER) info(`  After setup, run as ${SUDO_USER}: ${NAME} --help`);
      else info(`  Then: ${NAME} --help`);
    }
  } catch (e) { throw e; }
}

async function cmdInstallCodex(env, version) {
  const npm = "npm";
  try { execSync("which npm", { encoding: "utf8" }); } catch { die("npm not found. Install Node.js: https://nodejs.org"); }

  let pkg = "@openai/codex";
  if (version) pkg += `@${version}`;
  info(`installing ${pkg} ...`);
  const proc = spawn(npm, ["install", "-g", pkg], { env, stdio: "inherit" });
  await new Promise((res) => proc.on("close", res));
  const ver = codexVersion();
  info(`installed: ${ver || "latest"}`);
}

async function cmdUpdateCodex(env) {
  const npm = "npm";
  try { execSync("which npm", { encoding: "utf8" }); } catch { die("npm not found. Install Node.js: https://nodejs.org"); }
  info("updating @openai/codex ...");
  const proc = spawn(npm, ["update", "-g", "@openai/codex"], { env, stdio: "inherit" });
  await new Promise((res) => proc.on("close", res));
  const ver = codexVersion();
  info(`updated: ${ver || "latest"}`);
}

async function cmdInstall(opts = {}) {
  const cfg = loadConfig();
  const proxyUrl = cfg.https || cfg.http;
  const env = { ...process.env };
  if (proxyUrl) {
    env.HTTP_PROXY = proxyUrl;
    env.HTTPS_PROXY = proxyUrl;
    env.http_proxy = proxyUrl;
    env.https_proxy = proxyUrl;
    env.NO_PROXY = "localhost,127.0.0.1,::1,.local";
    env.no_proxy = "localhost,127.0.0.1,::1,.local";
  }

  if (opts.update) { await cmdUpdateCodex(env); return; }
  if (opts.version) { await cmdInstallCodex(env, opts.version); return; }

  info("step 1/2: installing codex-relay ...");
  try { await cmdInstallSelf(opts); }
  catch (e) { if (opts.force) die(e.message); info(`codex-relay self-install skipped (${e.message})`); }

  info("step 2/2: checking Codex CLI ...");
  if (findCodex()) info(`codex already installed (${codexVersion() || "unknown"})`);
  else await cmdInstallCodex(env);

  info("install complete.");
}

// ═══════════════════════════════════════════════════════════════════════════
// CLI: run
// ═══════════════════════════════════════════════════════════════════════════

function cmdRun(args) {
  const codexBin = findCodex() || die("'codex' not found. Install with: codex-relay install");

  const env = { ...process.env };
  const noProxy = "localhost,127.0.0.1,::1,.local";

  const cfg = loadConfig();
  const proxyUrl = process.env.HTTPS_PROXY || process.env.https_proxy ||
                   process.env.HTTP_PROXY || process.env.http_proxy ||
                   cfg.https || cfg.http;
  if (proxyUrl) {
    env.HTTP_PROXY = proxyUrl;
    env.HTTPS_PROXY = proxyUrl;
    env.http_proxy = proxyUrl;
    env.https_proxy = proxyUrl;
    env.WS_PROXY = proxyUrl;
    env.WSS_PROXY = proxyUrl;
    env.NO_PROXY = noProxy;
    env.no_proxy = noProxy;
    info(`using proxy: ${proxyUrl}`);
  }

  const proc = spawn(codexBin, args, { env, stdio: "inherit" });
  proc.on("close", (code) => process.exit(code || 0));
  proc.on("error", () => process.exit(1));
}

// ═══════════════════════════════════════════════════════════════════════════
// help & version
// ═══════════════════════════════════════════════════════════════════════════

function printHelp() {
  console.log(`${NAME} ${VERSION} — proxy wrapper for OpenAI Codex CLI.

  Quick start:
    ${NAME} proxy set http://user:pass@proxy:8080
    ${NAME} proxy check
    ${NAME} run chat

  Commands:
    ${NAME} proxy set <url>                          - configure upstream proxy
    ${NAME} proxy show                               - show current config
    ${NAME} proxy unset                              - clear proxy config
    ${NAME} proxy check [--url URL] [--timeout S]     - test proxy connectivity
    ${NAME} vps setup <user@host> [--key path]       - deploy forwarder to VPS
    ${NAME} vps proxy set <url>                      - set static proxy on VPS
    ${NAME} vps proxy show                           - show VPS proxy config
    ${NAME} vps start|stop|status|logs               - manage VPS forwarder
    ${NAME} install [--force]                        - install codex-relay + codex CLI
    ${NAME} install --update                         - update codex CLI
    ${NAME} install --version X                      - install specific codex version
    ${NAME} run <args...>                            - run codex with proxy env vars
    ${NAME} <anything>                               - passthrough to codex CLI
    ${NAME} --version                                - show version info`);
}

function printVersion() {
  console.log(`${NAME} ${VERSION}`);
  const cv = codexVersion();
  if (cv) console.log(`codex: ${cv}`);
}

// ═══════════════════════════════════════════════════════════════════════════
// argument parsing
// ═══════════════════════════════════════════════════════════════════════════

function parseArgs(argv) {
  const opts = { _: [] };
  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === "--url" || argv[i] === "--timeout" || argv[i] === "--version") {
      opts[argv[i].replace(/^--/, "")] = argv[i + 1];
      i++;
    } else if (argv[i] === "--update") {
      opts.update = true;
    } else if (argv[i] === "--force") {
      opts.force = true;
    } else {
      opts._.push(argv[i]);
    }
  }
  return opts;
}

// ═══════════════════════════════════════════════════════════════════════════
// CLI: vps
// ═══════════════════════════════════════════════════════════════════════════

// Run a command on the VPS via SSH. Returns stdout or throws.
function _vpsExec(cmd) {
  const cfg = loadConfig();
  const dest = process.argv.includes("--ssh") ? process.argv[process.argv.indexOf("--ssh") + 1] : cfg.vps?.ssh;
  if (!dest) die("no VPS configured. Run: codex-relay vps setup <user@host>");
  const keyArg = cfg.vps?.key ? ["-i", cfg.vps.key] : [];
  return execSync(`ssh -o ConnectTimeout=5 -o StrictHostKeyChecking=no ${keyArg.map(a => `'${a}'`).join(" ")} '${dest}' ${JSON.stringify(cmd)}`, { encoding: "utf8", timeout: 15000, stdio: "pipe" });
}

function _vpsExecNoFail(cmd) {
  try { return _vpsExec(cmd).trim(); } catch { return ""; }
}

function cmdVpsSetup(target) {
  if (!target || !target.includes("@")) die("usage: codex-relay vps setup <user@host> [--key <path>]");
  const keyIdx = process.argv.indexOf("--key");
  const key = keyIdx >= 0 ? process.argv[keyIdx + 1] : "";

  const cfg = loadConfig();
  cfg.vps = { ssh: target };
  if (key) cfg.vps.key = key;
  saveConfig(cfg);
  info(`VPS configured: ${target}`);

  // Deploy forwarder — try local file first, fall back to GitHub
  const keyArg = key ? ["-i", key] : [];
  const scriptDir = path.dirname(SCRIPT_PATH);
  const forwarderPath = path.join(scriptDir, "codex-relay-forward");
  let deployCmd = "";

  if (fs.existsSync(forwarderPath)) {
    // Local file available — scp it
    deployCmd = `scp -o StrictHostKeyChecking=no ${keyArg.map(a => `'${a}'`).join(" ")} '${forwarderPath}' '${target}:/usr/local/bin/'`;
  } else {
    // Download from GitHub
    const url = "https://raw.githubusercontent.com/garry-x/codex-relay/main/codex-relay-forward";
    deployCmd = `ssh -o StrictHostKeyChecking=no ${keyArg.map(a => `'${a}'`).join(" ")} '${target}' "curl -fsSLo /usr/local/bin/codex-relay-forward '${url}' && chmod +x /usr/local/bin/codex-relay-forward"`;
  }

  info("deploying codex-relay-forward...");
  try { execSync(deployCmd, { encoding: "utf8", timeout: 15000, stdio: "pipe" }); }
  catch (e) { die(`deploy failed: ${e.message}`); }

  // Start forwarder
  try {
    const out = _vpsExec("pkill -f codex-relay-forward 2>/dev/null; sleep 0.5; nohup codex-relay-forward 0.0.0.0:8443 > /tmp/codex-relay-forward.log 2>&1 & for i in 1 2 3 4 5; do sleep 0.5; ss -tlnp | grep -q 8443 && break; done; ss -tlnp | grep 8443 || echo 'FAILED'");
    info(out.trim());
  } catch (e) { info(`start failed — run codex-relay vps start`); }

  info("VPS setup complete.");
}

function cmdVpsProxy(action, url) {
  if (action === "set") {
    if (!url) die("usage: codex-relay vps proxy set <url>");
    _vpsExec(`mkdir -p ~/.codex-relay && node -e "var c=require('/root/.codex-relay/config.json')||{};c.http='${url}';c.https='${url}';require('fs').writeFileSync('/root/.codex-relay/config.json',JSON.stringify(c))"`);
    info(`VPS proxy set to: ${url}`);
  } else {
    const out = _vpsExecNoFail("cat ~/.codex-relay/config.json 2>/dev/null || echo '{}'");
    const cfg = (() => { try { return JSON.parse(out); } catch { return {}; } })();
    if (cfg.http) console.log(cfg.http);
    else console.log("(no proxy configured on VPS)");
  }
}

function cmdVpsStart() {
  const out = _vpsExec("pkill -f codex-relay-forward 2>/dev/null; sleep 0.5; nohup codex-relay-forward 0.0.0.0:8443 > /tmp/codex-relay-forward.log 2>&1 & for i in 1 2 3 4 5; do sleep 0.5; ss -tlnp | grep -q 8443 && break; done; ss -tlnp | grep 8443 || echo 'FAILED'");
  if (out.includes("FAILED")) die("VPS forwarder failed to start. Check: ssh vps \"cat /tmp/codex-relay-forward.log\"");
  info(`VPS forwarder started:\n${out.trim()}`);
}

function cmdVpsStop() {
  _vpsExecNoFail("pkill -f codex-relay-forward");
  info("VPS forwarder stopped.");
}

function cmdVpsStatus() {
  const out = _vpsExecNoFail("ss -tlnp | grep 8443; echo '---'; cat /tmp/codex-relay-forward.log 2>/dev/null | tail -1; echo '---'; cat ~/.codex-relay/config.json 2>/dev/null || echo '{}'");
  const parts = out.split("---");
  console.log(parts[0].trim() ? `forwarder:  running\n${parts[0].trim()}` : "forwarder:  stopped");
  if (parts[1]?.trim()) console.log(`last log:   ${parts[1].trim()}`);
  const pcfg = (() => { try { return JSON.parse(parts[2] || "{}"); } catch { return {}; } })();
  console.log(`upstream:   ${pcfg.http || "(not configured)"}`);
}

function cmdVpsLogs() {
  const out = _vpsExecNoFail("tail -30 /tmp/codex-relay-forward.log 2>/dev/null");
  console.log(out || "(no logs)");
}

// ═══════════════════════════════════════════════════════════════════════════
// main
// ═══════════════════════════════════════════════════════════════════════════

async function main() {
  const raw = process.argv.slice(2);
  const cmd = raw[0];
  const args = raw.slice(1);

  switch (cmd) {
    case undefined:
    case "--help":
    case "-h":
      printHelp();
      break;

    case "--version":
    case "-V":
      printVersion();
      break;

    case "proxy": {
      const action = args[0];
      const pargs = parseArgs(args.slice(1));
      switch (action) {
        case "set": cmdProxySet(pargs._[0]); break;
        case "show": cmdProxyShow(); break;
        case "unset": cmdProxyUnset(); break;
        case "check": cmdProxyCheck(pargs); break;
        default: die(`usage: ${NAME} proxy {set|show|unset|check}`);
      }
      break;
    }

    case "vps": {
      const action = args[0];
      const pargs = parseArgs(args.slice(1));
      switch (action) {
        case "setup": cmdVpsSetup(pargs._[0]); break;
        case "proxy": cmdVpsProxy(pargs._[0], pargs._[1]); break;
        case "start": cmdVpsStart(); break;
        case "stop": cmdVpsStop(); break;
        case "status": cmdVpsStatus(); break;
        case "logs": cmdVpsLogs(); break;
        default: die(`usage: ${NAME} vps {setup|proxy|start|stop|status|logs}`);
      }
      break;
    }

    case "install": {
      const pargs = parseArgs(args);
      await cmdInstall(pargs);
      break;
    }

    case "run":
      cmdRun(args);
      break;

    default:
      // Passthrough to codex
      cmdRun(raw);
      break;
  }
}

main().catch((e) => { die(e.message); });
