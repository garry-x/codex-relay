// ── main ───────────────────────────────────────────────────────────────────

function parseArgs(argv) {
  const opts = { _: [] };
  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === "--url" || argv[i] === "--timeout" || argv[i] === "--version" ||
        argv[i] === "--listen" || argv[i] === "--upstream" || argv[i] === "--token" ||
        argv[i] === "--allow" || argv[i] === "--tls-cert" || argv[i] === "--tls-key") {
      opts[argv[i].replace(/^--/, "")] = argv[i + 1];
      i++;
    } else if (argv[i] === "--update") {
      opts.update = true;
    } else if (argv[i] === "--force") {
      opts.force = true;
    } else if (argv[i] === "--remove") {
      opts.remove = true;
    } else {
      opts._.push(argv[i]);
    }
  }
  return opts;
}

async function main() {
  const raw = process.argv.slice(2);

  // Hidden: daemon mode
  if (raw[0] === "--_daemon") {
    const upstreamUrl = raw[1];
    if (!upstreamUrl) die("--_daemon requires upstream URL");
    runProxyDaemon(upstreamUrl);
    return;
  }
  if (raw[0] === "--_chain-daemon") {
    runChainDaemon();
    return;
  }
  if (raw[0] === "--_bypass-daemon") {
    const proxyPort = parseInt(raw[1], 10);
    if (!proxyPort) die("--_bypass-daemon requires proxy port");
    runBypassDaemon(proxyPort);
    return;
  }
  if (raw[0] === "--_bypass-setup") {
    // Called via sudo: adds hosts + launches bypass daemon
    const proxyPort = parseInt(raw[1], 10);
    if (!proxyPort) die("--_bypass-setup requires proxy port");
    if (isBypassRunning()) {
      console.log("[codex-relay] bypass already running.");
      return;
    }
    manageHosts("add");
    // Use shell backgrounding to reliably detach
    execSync(
      `nohup "${process.execPath}" "${SCRIPT_PATH}" --_bypass-daemon ${proxyPort} > /dev/null 2>&1 &`,
      { stdio: "ignore" }
    );
    for (let i = 0; i < 20; i++) {
      if (isBypassRunning()) break;
      execSync("sleep 0.1", { stdio: "ignore" });
    }
    if (isBypassRunning()) {
      console.log("[codex-relay] bypass started: 127.0.0.1:443 → 127.0.0.1:" + proxyPort);
    } else {
      console.error("error: bypass daemon failed to start");
      process.exit(1);
    }
    return;
  }
  if (raw[0] === "--_bypass-teardown") {
    // Called via sudo: stops bypass daemon + removes hosts
    if (isBypassRunning()) {
      const pid = parseInt(fs.readFileSync(BYPASS_PID_FILE, "utf8").trim(), 10);
      try { process.kill(pid, "SIGTERM"); } catch {}
      cleanupBypassFiles();
    }
    manageHosts("remove");
    return;
  }

  const cmd = raw[0];
  const args = raw.slice(1);

  switch (cmd) {
    case undefined:
    case "--help":
    case "-h":
      printHelp();
      break;

    case "--version":
    case "-V":
      printVersion();
      break;

    case "proxy": {
      const action = args[0];
      const pargs = parseArgs(args.slice(1));
      switch (action) {
        case "set": cmdProxySet(pargs._[0]); break;
        case "show": cmdProxyShow(); break;
        case "unset": cmdProxyUnset(); break;
        case "start": cmdProxyStart(); break;
        case "stop": cmdProxyStop(); break;
        case "test": cmdProxyTest(pargs); break;
        case "bypass": cmdProxyBypass(pargs); break;
        case "restart": cmdProxyStop(); cmdProxyStart(); break;
        case "logs": cmdProxyLogs(); break;
        case "status": cmdProxyStatus(); break;
        case "check": cmdProxyCheck(); break;
        default: die(`usage: ${NAME} proxy {set|show|unset|test|start|stop|restart|check|logs|status}`);
      }
      break;
    }

    case "dns":
      await cmdDns(args);
      break;

    case "chain":
      cmdChain(args);
      break;

    case "install": {
      const pargs = parseArgs(args);
      await cmdInstall(pargs);
      break;
    }

    case "run":
      cmdRun(args);
      break;

    default:
      // Passthrough to codex
      cmdRun(raw);
      break;
  }
}

main().catch((e) => {
  die(e.message);
});
