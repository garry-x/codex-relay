#!/usr/bin/env node
// codex-relay — Node.js wrapper for OpenAI Codex CLI with proxy support.
// Requires Node.js >= 18 (built-in fetch, no npm dependencies).

const net = require("net");
const tls = require("tls");
const fs = require("fs");
const path = require("path");
const os = require("os");
const crypto = require("crypto");
const { spawn, execSync } = require("child_process");

// ── config ─────────────────────────────────────────────────────────────────

const NAME = "codex-relay";
const VERSION = "0.2.0";

// When running via sudo, use the original user's home, not /var/root
const SUDO_USER = process.env.SUDO_USER;
const REAL_HOME = (() => {
  if (!SUDO_USER) return os.homedir();
  try {
    const info = require("os").userInfo({ encoding: "utf8" });
    // macOS: userInfo doesn't take options; try to resolve from /Users or /home
  } catch {}
  // Heuristic: check common home dir patterns
  for (const prefix of ["/Users", "/home"]) {
    const candidate = path.join(prefix, SUDO_USER);
    try { if (fs.statSync(candidate).isDirectory()) return candidate; } catch {}
  }
  return os.homedir();
})();
const CONFIG_DIR = path.join(REAL_HOME, ".codex-relay");
const CONFIG_FILE = path.join(CONFIG_DIR, "config.json");
const CHAIN_PID_FILE = path.join(CONFIG_DIR, "chain.pid");
const CHAIN_HEARTBEAT_FILE = path.join(CONFIG_DIR, "chain.heartbeat");
const CHAIN_LOG_FILE = path.join(CONFIG_DIR, "chain.log");
const CERT_DIR = path.join(CONFIG_DIR, "certs");
const SPLIT_EDGE_PID_FILE = path.join(CONFIG_DIR, "split-edge.pid");
const SPLIT_EDGE_HB_FILE = path.join(CONFIG_DIR, "split-edge.heartbeat");
const SPLIT_LOCAL_PID_FILE = path.join(CONFIG_DIR, "split-local.pid");
const SPLIT_LOCAL_HB_FILE = path.join(CONFIG_DIR, "split-local.heartbeat");
const SPLIT_TUNNEL_PID_FILE = path.join(CONFIG_DIR, "split-tunnel.pid");
const MAX_LOG_LINES = 500;

let _logCount = 0;
function chainLog(msg) {
  const ts = new Date().toISOString();
  const line = `${ts} ${msg}\n`;
  // Async write — never block the hot path on disk I/O
  fs.appendFile(CHAIN_LOG_FILE, line, () => {});
  // Rotate every ~100 writes instead of every line
  _logCount++;
  if (_logCount % 100 === 0) {
    try {
      const lines = fs.readFileSync(CHAIN_LOG_FILE, "utf8").split("\n");
      if (lines.length > MAX_LOG_LINES + 50) {
        fs.writeFileSync(CHAIN_LOG_FILE, lines.slice(-MAX_LOG_LINES).join("\n"));
      }
    } catch {}
  }
}

// Resolve script path (handle relative paths for sudo)
const SCRIPT_PATH = (() => {
  try { return fs.realpathSync(process.argv[1]); } catch { return process.argv[1]; }
})();

// ── helpers ────────────────────────────────────────────────────────────────

function die(msg) {
  console.error(`error: ${msg}`);
  process.exit(1);
}
function info(msg) {
  console.error(`[${NAME}] ${msg}`);
}

function loadConfig() {
  try { return JSON.parse(fs.readFileSync(CONFIG_FILE, "utf8")); } catch { return {}; }
}
function saveConfig(cfg) {
  fs.mkdirSync(CONFIG_DIR, { recursive: true });
  fs.writeFileSync(CONFIG_FILE, JSON.stringify(cfg, null, 2));
}
function generateToken() {
  return crypto.randomBytes(24).toString("base64url");
}
function hashToken(token) {
  return "sha256:" + crypto.createHash("sha256").update(token).digest("hex");
}
function tokenMatches(token, hash) {
  if (!hash) return false;
  if (hash.startsWith("sha256:")) return hashToken(token) === hash;
  return token === hash;
}

// ── split proxy: certificate management ────────────────────────────────────

function shorthash(s) {
  return crypto.createHash("sha256").update(s).digest("hex").slice(0, 16);
}

function ensureSplitCACert() {
  fs.mkdirSync(CERT_DIR, { recursive: true });
  const caKeyPath = path.join(CERT_DIR, "ca-key.pem");
  const caCertPath = path.join(CERT_DIR, "ca-cert.pem");
  if (fs.existsSync(caKeyPath) && fs.existsSync(caCertPath)) {
    return { key: fs.readFileSync(caKeyPath, "utf8"), cert: fs.readFileSync(caCertPath, "utf8"), certPath: caCertPath };
  }
  if (!shutil("openssl")) die("openssl is required for split proxy mode. Install: apt install openssl");
  execSync(
    `openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 ` +
    `-days 3650 -nodes -keyout '${caKeyPath}' -out '${caCertPath}' ` +
    `-subj '/CN=CodexRelayLocalCA' 2>/dev/null`,
    { encoding: "utf8", timeout: 10000 }
  );
  // Verify generation
  try { execSync(`openssl verify -CAfile '${caCertPath}' '${caCertPath}' 2>/dev/null`, { encoding: "utf8" }); } catch {
    die("openssl CA cert generation failed — check openssl installation");
  }
  info(`split proxy CA generated at ${caCertPath}`);
  return { key: fs.readFileSync(caKeyPath, "utf8"), cert: fs.readFileSync(caCertPath, "utf8"), certPath: caCertPath };
}

function getSplitDomainCert(hostname) {
  const domainDir = path.join(CERT_DIR, shorthash(hostname));
  const keyPath = path.join(domainDir, "key.pem");
  const certPath = path.join(domainDir, "cert.pem");
  if (fs.existsSync(keyPath) && fs.existsSync(certPath)) {
    return { key: fs.readFileSync(keyPath, "utf8"), cert: fs.readFileSync(certPath, "utf8") };
  }
  fs.mkdirSync(domainDir, { recursive: true });
  const ca = ensureSplitCACert();
  // Write CA files to domain dir for openssl (needs file paths)
  const caKeyPath = path.join(CERT_DIR, "ca-key.pem");
  const caCertPath = path.join(CERT_DIR, "ca-cert.pem");
  // Generate domain key
  execSync(
    `openssl ecparam -genkey -name prime256v1 -noout -out '${keyPath}' 2>/dev/null`,
    { encoding: "utf8", timeout: 5000 }
  );
  // Generate CSR with SAN
  const csrPath = path.join(domainDir, "domain.csr");
  execSync(
    `openssl req -new -key '${keyPath}' -out '${csrPath}' ` +
    `-subj "/CN=${hostname}" -addext "subjectAltName=DNS:${hostname}" 2>/dev/null`,
    { encoding: "utf8", timeout: 5000 }
  );
  // Sign with CA
  execSync(
    `openssl x509 -req -in '${csrPath}' ` +
    `-CA '${caCertPath}' -CAkey '${caKeyPath}' -CAcreateserial ` +
    `-out '${certPath}' -days 365 -sha256 ` +
    `-extfile <(printf "subjectAltName=DNS:${hostname}\\n") 2>/dev/null`,
    { encoding: "utf8", shell: "/bin/bash", timeout: 5000 }
  );
  // Clean up CSR
  try { fs.unlinkSync(csrPath); } catch {}
  return { key: fs.readFileSync(keyPath, "utf8"), cert: fs.readFileSync(certPath, "utf8") };
}

const _splitCtxCache = new Map();
function getSplitSecureContext(hostname) {
  let ctx = _splitCtxCache.get(hostname);
  if (ctx) return ctx;
  const { key, cert } = getSplitDomainCert(hostname);
  ctx = tls.createSecureContext({ key, cert });
  _splitCtxCache.set(hostname, ctx);
  return ctx;
}

function findCodex() {
  try { return execSync("which codex", { encoding: "utf8" }).trim(); } catch { return null; }
}
function codexVersion() {
  const bin = findCodex();
  if (!bin) return null;
  try { return execSync(`"${bin}" --version`, { encoding: "utf8", timeout: 5000 }).trim(); } catch { return null; }
}

// Detect the shell config file for PATH setup.
// Returns { rc: absolute path, name: display name, home: user home dir }.
function detectShellRc() {
  let shell = process.env.SHELL || "";
  let home = os.homedir();

  // When running via sudo, resolve the original user's data
  if (SUDO_USER) {
    for (const prefix of ["/Users", "/home"]) {
      const candidate = path.join(prefix, SUDO_USER);
      try { if (fs.statSync(candidate).isDirectory()) { home = candidate; break; } } catch {}
    }
    // Get original user's shell
    try {
      if (process.platform === "darwin") {
        const out = execSync(`dscl . -read /Users/${SUDO_USER} UserShell 2>/dev/null`, { encoding: "utf8", timeout: 2000 });
        const m = out.match(/UserShell:\s*(\S+)/);
        if (m) shell = m[1];
      } else {
        shell = execSync(`getent passwd ${SUDO_USER} 2>/dev/null | cut -d: -f7`, { encoding: "utf8", timeout: 2000 }).trim() || shell;
      }
    } catch {}
  }

  const isBash = shell.includes("bash");
  const isZsh = shell.includes("zsh");

  if (isZsh) {
    return { rc: path.join(home, ".zshrc"), name: "~/.zshrc", home };
  }
  if (isBash) {
    // macOS bash sources .bash_profile for login shells; Linux uses .bashrc
    const bashProfile = path.join(home, ".bash_profile");
    if (fs.existsSync(bashProfile) || process.platform === "darwin") {
      return { rc: bashProfile, name: "~/.bash_profile", home };
    }
    return { rc: path.join(home, ".bashrc"), name: "~/.bashrc", home };
  }
  return { rc: path.join(home, ".profile"), name: "~/.profile", home };
}

// Parse proxy URL: http://[user:pass@]host:port
function parseProxyUrl(url) {
  const schemeMatch = String(url).match(/^(https?):\/\//);
  const scheme = schemeMatch ? schemeMatch[1] : "http";
  const noScheme = String(url).replace(/^https?:\/\//, "");
  const atIdx = noScheme.lastIndexOf("@");
  const authPart = atIdx >= 0 ? noScheme.slice(0, atIdx) : "";
  const hostPort = atIdx >= 0 ? noScheme.slice(atIdx + 1) : noScheme;
  const colonIdx = hostPort.lastIndexOf(":");
  const host = colonIdx >= 0 ? hostPort.slice(0, colonIdx) : hostPort;
  const port = colonIdx >= 0 ? parseInt(hostPort.slice(colonIdx + 1), 10) : (scheme === "https" ? 443 : 80);
  const userColon = authPart.indexOf(":");
  const user = userColon >= 0 ? authPart.slice(0, userColon) : (authPart || "");
  const pass = userColon >= 0 ? authPart.slice(userColon + 1) : "";
  const auth = user ? Buffer.from(`${user}:${pass}`).toString("base64") : "";
  return { scheme, host, port, user, pass, auth };
}

function connectProxySocket(proxyUrl, onConnect) {
  const { scheme, host, port } = parseProxyUrl(proxyUrl);
  const sock = scheme === "https"
    ? tls.connect({ host, port, servername: host, rejectUnauthorized: false }, onConnect)
    : net.connect(port, host, onConnect);
  sock.setNoDelay(true);
  sock.setKeepAlive(true, 30000);
  return sock;
}

function parseListenAddr(value) {
  const input = value || "127.0.0.1:8080";
  const idx = input.lastIndexOf(":");
  if (idx < 0) return { host: input, port: 8080 };
  const host = input.slice(0, idx) || "0.0.0.0";
  const port = parseInt(input.slice(idx + 1), 10);
  if (!port) die(`invalid listen address: ${input}`);
  return { host, port };
}

function stripProxyAuthorization(headStr) {
  const start = headStr.indexOf("Proxy-Authorization:");
  if (start === -1) return headStr;
  const end = headStr.indexOf("\r\n", start);
  return end === -1 ? headStr : headStr.slice(0, start) + headStr.slice(end + 2);
}

function addProxyAuthorization(headStr, auth) {
  const cleaned = stripProxyAuthorization(headStr);
  if (!auth) return cleaned;
  const end = cleaned.lastIndexOf("\r\n\r\n");
  if (end === -1) return cleaned + `Proxy-Authorization: Basic ${auth}\r\n\r\n`;
  return cleaned.slice(0, end) + `\r\nProxy-Authorization: Basic ${auth}` + cleaned.slice(end);
}

function addInternalHostHeader(headStr, host) {
  const cleaned = stripInternalHeaders(headStr);
  const end = cleaned.lastIndexOf("\r\n\r\n");
  if (end === -1) return cleaned + `X-Codex-Relay-Host: ${host}\r\n\r\n`;
  return cleaned.slice(0, end) + `\r\nX-Codex-Relay-Host: ${host}` + cleaned.slice(end);
}

function stripInternalHeaders(headStr) {
  const start = headStr.indexOf("X-Codex-Relay-Host:");
  if (start === -1) return headStr;
  const end = headStr.indexOf("\r\n", start);
  return end === -1 ? headStr : headStr.slice(0, start) + headStr.slice(end + 2);
}

function internalHost(headStr) {
  const prefix = "X-Codex-Relay-Host: ";
  const idx = headStr.indexOf(prefix);
  if (idx === -1) return "";
  const valStart = idx + prefix.length;
  const lineEnd = headStr.indexOf("\r\n", valStart);
  return lineEnd === -1 ? headStr.slice(valStart).trim() : headStr.slice(valStart, lineEnd).trim();
}

function proxyAuthToken(headStr) {
  const prefix = "Proxy-Authorization: Basic ";
  const idx = headStr.indexOf(prefix);
  if (idx === -1) return "";
  const valStart = idx + prefix.length;
  const lineEnd = headStr.indexOf("\r\n", valStart);
  const val = lineEnd === -1 ? headStr.slice(valStart) : headStr.slice(valStart, lineEnd);
  try {
    const decoded = Buffer.from(val.trim(), "base64").toString("utf8");
    const colon = decoded.indexOf(":");
    return colon >= 0 ? decoded.slice(0, colon) : decoded;
  } catch {
    return "";
  }
}

function chainUpstreams(input) {
  if (Array.isArray(input)) return input.filter(Boolean);
  return String(input || "").split(",").map((s) => s.trim()).filter(Boolean);
}

function redactProxyUrl(url) {
  return String(url).replace(/\/\/[^@/]+@/, "//***@");
}

function connectTargetFromHead(headStr) {
  const firstSpace = headStr.indexOf(" ");
  if (firstSpace === -1) return null;
  const method = headStr.slice(0, firstSpace);

  if (method === "CONNECT") {
    const hostStart = firstSpace + 1;
    const hostEnd = headStr.indexOf(" ", hostStart);
    if (hostEnd === -1) return null;
    const hostPort = headStr.slice(hostStart, hostEnd);
    const colonIdx = hostPort.lastIndexOf(":");
    if (colonIdx === -1) return null;
    return {
      mode: "connect",
      host: hostPort.slice(0, colonIdx),
      port: parseInt(hostPort.slice(colonIdx + 1), 10),
    };
  }

  const urlStart = firstSpace + 1;
  const urlEnd = headStr.indexOf(" ", urlStart);
  if (urlEnd === -1) return null;
  const url = headStr.slice(urlStart, urlEnd);
  if (!url.startsWith("http://")) return null;

  const hostStart = 7;
  const pathStart = url.indexOf("/", hostStart);
  const hostPortPart = pathStart === -1 ? url.slice(hostStart) : url.slice(hostStart, pathStart);
  const colonIdx = hostPortPart.indexOf(":");
  const host2 = colonIdx === -1 ? hostPortPart : hostPortPart.slice(0, colonIdx);
  const port = colonIdx === -1 ? 80 : parseInt(hostPortPart.slice(colonIdx + 1), 10);
  const path = pathStart === -1 ? "/" : url.slice(pathStart);

  return { mode: "http", host: host2, port, method, path };
}

function prepareChainTarget(headStr, target, reqId) {
  const originalHost = internalHost(headStr) || target.host;
  const nextHead = addInternalHostHeader(headStr, originalHost);
  chainLog(`${reqId} ${target.mode.toUpperCase()} ${originalHost}:${target.port}`);
  return {
    headStr: nextHead,
    target: { ...target, originalHost },
  };
}

function tryChainUpstream(clientSocket, headStr, upstreamUrl, upstreamAuth, target, reqId, timeoutMs) {
  return new Promise((resolve) => {
    if (upstreamUrl === "direct") {
      const direct = net.connect(target.port, target.host);
      direct.setNoDelay(true);
      direct.setKeepAlive(true, 30000);
      const timer = setTimeout(() => {
        chainLog(`${reqId} direct ${target.host}:${target.port} connect timeout`);
        try { direct.destroy(); } catch {}
        resolve(false);
      }, timeoutMs);
      direct.once("connect", () => {
        clearTimeout(timer);
        chainLog(`${reqId} direct ${target.host}:${target.port} OK`);
        if (target.mode === "connect") {
          clientSocket.write("HTTP/1.1 200 Connection Established\r\n\r\n");
        } else {
          const cleaned = stripInternalHeaders(stripProxyAuthorization(headStr));
          const lineEnd = cleaned.indexOf("\r\n");
          const firstLine = lineEnd === -1 ? cleaned : cleaned.slice(0, lineEnd);
          const tail = lineEnd === -1 ? "" : cleaned.slice(lineEnd);
          const sp1 = firstLine.indexOf(" ");
          const sp2 = firstLine.lastIndexOf(" ");
          const method = firstLine.slice(0, sp1);
          const httpVer = firstLine.slice(sp2);
          const originHead = method + " " + target.path + httpVer + tail;
          direct.write(originHead);
        }
        clientSocket.pipe(direct);
        direct.pipe(clientSocket);
        resolve(true);
      });
      direct.once("error", (e) => {
        clearTimeout(timer);
        chainLog(`${reqId} direct ${target.host}:${target.port} error: ${e.message}`);
        resolve(false);
      });
      clientSocket.once("error", () => { try { direct.destroy(); } catch {} resolve(true); });
      return;
    }

    const upstreamHead = addProxyAuthorization(stripInternalHeaders(headStr), upstreamAuth);
    const upstream = connectProxySocket(upstreamUrl, () => {
      upstream.write(upstreamHead);
      if (target.mode !== "connect") {
        chainLog(`${reqId} upstream ${redactProxyUrl(upstreamUrl)} HTTP forward`);
        clientSocket.pipe(upstream);
        upstream.pipe(clientSocket);
        clearTimeout(timer);
        resolve(true);
      }
    });
    let respBuf = Buffer.alloc(0);
    const timer = setTimeout(() => {
      chainLog(`${reqId} upstream ${redactProxyUrl(upstreamUrl)} timeout`);
      try { upstream.destroy(); } catch {}
      resolve(false);
    }, timeoutMs);
    upstream.on("data", (chunk) => {
      if (target.mode !== "connect") return;
      respBuf = Buffer.concat([respBuf, chunk]);
      const headerEnd = respBuf.indexOf("\r\n\r\n");
      if (headerEnd < 0) return;
      clearTimeout(timer);
      const respStr = respBuf.toString("utf8", 0, headerEnd + 4);
      const status = respStr.split("\r\n")[0];
      upstream.removeAllListeners("data");
      if (respStr.startsWith("HTTP/1.1 200") || respStr.startsWith("HTTP/1.0 200")) {
        chainLog(`${reqId} upstream ${redactProxyUrl(upstreamUrl)} OK`);
        clientSocket.write(respStr);
        const leftover = respBuf.slice(headerEnd + 4);
        if (leftover.length > 0) clientSocket.write(leftover);
        clientSocket.pipe(upstream);
        upstream.pipe(clientSocket);
        resolve(true);
      } else {
        chainLog(`${reqId} upstream ${redactProxyUrl(upstreamUrl)} rejected: ${status}`);
        try { upstream.destroy(); } catch {}
        resolve(false);
      }
    });
    upstream.once("error", (e) => {
      clearTimeout(timer);
      chainLog(`${reqId} upstream ${redactProxyUrl(upstreamUrl)} error: ${e.message}`);
      resolve(false);
    });
    clientSocket.once("error", () => { try { upstream.destroy(); } catch {} resolve(true); });
  });
}

// ── split proxy: edge server (VPS side) ────────────────────────────────────

function handleSplitEdgeConnection(socket) {
  socket.setNoDelay(true);
  socket.setKeepAlive(true, 30000);
  let buf = Buffer.alloc(0);
  let targetSocket = null;

  socket.on("data", (chunk) => {
    if (targetSocket) {
      targetSocket.write(chunk);
      return;
    }
    buf = Buffer.concat([buf, chunk]);
    const metaEnd = buf.indexOf("\r\n\r\n");
    if (metaEnd === -1) return;
    const metaStr = buf.toString("utf8", 0, metaEnd);
    const m = metaStr.match(/^X-Target:\s*(.+):(\d+)\s*$/im);
    if (!m) {
      try { socket.write("HTTP/1.1 400 Bad Request\r\n\r\n"); socket.end(); } catch {}
      return;
    }
    const host = m[1].trim();
    const port = parseInt(m[2], 10);
    const remaining = buf.slice(metaEnd + 4);
    buf = null;
    const tlsSock = tls.connect({ host, port, servername: host, rejectUnauthorized: false }, () => {
      tlsSock.setNoDelay(true);
      tlsSock.setKeepAlive(true, 30000);
      targetSocket = tlsSock;
      if (remaining.length > 0) tlsSock.write(remaining);
      socket.pipe(tlsSock);
      tlsSock.pipe(socket);
      tlsSock.on("end", () => { try { socket.end(); } catch {} });
    });
    tlsSock.once("error", () => {
      try { socket.write("HTTP/1.1 502 Bad Gateway\r\n\r\n"); socket.end(); } catch {}
    });
  });

  socket.on("error", () => { try { targetSocket?.destroy(); } catch {} });
  socket.on("end", () => { try { targetSocket?.end(); } catch {} });
}

function startSplitEdge(opts) {
  const { host, port } = parseListenAddr(opts.listen || "127.0.0.1:9090");
  const server = net.createServer(handleSplitEdgeConnection);
  server.on("error", (e) => die(`split edge failed: ${e.message}`));
  server.listen(port, host, () => {
    info(`split edge listening on ${host}:${port}`);
    info("no token auth — use SSH tunnel or firewall for security");
  });
  return server;
}

// ── split proxy: local server (client side) ────────────────────────────────

function handleSplitLocalConnection(clientSocket, edgeHost, edgePort) {
  clientSocket.setNoDelay(true);
  clientSocket.once("data", (head) => {
    const headStr = head.toString();
    const target = connectTargetFromHead(headStr);
    if (!target) {
      try { clientSocket.write("HTTP/1.1 400 Bad Request\r\n\r\n"); clientSocket.end(); } catch {}
      return;
    }
    try {
      const ctx = getSplitSecureContext(target.host);
      clientSocket.write("HTTP/1.1 200 Connection Established\r\n\r\n");
      const tlsSocket = new tls.TLSSocket(clientSocket, {
        isServer: true,
        secureContext: ctx,
        ALPNProtocols: ["http/1.1"],
      });
      let pending = [];
      tlsSocket.on("data", (d) => { pending.push(d); });
      tlsSocket.once("error", () => { try { edgeSocket?.destroy(); } catch {} });

      const meta = `X-Target: ${target.host}:${target.port}\r\n\r\n`;
      const edgeSocket = net.connect(edgePort, edgeHost, () => {
        edgeSocket.setNoDelay(true);
        edgeSocket.setKeepAlive(true, 30000);
        edgeSocket.write(meta);
        // Flush buffered data from codex (arrived during TLS handshake)
        for (const p of pending) edgeSocket.write(p);
        pending = null;
        tlsSocket.removeAllListeners("data");
        tlsSocket.pipe(edgeSocket);
        edgeSocket.pipe(tlsSocket);
      });
      edgeSocket.once("error", () => { try { tlsSocket.destroy(); } catch {} });
    } catch (e) {
      try { clientSocket.write("HTTP/1.1 500 Internal Server Error\r\n\r\n"); clientSocket.end(); } catch {}
    }
  });
  clientSocket.on("error", () => {});
}

function startSplitLocal(opts) {
  const { host, port } = parseListenAddr(opts.listen || "127.0.0.1:8443");
  // Ensure CA certs exist before accepting connections
  const ca = ensureSplitCACert();
  info(`split local CA: ${ca.certPath}`);
  info(`install CA cert on this machine: NODE_EXTRA_CA_CERTS=${ca.certPath}`);
  const server = net.createServer((socket) => handleSplitLocalConnection(socket, opts.edgeHost, opts.edgePort));
  server.on("error", (e) => die(`split local failed: ${e.message}`));
  server.listen(port, host, () => {
    info(`split local listening on ${host}:${port}`);
    info(`edge: ${opts.edgeHost}:${opts.edgePort}`);
  });
  return server;
}

// ── split proxy: daemon management ─────────────────────────────────────────

function isSplitEdgeRunning() {
  try { process.kill(parseInt(fs.readFileSync(SPLIT_EDGE_PID_FILE, "utf8").trim(), 10), 0); return true; } catch { return false; }
}
function isSplitLocalRunning() {
  try { process.kill(parseInt(fs.readFileSync(SPLIT_LOCAL_PID_FILE, "utf8").trim(), 10), 0); return true; } catch { return false; }
}

function runSplitEdgeDaemon() {
  process.title = "codex-relay-split-edge";
  const cfg = loadConfig();
  const sc = cfg.split?.edge || {};
  const listen = sc.listen || "127.0.0.1:9090";
  process.on("uncaughtException", (e) => { try { fs.unlinkSync(SPLIT_EDGE_PID_FILE); } catch {} process.exit(1); });
  const hbInterval = setInterval(() => { try { fs.writeFileSync(SPLIT_EDGE_HB_FILE, String(Date.now())); } catch {} }, 60000);
  const server = startSplitEdge({ listen });
  fs.writeFileSync(SPLIT_EDGE_PID_FILE, String(process.pid));
  try { process.stdin.destroy(); } catch {}
