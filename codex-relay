function cmdProxyUnset() {
  const cfg = loadConfig();
  delete cfg.http;
  delete cfg.https;
  delete cfg.provider_url;
  saveConfig(cfg);
  info("proxy configuration cleared.");
}

function cmdProxyStart() {
  const cfg = loadConfig();
  const upstreamUrl = cfg.https || cfg.http;
  if (!upstreamUrl) die("no upstream proxy configured. Set one first: codex-relay proxy set <url>");

  if (isProxyRunning()) {
    const port = fs.readFileSync(PORT_FILE, "utf8").trim();
    info(`local proxy already running on 127.0.0.1:${port}`);
  } else {
    // Launch daemon process
    const child = spawn(
      process.execPath,
      [SCRIPT_PATH, "--_daemon", upstreamUrl],
      { detached: true, stdio: "ignore" }
    );
    child.unref();

    for (let i = 0; i < 20; i++) {
      if (isProxyRunning()) break;
      execSync("sleep 0.1", { stdio: "ignore" });
    }

    if (!isProxyRunning()) die("failed to start local proxy daemon");
    const port = fs.readFileSync(PORT_FILE, "utf8").trim();
    info(`local proxy started on 127.0.0.1:${port}`);
    info(`HTTP_PROXY=http://127.0.0.1:${port} is active for codex sessions`);
  }

  // Bypass is off by default since apps feature is disabled
  // Run `codex-relay proxy bypass` to enable if needed (requires sudo)
}

function runProxyDaemon(upstreamUrl) {
  process.title = "codex-relay-proxy";
  proxyLog("daemon started, pid=" + process.pid);

  // Prevent SIGHUP from killing daemon when terminal closes
  process.on("SIGHUP", () => {
    proxyLog("received SIGHUP — ignoring");
  });
  process.on("SIGPIPE", () => {
    proxyLog("received SIGPIPE — ignoring");
  });

  process.on("beforeExit", (code) => {
    clearInterval(hbInterval);
    proxyLog(`daemon exiting, code=${code}`);
    cleanupProxyFiles();
  });

  process.on("unhandledRejection", (e) => {
    proxyLog(`unhandled rejection: ${e?.message || e}`);
  });
  process.on("uncaughtException", (e) => {
    proxyLog(`CRASH: ${e.message}`);
    process.exit(1);
  });

  // Heartbeat every 60s to confirm daemon is alive
  const hbInterval = setInterval(() => {
    try { fs.writeFileSync(path.join(CONFIG_DIR, "proxy.heartbeat"), String(Date.now())); } catch {}
  }, 60000);

  const REFRESH_INTERVAL = 5 * 60 * 1000; // 5 minutes

  async function refreshDnsLoop() {
    while (true) {
      await new Promise((r) => setTimeout(r, REFRESH_INTERVAL));
      try {
        // Refresh: resolve all IPs and test connectivity
        await refreshDnsCache(OPENAI_DOMAINS, upstreamUrl, (msg) => proxyLog(msg));
      } catch {} // silent — proxy still works with stale cache
    }
  }

  startLocalProxy(upstreamUrl).then(({ server, port }) => {
    fs.writeFileSync(PID_FILE, String(process.pid));
    fs.writeFileSync(PORT_FILE, String(port));

    // Detach from terminal
    try { process.stdin.destroy(); } catch {}
    try { process.stdout.destroy(); } catch {}
    try { process.stderr.destroy(); } catch {}
    try { fs.closeSync(0); } catch {}
    try { fs.closeSync(1); } catch {}
    try { fs.closeSync(2); } catch {}

    // Periodic DNS refresh
    refreshDnsLoop();

    const cleanup = () => {
      proxyLog("daemon shutting down on signal");
      clearInterval(hbInterval);
      server.close();
      cleanupProxyFiles();
      process.exit(0);
    };
    process.on("SIGTERM", cleanup);
    process.on("SIGINT", cleanup);
  }).catch(() => process.exit(1));
}

function cmdProxyStop() {
  if (!isProxyRunning()) {
    info("no proxy daemon running.");
    return;
  }

  if (isProxyRunning()) {
    const pid = parseInt(fs.readFileSync(PID_FILE, "utf8").trim(), 10);
    try { process.kill(pid, "SIGTERM"); } catch {}
    cleanupProxyFiles();
    info("local proxy stopped.");
  }
}

function cleanupProxyFiles() {
  try { fs.unlinkSync(PID_FILE); } catch {}
  try { fs.unlinkSync(PORT_FILE); } catch {}
}

function isBypassRunning() {
  try {
    const pid = parseInt(fs.readFileSync(BYPASS_PID_FILE, "utf8").trim(), 10);
    try { process.kill(pid, 0); return true; } catch {}
    // Root-owned process — check via ps
    const out = execSync(`ps -p ${pid} -o comm= 2>/dev/null`, { encoding: "utf8", timeout: 2000 }).trim();
    return out.includes("codex-relay-bypass");
  } catch {
    return false;
  }
}

function runBypassDaemon(proxyPort) {
  process.title = "codex-relay-bypass";
  proxyLog("bypass daemon started, pid=" + process.pid + ", target=127.0.0.1:" + proxyPort);

  process.on("SIGHUP", () => {});
  process.on("beforeExit", (code) => {
    proxyLog(`bypass daemon exiting, code=${code}`);
    try { fs.unlinkSync(BYPASS_PID_FILE); } catch {}
  });

  process.on("unhandledRejection", (e) => {
    proxyLog(`bypass unhandled rejection: ${e?.message || e}`);
  });
  process.on("uncaughtException", (e) => {
    proxyLog(`bypass CRASH: ${e.message}`);
    try { fs.unlinkSync(BYPASS_PID_FILE); } catch {}
    process.exit(1);
  });

  const server = net.createServer((clientSocket) => {
    const upstream = new net.Socket();
    upstream.connect(proxyPort, "127.0.0.1", () => {
      upstream.setKeepAlive(true, 30000);
      clientSocket.setKeepAlive(true, 30000);
      clientSocket.pipe(upstream);
      upstream.pipe(clientSocket);
    });
    upstream.on("error", () => { try { clientSocket.end(); } catch {} });
    clientSocket.on("error", () => { try { upstream.end(); } catch {} });
  });

  server.on("error", (e) => {
    proxyLog(`bypass server error: ${e.message}`);
    process.exit(1);
  });
  server.listen(443, "127.0.0.1", () => {
    fs.writeFileSync(BYPASS_PID_FILE, String(process.pid));

    try { process.stdin.destroy(); } catch {}
    try { process.stdout.destroy(); } catch {}
    try { process.stderr.destroy(); } catch {}
    try { fs.closeSync(0); } catch {}
    try { fs.closeSync(1); } catch {}
    try { fs.closeSync(2); } catch {}

    // Heartbeat every 60s
    const hbInterval = setInterval(() => {
      try { fs.writeFileSync(path.join(CONFIG_DIR, "bypass.heartbeat"), String(Date.now())); } catch {}
    }, 60000);

    const cleanup = () => {
      proxyLog("bypass daemon shutting down on signal");
      clearInterval(hbInterval);
      server.close();
      try { fs.unlinkSync(BYPASS_PID_FILE); } catch {}
      try { fs.unlinkSync(path.join(CONFIG_DIR, "bypass.heartbeat")); } catch {}
      process.exit(0);
    };
    process.on("SIGTERM", cleanup);
    process.on("SIGINT", cleanup);
  });
}

function cleanupBypassFiles() {
  try { fs.unlinkSync(BYPASS_PID_FILE); } catch {}
  try { fs.unlinkSync(path.join(CONFIG_DIR, "bypass.heartbeat")); } catch {}
}

function manageHosts(action) {
  const hostsFile = "/etc/hosts";
  const marker = "# codex-relay-bypass";
  let content;
  try {
    content = fs.readFileSync(hostsFile, "utf8");
  } catch {
    die(`cannot read ${hostsFile}`);
  }

  const lines = content.split("\n").filter((l) => !l.includes(marker));
  if (action === "add") {
    for (const entry of BYPASS_HOSTS) {
      lines.push(`${entry.alias} ${entry.host} ${marker}`);
    }
  }
  try {
    fs.writeFileSync(hostsFile, lines.join("\n") + "\n");
  } catch {
    die(`cannot write ${hostsFile}. Run with sudo.`);
  }
}

function cmdProxyBypass(opts = {}) {
  if (opts.remove) {
    if (!isBypassRunning()) {
      info("bypass not running.");
    } else {
      const pid = parseInt(fs.readFileSync(BYPASS_PID_FILE, "utf8").trim(), 10);
      try { process.kill(pid, "SIGTERM"); } catch {}
      cleanupBypassFiles();
      info("bypass stopped.");
    }
    manageHosts("remove");
    info("hosts entries removed.");
    return;
  }

  if (isBypassRunning()) {
    info("bypass already running.");
    return;
  }

  const localPort = getLocalProxyPort();
  if (!localPort) die("local proxy not running. Start it first: codex-relay proxy start");

  // 1. Add hosts entries
  manageHosts("add");
  info("hosts: chatgpt.com → 127.0.0.1");

  // 2. Launch bypass daemon (needs sudo for port 443)
  const child = spawn(
    process.execPath,
    [SCRIPT_PATH, "--_bypass-daemon", String(localPort)],
    { detached: true, stdio: "ignore" }
  );
  child.unref();

  for (let i = 0; i < 20; i++) {
    if (isBypassRunning()) break;
    execSync("sleep 0.1", { stdio: "ignore" });
  }

  if (isBypassRunning()) {
    info("bypass started: 127.0.0.1:443 → 127.0.0.1:" + localPort);
  } else {
    die("bypass failed to start. Try: sudo codex-relay proxy bypass");
  }
}

function getLocalProxyPort() {
  try {
    if (isProxyRunning()) {
      return parseInt(fs.readFileSync(PORT_FILE, "utf8").trim(), 10);
    }
  } catch {}
  return null;
}

function cmdProxyTest(opts = {}) {
  const testUrl = opts.url || "https://ipv4.icanhazip.com";
  const timeout = opts.timeout || 10;

  let proxyUrl = process.env.HTTPS_PROXY || process.env.https_proxy ||
                 process.env.HTTP_PROXY || process.env.http_proxy;

  const localPort = getLocalProxyPort();
  if (!proxyUrl && localPort) {
    proxyUrl = `http://127.0.0.1:${localPort}`;
  }

  if (!proxyUrl) {
    const cfg = loadConfig();
    proxyUrl = cfg.https || cfg.http;
  }

  if (!proxyUrl && !localPort) {
    console.log(`Proxy:    (none configured)`);
    console.log(`Test URL: ${testUrl}`);
    console.log(`Result:   FAIL — No proxy configured.`);
    process.exit(1);
  }

  console.log(`Proxy:    ${proxyUrl}`);
  console.log(`Test URL: ${testUrl}`);

  let allOk = true;
  const start = Date.now();
  try {
    const out = execSync(
      `curl -s -o /dev/null -w '%{http_code}' --proxy '${proxyUrl}' --connect-timeout ${timeout} --max-time ${timeout} '${testUrl}'`,
      { encoding: "utf8", timeout: (timeout + 5) * 1000 }
    ).trim();
    const latency = Date.now() - start;
    console.log(`Status:   ${out}`);
    console.log(`Latency:  ${latency}ms`);
    const code = parseInt(out, 10);
    if (code >= 200 && code < 500) {
      console.log(`Result:   OK — proxy is reachable`);
    } else {
      console.log(`Result:   FAIL — got status ${out}`);
      allOk = false;
    }
  } catch {
    const latency = Date.now() - start;
    console.log(`Status:   000`);
    console.log(`Latency:  ${latency}ms`);
    console.log(`Result:   FAIL — could not connect`);
    allOk = false;
  }

  // codex doctor integration
  if (localPort && findCodex()) {
    console.log(`\ncodex doctor:`);
    try {
      const env = { ...process.env,
        HTTPS_PROXY: `http://127.0.0.1:${localPort}`,
        HTTP_PROXY: `http://127.0.0.1:${localPort}`,
        http_proxy: `http://127.0.0.1:${localPort}`,
        https_proxy: `http://127.0.0.1:${localPort}`,
        WS_PROXY: `http://127.0.0.1:${localPort}`,
        WSS_PROXY: `http://127.0.0.1:${localPort}`,
        NO_PROXY: "localhost,127.0.0.1,::1",
      };
      const out = execSync(`${findCodex()} doctor`, { encoding: "utf8", timeout: 25000, env });
      // Extract key lines
      const lines = out.split("\n");
      const wsLine = lines.find((l) => l.includes("websocket") && l.includes("connected"));
      const reachLine = lines.find((l) => l.includes("reachability") && l.includes("provider"));
      const baseLine = lines.find((l) => l.includes("base URL"));
      const handshakeLine = lines.find((l) => l.includes("handshake result"));
      if (wsLine) {
        const ok = wsLine.includes("✓") || wsLine.includes("connected");
        console.log(`  ${ok ? "✓" : "✗"} websocket: ${wsLine.replace(/^\s+/, "").replace(/^\S+\s+/, "").trim()}`);
        if (!ok) allOk = false;
      }
      if (handshakeLine) console.log(`    ${handshakeLine.trim()}`);
      if (reachLine) {
        const ok = reachLine.includes("✓") || reachLine.includes("reachable");
        console.log(`  ${ok ? "✓" : "✗"} reachability: ${reachLine.replace(/^\s+/, "").replace(/^\S+\s+/, "").trim()}`);
        if (!ok) allOk = false;
      }
      if (baseLine) console.log(`    ${baseLine.trim()}`);
    } catch {
      console.log(`  ✗ codex doctor: timeout or failed to run`);
      allOk = false;
    }
  }

  if (!allOk) process.exit(1);
}

