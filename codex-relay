#!/usr/bin/env node
// codex-relay — Node.js wrapper for OpenAI Codex CLI with proxy support.
// Requires Node.js >= 18 (built-in fetch, no npm dependencies).

const net = require("net");
const dns = require("dns").promises;
const fs = require("fs");
const path = require("path");
const os = require("os");
const { spawn, execSync } = require("child_process");

// ── config ─────────────────────────────────────────────────────────────────

const NAME = "codex-relay";
const VERSION = "0.2.0";

// When running via sudo, use the original user's home, not /var/root
const SUDO_USER = process.env.SUDO_USER;
const REAL_HOME = (() => {
  if (!SUDO_USER) return os.homedir();
  try {
    const info = require("os").userInfo({ encoding: "utf8" });
    // macOS: userInfo doesn't take options; try to resolve from /Users or /home
  } catch {}
  // Heuristic: check common home dir patterns
  for (const prefix of ["/Users", "/home"]) {
    const candidate = path.join(prefix, SUDO_USER);
    try { if (fs.statSync(candidate).isDirectory()) return candidate; } catch {}
  }
  return os.homedir();
})();
const CONFIG_DIR = path.join(REAL_HOME, ".codex-relay");
const CONFIG_FILE = path.join(CONFIG_DIR, "config.json");
const DNS_CACHE_FILE = path.join(CONFIG_DIR, "dns.json");
const PID_FILE = path.join(CONFIG_DIR, "proxy.pid");
const PORT_FILE = path.join(CONFIG_DIR, "proxy.port");
const BYPASS_PID_FILE = path.join(CONFIG_DIR, "bypass.pid");
const LOG_FILE = path.join(CONFIG_DIR, "proxy.log");
const MAX_LOG_LINES = 500;

function proxyLog(msg) {
  const ts = new Date().toISOString();
  const line = `${ts} ${msg}\n`;
  try {
    fs.appendFileSync(LOG_FILE, line);
    // Rotate if too large
    const lines = fs.readFileSync(LOG_FILE, "utf8").split("\n");
    if (lines.length > MAX_LOG_LINES + 50) {
      fs.writeFileSync(LOG_FILE, lines.slice(-MAX_LOG_LINES).join("\n"));
    }
  } catch {}
}

// Resolve script path (handle relative paths for sudo)
const SCRIPT_PATH = (() => {
  try { return fs.realpathSync(process.argv[1]); } catch { return process.argv[1]; }
})();

const BYPASS_HOSTS = [
  { host: "chatgpt.com", alias: "127.0.0.1" },
];

const OPENAI_DOMAINS = [
  "api.openai.com",
  "auth.openai.com",
  "chatgpt.com",
  "platform.openai.com",
  "developers.openai.com",
];

// ── helpers ────────────────────────────────────────────────────────────────

function die(msg) {
  console.error(`error: ${msg}`);
  process.exit(1);
}
function info(msg) {
  console.error(`[${NAME}] ${msg}`);
}

function loadConfig() {
  try { return JSON.parse(fs.readFileSync(CONFIG_FILE, "utf8")); } catch { return {}; }
}
function saveConfig(cfg) {
  fs.mkdirSync(CONFIG_DIR, { recursive: true });
  fs.writeFileSync(CONFIG_FILE, JSON.stringify(cfg, null, 2));
}

function findCodex() {
  try { return execSync("which codex", { encoding: "utf8" }).trim(); } catch { return null; }
}
function codexVersion() {
  const bin = findCodex();
  if (!bin) return null;
  try { return execSync(`"${bin}" --version`, { encoding: "utf8", timeout: 5000 }).trim(); } catch { return null; }
}

// ── DNS resolution ─────────────────────────────────────────────────────────

async function resolveAllIPs(host) {
  try { return await dns.resolve4(host); } catch { return []; }
}

// In-memory cache to reduce disk I/O on every CONNECT
let _dnsMemCache = null;
let _dnsMemCacheTs = 0;
const DNS_MEM_CACHE_TTL = 30000; // 30 seconds before re-reading from disk

function loadDnsCache() {
  const now = Date.now();
  if (_dnsMemCache && (now - _dnsMemCacheTs) < DNS_MEM_CACHE_TTL) return _dnsMemCache;
  try {
    const raw = JSON.parse(fs.readFileSync(DNS_CACHE_FILE, "utf8"));
    for (const [host, entry] of Object.entries(raw)) {
      if (entry.ip && !entry.ips) {
        raw[host] = { ips: [{ ip: entry.ip, ok: null, testedAt: null }], ts: entry.ts || 0 };
      }
    }
    _dnsMemCache = raw;
    _dnsMemCacheTs = now;
    return raw;
  } catch { return {}; }
}
function saveDnsCache(cache) {
  fs.mkdirSync(CONFIG_DIR, { recursive: true });
  fs.writeFileSync(DNS_CACHE_FILE, JSON.stringify(cache, null, 2));
  _dnsMemCache = cache;
  _dnsMemCacheTs = Date.now();
}

function getBestIp(host) {
  const cache = loadDnsCache();
  const entry = cache[host];
  if (!entry || !entry.ips?.length) return null;
  // Priority: ok:true > ok:null (untested) > skip ok:false
  const good = entry.ips.filter((e) => e.ok === true);
  const untested = entry.ips.filter((e) => e.ok === null || e.ok === undefined);
  const pool = good.length > 0 ? good : untested.length > 0 ? untested : entry.ips;
  // Random within same priority tier
  return pool[Math.floor(Math.random() * pool.length)]?.ip || null;
}

function markIpResult(host, ip, ok) {
  const cache = loadDnsCache();
  const entry = cache[host];
  if (!entry || !entry.ips) return;
  for (const e of entry.ips) {
    if (e.ip === ip) { e.ok = ok; e.testedAt = Date.now(); break; }
  }
  // If none matched, add it
  if (!entry.ips.some((e) => e.ip === ip)) {
    entry.ips.push({ ip, ok, testedAt: Date.now() });
  }
  saveDnsCache(cache);
}

function upsertCacheIPs(host, ips) {
  const cache = loadDnsCache();
  const entry = cache[host] || { ips: [], ts: 0 };
  const existing = new Map(entry.ips.map((e) => [e.ip, e]));
  entry.ips = ips.map((ip) => {
    const old = existing.get(ip);
    return old || { ip, ok: null, testedAt: null };
  });
  entry.ts = Date.now();
  cache[host] = entry;
  saveDnsCache(cache);
}

// Test one IP through the upstream proxy by checking CONNECT response
async function testIp(ip, host, port, upstreamUrl) {
  const { host: upHost, port: upPort, auth } = parseProxyUrl(upstreamUrl);
  return new Promise((resolve) => {
    const sock = new net.Socket();
    sock.setTimeout(3000);
    sock.on("error", () => resolve(false));
    sock.on("timeout", () => { sock.destroy(); resolve(false); });
    sock.connect(upPort, upHost, () => {
      let req = `CONNECT ${ip}:${port || 443} HTTP/1.1\r\nHost: ${host}:${port || 443}\r\n`;
      if (auth) req += `Proxy-Authorization: Basic ${auth}\r\n`;
      req += "\r\n";
      sock.write(req);
      sock.once("data", (data) => {
        const ok = data.toString().startsWith("HTTP/1.1 200") || data.toString().startsWith("HTTP/1.0 200");
        sock.destroy();
        resolve(ok);
      });
    });
  });
}

async function refreshDnsCache(domains = OPENAI_DOMAINS, proxyUrl, logCb) {
  const log = logCb || ((...a) => console.log(...a));
  if (!proxyUrl) {
    const cfg = loadConfig();
    proxyUrl = cfg.https || cfg.http;
  }
  for (const host of domains) {
    const ips = await resolveAllIPs(host);
    if (ips.length > 0) {
      upsertCacheIPs(host, ips);
      if (proxyUrl) {
        const results = [];
        for (const ip of ips) {
          const ok = await testIp(ip, host, 443, proxyUrl);
          results.push(ok ? "✓" : "✗");
          markIpResult(host, ip, ok);
        }
        log(`  ${host.padEnd(30)} → ${ips.join(", ")}  [${results.join(" ")}]`);
      } else {
        log(`  ${host.padEnd(30)} → ${ips.join(", ")}  (no proxy to test)`);
      }
    } else {
      log(`  ${host.padEnd(30)} → FAILED`);
    }
  }
  return loadDnsCache();
}

// Parse proxy URL: http://[user:pass@]host:port
function parseProxyUrl(url) {
  const noScheme = url.replace(/^https?:\/\//, "");
  const atIdx = noScheme.lastIndexOf("@");
  const authPart = atIdx >= 0 ? noScheme.slice(0, atIdx) : "";
  const hostPort = atIdx >= 0 ? noScheme.slice(atIdx + 1) : noScheme;
  const colonIdx = hostPort.lastIndexOf(":");
  const host = colonIdx >= 0 ? hostPort.slice(0, colonIdx) : hostPort;
  const port = colonIdx >= 0 ? parseInt(hostPort.slice(colonIdx + 1), 10) : 80;
  const userColon = authPart.indexOf(":");
  const user = userColon >= 0 ? authPart.slice(0, userColon) : (authPart || "");
  const pass = userColon >= 0 ? authPart.slice(userColon + 1) : "";
  const auth = user ? Buffer.from(`${user}:${pass}`).toString("base64") : "";
  return { host, port, user, pass, auth };
}

// ── local forward proxy ────────────────────────────────────────────────────

function startLocalProxy(upstreamUrl, port = 0) {
  return new Promise((resolve, reject) => {
    const server = net.createServer();
    server.on("error", reject);

    server.listen(port, "127.0.0.1", () => {
      // Replace startup-only error handler with persistent one
      server.removeListener("error", reject);
      server.on("error", (e) => {
        proxyLog(`server error: ${e.message}`);
      });
      const addr = server.address();
      resolve({ server, port: addr.port });
    });

    server.on("connection", (clientSocket) => {
      clientSocket.once("data", (head) => {
        handleRequest(clientSocket, head, upstreamUrl);
      });
      clientSocket.on("error", () => {}); // prevent crash on client errors
    });
  });
}

async function handleRequest(clientSocket, head, upstreamUrl) {
  try {
    const headStr = head.toString();
    const connectMatch = headStr.match(/^CONNECT (.+):(\d+)/m);

    if (!connectMatch) {
      forwardHttp(clientSocket, head, upstreamUrl);
      return;
    }

    const host = connectMatch[1];
    const port = parseInt(connectMatch[2], 10);

        // Resolve all IPs and cache if not already cached
        let entry = loadDnsCache()[host];
        if (!entry || !entry.ips?.length) {
          const ips = await resolveAllIPs(host);
          if (ips.length > 0) { upsertCacheIPs(host, ips); entry = loadDnsCache()[host]; }
        }

        // Parse proxy URL: http://[user:pass@]host:port
        const { host: upHost, port: upPort, auth } = parseProxyUrl(upstreamUrl);

        // Try up to 3 IPs
        const triedIps = [];
        let connected = false;
        const MAX_TRIES = 2; // 2 attempts; WebSocket has tight timeouts

        for (let attempt = 0; attempt < MAX_TRIES && !connected; attempt++) {
          const ip = getBestIp(host);
          if (!ip) break;
          if (triedIps.includes(ip)) break;
          triedIps.push(ip);

          const target = ip || host;
          let modified = headStr.replace(
            /^CONNECT .+:\d+/m,
            `CONNECT ${target}:${port}`
          );
          if (auth && !/Proxy-Authorization:/im.test(modified)) {
            modified = modified.replace(
              /\r\n\r\n$/,
              `\r\nProxy-Authorization: Basic ${auth}\r\n\r\n`
            );
          }

          await new Promise((resolve) => {
            const upstreamSocket = new net.Socket();
            // TCP connect timeout: 3s to reach upstream proxy
            const connTimer = setTimeout(() => {
              markIpResult(host, ip, false);
              proxyLog(`CONNECT ${host}:${port} → ${ip} connect timeout`);
              try { upstreamSocket.destroy(); } catch {}
              resolve(); // try next IP
            }, 3000);
            upstreamSocket.once("connect", () => {
              clearTimeout(connTimer);
              // Response timeout: 3s for upstream to reply to CONNECT
              upstreamSocket.setTimeout(3000);
              upstreamSocket.on("timeout", () => {
                markIpResult(host, ip, false);
                proxyLog(`CONNECT ${host}:${port} → ${ip} response timeout`);
                try { clientSocket.write("HTTP/1.1 504 Gateway Timeout\r\n\r\n"); clientSocket.end(); } catch {}
                try { upstreamSocket.destroy(); } catch {}
                connected = true;
                resolve();
              });
              upstreamSocket.write(modified);
              // Buffer entire upstream HTTP response to avoid TLS stream corruption
              let respBuf = Buffer.alloc(0);
              const onData = (chunk) => {
                respBuf = Buffer.concat([respBuf, chunk]);
                const headerEnd = respBuf.indexOf("\r\n\r\n");
                if (headerEnd < 0) return; // need more data
                upstreamSocket.removeListener("data", onData);

                const respStr = respBuf.toString("utf8", 0, headerEnd + 4);
                if (respStr.startsWith("HTTP/1.1 200") || respStr.startsWith("HTTP/1.0 200")) {
                  markIpResult(host, ip, true);
                  proxyLog(`CONNECT ${host}:${port} → ${ip} OK`);
                  upstreamSocket.setTimeout(0);
                  upstreamSocket.removeAllListeners("timeout");
                  // TCP keepalive to prevent upstream proxy idle timeout
                  upstreamSocket.setKeepAlive(true, 30000);
                  clientSocket.setKeepAlive(true, 30000);
                  clientSocket.write("HTTP/1.1 200 Connection Established\r\n\r\n");
                  const leftover = respBuf.slice(headerEnd + 4);
                  if (leftover.length > 0) clientSocket.write(leftover);
                  clientSocket.pipe(upstreamSocket);
                  upstreamSocket.pipe(clientSocket);
                  connected = true;
                } else {
                  markIpResult(host, ip, false);
                  proxyLog(`CONNECT ${host}:${port} → ${ip} rejected: ${respStr.split("\r\n")[0]}`);
                  try { clientSocket.write(respStr); } catch {}
                  upstreamSocket.destroy();
                }
                resolve();
              };
              upstreamSocket.on("data", onData);
            });
            upstreamSocket.on("error", () => {
              if (connected) return;
              clearTimeout(connTimer);
              markIpResult(host, ip, false);
              try { upstreamSocket.destroy(); } catch {}
              resolve(); // try next IP
            });
            clientSocket.on("error", () => {
              clearTimeout(connTimer);
              try { upstreamSocket.destroy(); } catch {}
              resolve();
            });
            upstreamSocket.connect(upPort, upHost);
          });
        }

        if (!connected) {
          proxyLog(`CONNECT ${host}:${port} FAIL all IPs tried: ${triedIps.join(", ")}`);
          try { clientSocket.write("HTTP/1.1 502 Bad Gateway\r\n\r\n"); clientSocket.end(); } catch {}
        }
  } catch (e) {
    proxyLog(`request error: ${e.message}`);
    try { clientSocket.end(); } catch {}
  }
}

async function forwardHttp(clientSocket, head, upstreamUrl) {
  const headStr = head.toString();

  // Parse target host from HTTP request line: GET http://host/path HTTP/1.1
  const reqMatch = headStr.match(/^([A-Z]+) http:\/\/([^/:]+)(:\d+)?(\/[^\s]*)? HTTP\/[0-9.]+\r\n/m);
  let modifiedHead = headStr;

  if (reqMatch) {
    const host = reqMatch[2];
    let ip = getBestIp(host);
    if (!ip) {
      const ips = await resolveAllIPs(host);
      if (ips.length > 0) { upsertCacheIPs(host, ips); ip = getBestIp(host); }
    }
    if (ip) {
      // Rewrite request URL to use IP so upstream proxy doesn't need DNS
      const portSuffix = reqMatch[3] || "";
      const path = reqMatch[4] || "/";
      modifiedHead = headStr.replace(
        `http://${host}${portSuffix}${path}`,
        `http://${ip}${portSuffix}${path}`
      );
    }
  }

  const { host: upHost, port: upPort, auth } = parseProxyUrl(upstreamUrl);

  // Inject Proxy-Authorization if upstream needs it and request lacks it
  if (auth && !/Proxy-Authorization:/im.test(modifiedHead)) {
    modifiedHead = modifiedHead.replace(
      /\r\n\r\n$/,
      `\r\nProxy-Authorization: Basic ${auth}\r\n\r\n`
    );
  }

  const upstream = new net.Socket();
  upstream.setTimeout(10000);
  upstream.on("timeout", () => {
    try { clientSocket.end(); } catch {}
    try { upstream.destroy(); } catch {}
  });
  upstream.connect(upPort, upHost, () => {
    upstream.setKeepAlive(true, 30000);
    clientSocket.setKeepAlive(true, 30000);
    upstream.write(modifiedHead);
    clientSocket.pipe(upstream);
    upstream.pipe(clientSocket);
  });
  upstream.on("error", () => { try { clientSocket.end(); } catch {} });
  clientSocket.on("error", () => { try { upstream.end(); } catch {} });
}

function isProxyRunning() {
  try {
    const pid = parseInt(fs.readFileSync(PID_FILE, "utf8").trim(), 10);
    process.kill(pid, 0);
    return true;
  } catch {
    return false;
  }
}

// ── CLI handlers ───────────────────────────────────────────────────────────

function cmdProxySet(url) {
  if (!url) die(`usage: ${NAME} proxy set <url>`);
  const cfg = loadConfig();
  cfg.http = url;
  cfg.https = url;
  saveConfig(cfg);
  info(`proxy set to: ${url}`);
}

function cmdProxyShow() {
  const cfg = loadConfig();

  // Upstream proxy config
  if (process.env.HTTP_PROXY) console.log(`env proxy:       ${process.env.HTTP_PROXY}`);
  else if (process.env.http_proxy) console.log(`env proxy:       ${process.env.http_proxy}`);
  if (cfg.http) console.log(`config proxy:    ${cfg.http}`);
  if (cfg.provider_url) console.log(`provider URL:    ${cfg.provider_url}`);

  // Local forward proxy daemon status
  if (isProxyRunning()) {
    const port = fs.readFileSync(PORT_FILE, "utf8").trim();
    console.log(`local daemon:    running on 127.0.0.1:${port}`);
  } else {
    console.log(`local daemon:    stopped`);
  }

  // Effective proxy for codex sessions
  const localPort = getLocalProxyPort();
  if (localPort) {
    console.log(`effective proxy: http://127.0.0.1:${localPort} (local daemon)`);
  } else if (cfg.http || process.env.HTTP_PROXY || process.env.http_proxy) {
    console.log(`effective proxy: ${cfg.http || process.env.HTTP_PROXY || process.env.http_proxy} (direct)`);
  } else {
    console.log(`effective proxy: none`);
  }

}

function cmdProxyUnset() {
  const cfg = loadConfig();
  delete cfg.http;
  delete cfg.https;
  delete cfg.provider_url;
  saveConfig(cfg);
  info("proxy configuration cleared.");
}

function cmdProxyStart() {
  const cfg = loadConfig();
  const upstreamUrl = cfg.https || cfg.http;
  if (!upstreamUrl) die("no upstream proxy configured. Set one first: codex-relay proxy set <url>");

  if (isProxyRunning()) {
    const port = fs.readFileSync(PORT_FILE, "utf8").trim();
    info(`local proxy already running on 127.0.0.1:${port}`);
  } else {
    // Launch daemon process
    const child = spawn(
      process.execPath,
      [SCRIPT_PATH, "--_daemon", upstreamUrl],
      { detached: true, stdio: "ignore" }
    );
    child.unref();

    for (let i = 0; i < 20; i++) {
      if (isProxyRunning()) break;
      execSync("sleep 0.1", { stdio: "ignore" });
    }

    if (!isProxyRunning()) die("failed to start local proxy daemon");
    const port = fs.readFileSync(PORT_FILE, "utf8").trim();
    info(`local proxy started on 127.0.0.1:${port}`);
    info(`HTTP_PROXY=http://127.0.0.1:${port} is active for codex sessions`);
  }

  // Bypass is off by default since apps feature is disabled
  // Run `codex-relay proxy bypass` to enable if needed (requires sudo)
}

function runProxyDaemon(upstreamUrl) {
  process.title = "codex-relay-proxy";
  proxyLog("daemon started, pid=" + process.pid);

  // Prevent SIGHUP from killing daemon when terminal closes
  process.on("SIGHUP", () => {
    proxyLog("received SIGHUP — ignoring");
  });
  process.on("SIGPIPE", () => {
    proxyLog("received SIGPIPE — ignoring");
  });

  process.on("beforeExit", (code) => {
    clearInterval(hbInterval);
    proxyLog(`daemon exiting, code=${code}`);
    cleanupProxyFiles();
  });

  process.on("unhandledRejection", (e) => {
    proxyLog(`unhandled rejection: ${e?.message || e}`);
  });
  process.on("uncaughtException", (e) => {
    proxyLog(`CRASH: ${e.message}`);
    process.exit(1);
  });

  // Heartbeat every 60s to confirm daemon is alive
  const hbInterval = setInterval(() => {
    try { fs.writeFileSync(path.join(CONFIG_DIR, "proxy.heartbeat"), String(Date.now())); } catch {}
  }, 60000);

  const REFRESH_INTERVAL = 5 * 60 * 1000; // 5 minutes

  async function refreshDnsLoop() {
    while (true) {
      await new Promise((r) => setTimeout(r, REFRESH_INTERVAL));
      try {
        // Refresh: resolve all IPs and test connectivity
        await refreshDnsCache(OPENAI_DOMAINS, upstreamUrl, (msg) => proxyLog(msg));
      } catch {} // silent — proxy still works with stale cache
    }
  }

  startLocalProxy(upstreamUrl).then(({ server, port }) => {
    fs.writeFileSync(PID_FILE, String(process.pid));
    fs.writeFileSync(PORT_FILE, String(port));

    // Detach from terminal
    try { process.stdin.destroy(); } catch {}
    try { process.stdout.destroy(); } catch {}
    try { process.stderr.destroy(); } catch {}
    try { fs.closeSync(0); } catch {}
    try { fs.closeSync(1); } catch {}
    try { fs.closeSync(2); } catch {}

    // Periodic DNS refresh
    refreshDnsLoop();

    const cleanup = () => {
      proxyLog("daemon shutting down on signal");
      clearInterval(hbInterval);
      server.close();
      cleanupProxyFiles();
      process.exit(0);
    };
    process.on("SIGTERM", cleanup);
    process.on("SIGINT", cleanup);
  }).catch(() => process.exit(1));
}

function cmdProxyStop() {
  if (!isProxyRunning()) {
    info("no proxy daemon running.");
    return;
  }

  if (isProxyRunning()) {
    const pid = parseInt(fs.readFileSync(PID_FILE, "utf8").trim(), 10);
    try { process.kill(pid, "SIGTERM"); } catch {}
    cleanupProxyFiles();
    info("local proxy stopped.");
  }
}

function cleanupProxyFiles() {
  try { fs.unlinkSync(PID_FILE); } catch {}
  try { fs.unlinkSync(PORT_FILE); } catch {}
}

function isBypassRunning() {
  try {
    const pid = parseInt(fs.readFileSync(BYPASS_PID_FILE, "utf8").trim(), 10);
    try { process.kill(pid, 0); return true; } catch {}
    // Root-owned process — check via ps
    const out = execSync(`ps -p ${pid} -o comm= 2>/dev/null`, { encoding: "utf8", timeout: 2000 }).trim();
    return out.includes("codex-relay-bypass");
  } catch {
    return false;
  }
}

function runBypassDaemon(proxyPort) {
  process.title = "codex-relay-bypass";
  proxyLog("bypass daemon started, pid=" + process.pid + ", target=127.0.0.1:" + proxyPort);

  process.on("SIGHUP", () => {});
  process.on("beforeExit", (code) => {
    proxyLog(`bypass daemon exiting, code=${code}`);
    try { fs.unlinkSync(BYPASS_PID_FILE); } catch {}
  });

  process.on("unhandledRejection", (e) => {
    proxyLog(`bypass unhandled rejection: ${e?.message || e}`);
  });
  process.on("uncaughtException", (e) => {
    proxyLog(`bypass CRASH: ${e.message}`);
    try { fs.unlinkSync(BYPASS_PID_FILE); } catch {}
    process.exit(1);
  });

  const server = net.createServer((clientSocket) => {
    const upstream = new net.Socket();
    upstream.connect(proxyPort, "127.0.0.1", () => {
      upstream.setKeepAlive(true, 30000);
      clientSocket.setKeepAlive(true, 30000);
      clientSocket.pipe(upstream);
      upstream.pipe(clientSocket);
    });
    upstream.on("error", () => { try { clientSocket.end(); } catch {} });
    clientSocket.on("error", () => { try { upstream.end(); } catch {} });
  });

  server.on("error", (e) => {
    proxyLog(`bypass server error: ${e.message}`);
    process.exit(1);
  });
  server.listen(443, "127.0.0.1", () => {
    fs.writeFileSync(BYPASS_PID_FILE, String(process.pid));

    try { process.stdin.destroy(); } catch {}
    try { process.stdout.destroy(); } catch {}
    try { process.stderr.destroy(); } catch {}
    try { fs.closeSync(0); } catch {}
    try { fs.closeSync(1); } catch {}
    try { fs.closeSync(2); } catch {}

    // Heartbeat every 60s
    const hbInterval = setInterval(() => {
      try { fs.writeFileSync(path.join(CONFIG_DIR, "bypass.heartbeat"), String(Date.now())); } catch {}
    }, 60000);

    const cleanup = () => {
      proxyLog("bypass daemon shutting down on signal");
      clearInterval(hbInterval);
      server.close();
      try { fs.unlinkSync(BYPASS_PID_FILE); } catch {}
      try { fs.unlinkSync(path.join(CONFIG_DIR, "bypass.heartbeat")); } catch {}
      process.exit(0);
    };
    process.on("SIGTERM", cleanup);
    process.on("SIGINT", cleanup);
  });
}

function cleanupBypassFiles() {
  try { fs.unlinkSync(BYPASS_PID_FILE); } catch {}
  try { fs.unlinkSync(path.join(CONFIG_DIR, "bypass.heartbeat")); } catch {}
}

function manageHosts(action) {
  const hostsFile = "/etc/hosts";
  const marker = "# codex-relay-bypass";
  let content;
  try {
    content = fs.readFileSync(hostsFile, "utf8");
  } catch {
    die(`cannot read ${hostsFile}`);
  }

  const lines = content.split("\n").filter((l) => !l.includes(marker));
  if (action === "add") {
    for (const entry of BYPASS_HOSTS) {
      lines.push(`${entry.alias} ${entry.host} ${marker}`);
    }
  }
  try {
    fs.writeFileSync(hostsFile, lines.join("\n") + "\n");
  } catch {
    die(`cannot write ${hostsFile}. Run with sudo.`);
  }
}

function cmdProxyBypass(opts = {}) {
  if (opts.remove) {
    if (!isBypassRunning()) {
      info("bypass not running.");
    } else {
      const pid = parseInt(fs.readFileSync(BYPASS_PID_FILE, "utf8").trim(), 10);
      try { process.kill(pid, "SIGTERM"); } catch {}
      cleanupBypassFiles();
      info("bypass stopped.");
    }
    manageHosts("remove");
    info("hosts entries removed.");
    return;
  }

  if (isBypassRunning()) {
    info("bypass already running.");
    return;
  }

  const localPort = getLocalProxyPort();
  if (!localPort) die("local proxy not running. Start it first: codex-relay proxy start");

  // 1. Add hosts entries
  manageHosts("add");
  info("hosts: chatgpt.com → 127.0.0.1");

  // 2. Launch bypass daemon (needs sudo for port 443)
  const child = spawn(
    process.execPath,
    [SCRIPT_PATH, "--_bypass-daemon", String(localPort)],
    { detached: true, stdio: "ignore" }
  );
  child.unref();

  for (let i = 0; i < 20; i++) {
    if (isBypassRunning()) break;
    execSync("sleep 0.1", { stdio: "ignore" });
  }

  if (isBypassRunning()) {
    info("bypass started: 127.0.0.1:443 → 127.0.0.1:" + localPort);
  } else {
    die("bypass failed to start. Try: sudo codex-relay proxy bypass");
  }
}

function getLocalProxyPort() {
  try {
    if (isProxyRunning()) {
      return parseInt(fs.readFileSync(PORT_FILE, "utf8").trim(), 10);
    }
  } catch {}
  return null;
}

function cmdProxyTest(opts = {}) {
  const testUrl = opts.url || "https://ipv4.icanhazip.com";
  const timeout = opts.timeout || 10;

  let proxyUrl = process.env.HTTPS_PROXY || process.env.https_proxy ||
                 process.env.HTTP_PROXY || process.env.http_proxy;

  const localPort = getLocalProxyPort();
  if (!proxyUrl && localPort) {
    proxyUrl = `http://127.0.0.1:${localPort}`;
  }

  if (!proxyUrl) {
    const cfg = loadConfig();
    proxyUrl = cfg.https || cfg.http;
  }

  if (!proxyUrl && !localPort) {
    console.log(`Proxy:    (none configured)`);
    console.log(`Test URL: ${testUrl}`);
    console.log(`Result:   FAIL — No proxy configured.`);
    process.exit(1);
  }

  console.log(`Proxy:    ${proxyUrl}`);
  console.log(`Test URL: ${testUrl}`);

  let allOk = true;
  const start = Date.now();
  try {
    const out = execSync(
      `curl -s -o /dev/null -w '%{http_code}' --proxy '${proxyUrl}' --connect-timeout ${timeout} --max-time ${timeout} '${testUrl}'`,
      { encoding: "utf8", timeout: (timeout + 5) * 1000 }
    ).trim();
    const latency = Date.now() - start;
    console.log(`Status:   ${out}`);
    console.log(`Latency:  ${latency}ms`);
    const code = parseInt(out, 10);
    if (code >= 200 && code < 500) {
      console.log(`Result:   OK — proxy is reachable`);
    } else {
      console.log(`Result:   FAIL — got status ${out}`);
      allOk = false;
    }
  } catch {
    const latency = Date.now() - start;
    console.log(`Status:   000`);
    console.log(`Latency:  ${latency}ms`);
    console.log(`Result:   FAIL — could not connect`);
    allOk = false;
  }

  // codex doctor integration
  if (localPort && findCodex()) {
    console.log(`\ncodex doctor:`);
    try {
      const env = { ...process.env,
        HTTPS_PROXY: `http://127.0.0.1:${localPort}`,
        HTTP_PROXY: `http://127.0.0.1:${localPort}`,
        http_proxy: `http://127.0.0.1:${localPort}`,
        https_proxy: `http://127.0.0.1:${localPort}`,
        WS_PROXY: `http://127.0.0.1:${localPort}`,
        WSS_PROXY: `http://127.0.0.1:${localPort}`,
        NO_PROXY: "localhost,127.0.0.1,::1",
      };
      const out = execSync(`${findCodex()} doctor`, { encoding: "utf8", timeout: 25000, env });
      // Extract key lines
      const lines = out.split("\n");
      const wsLine = lines.find((l) => l.includes("websocket") && l.includes("connected"));
      const reachLine = lines.find((l) => l.includes("reachability") && l.includes("provider"));
      const baseLine = lines.find((l) => l.includes("base URL"));
      const handshakeLine = lines.find((l) => l.includes("handshake result"));
      if (wsLine) {
        const ok = wsLine.includes("✓") || wsLine.includes("connected");
        console.log(`  ${ok ? "✓" : "✗"} websocket: ${wsLine.replace(/^\s+/, "").replace(/^\S+\s+/, "").trim()}`);
        if (!ok) allOk = false;
      }
      if (handshakeLine) console.log(`    ${handshakeLine.trim()}`);
      if (reachLine) {
        const ok = reachLine.includes("✓") || reachLine.includes("reachable");
        console.log(`  ${ok ? "✓" : "✗"} reachability: ${reachLine.replace(/^\s+/, "").replace(/^\S+\s+/, "").trim()}`);
        if (!ok) allOk = false;
      }
      if (baseLine) console.log(`    ${baseLine.trim()}`);
    } catch {
      console.log(`  ✗ codex doctor: timeout or failed to run`);
      allOk = false;
    }
  }

  if (!allOk) process.exit(1);
}

