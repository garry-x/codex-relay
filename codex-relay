function chainConfigFromOpts(cfg, opts = {}) {
  const chain = cfg.chain || {};
  return {
    listen: opts.listen || chain.listen || "127.0.0.1:8080",
    upstreams: opts.upstream ? chainUpstreams(opts.upstream) : chain.upstreams || (chain.upstream ? [chain.upstream] : []),
    token: opts.token || "",
    tokenHash: opts.token ? "" : (chain.token_hash || cfg.chain_token_hash || cfg.chain_token || ""),
    allow: opts.allow ? opts.allow.split(",").map((s) => s.trim()).filter(Boolean) : chain.allow || [],
    tlsCert: opts["tls-cert"] || chain.tls_cert || "",
    tlsKey: opts["tls-key"] || chain.tls_key || "",
  };
}

function saveChainConfig(opts = {}) {
  const cfg = loadConfig();
  const chain = cfg.chain || {};
  if (opts.listen) chain.listen = opts.listen;
  if (opts.upstream) chain.upstreams = chainUpstreams(opts.upstream);
  if (opts.allow) chain.allow = opts.allow.split(",").map((s) => s.trim()).filter(Boolean);
  if (opts["tls-cert"]) chain.tls_cert = opts["tls-cert"];
  if (opts["tls-key"]) chain.tls_key = opts["tls-key"];
  cfg.chain = chain;
  saveConfig(cfg);
  return chain;
}

function isChainRunning() {
