}

function printVersion() {
  console.log(`${NAME} ${VERSION}`);
  const cv = codexVersion();
  console.log(cv ? `codex: ${cv}` : "codex: not found");
}

// ── main ───────────────────────────────────────────────────────────────────

function parseArgs(argv) {
  const opts = { _: [] };
  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === "--url" || argv[i] === "--timeout" || argv[i] === "--version") {
      opts[argv[i].replace(/^--/, "")] = argv[i + 1];
      i++;
    } else if (argv[i] === "--update") {
      opts.update = true;
    } else if (argv[i] === "--force") {
      opts.force = true;
    } else {
      opts._.push(argv[i]);
    }
  }
  return opts;
}

async function main() {
  const raw = process.argv.slice(2);

  // Hidden: daemon mode
  if (raw[0] === "--_daemon") {
    const upstreamUrl = raw[1];
    if (!upstreamUrl) die("--_daemon requires upstream URL");
    runProxyDaemon(upstreamUrl);
    return;
  }

  const cmd = raw[0];
  const args = raw.slice(1);

  switch (cmd) {
    case undefined:
    case "--help":
    case "-h":
      printHelp();
      break;

    case "--version":
    case "-V":
      printVersion();
      break;

    case "proxy": {
      const action = args[0];
      const pargs = parseArgs(args.slice(1));
      switch (action) {
        case "set": cmdProxySet(pargs._[0]); break;
        case "show": cmdProxyShow(); break;
        case "unset": cmdProxyUnset(); break;
        case "start": cmdProxyStart(); break;
        case "stop": cmdProxyStop(); break;
        case "test": cmdProxyTest(pargs); break;
        default: die(`usage: ${NAME} proxy {set|show|unset|test|start|stop}`);
      }
      break;
    }

    case "dns":
      await cmdDns(args);
      break;

    case "install": {
      const pargs = parseArgs(args);
      await cmdInstall(pargs);
      break;
    }

    case "run":
      cmdRun(args);
      break;

    default:
      // Passthrough to codex
      cmdRun(raw);
      break;
  }
}

main().catch((e) => {
  die(e.message);
});
