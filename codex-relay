#!/usr/bin/env node
// codex-relay — Node.js wrapper for OpenAI Codex CLI with proxy support.
// Requires Node.js >= 18 (built-in fetch, no npm dependencies).

const fs = require("fs");
const path = require("path");
const os = require("os");
const { spawn, execFileSync } = require("child_process");

// ═══════════════════════════════════════════════════════════════════════════
// config
// ═══════════════════════════════════════════════════════════════════════════

const NAME = "codex-relay";
const VERSION = "0.4.0";

// When running via sudo, use the original user's home, not /var/root
const SUDO_USER = process.env.SUDO_USER;
const REAL_HOME = (() => {
  if (!SUDO_USER) return os.homedir();
  for (const prefix of ["/Users", "/home"]) {
    const candidate = path.join(prefix, SUDO_USER);
    try { if (fs.statSync(candidate).isDirectory()) return candidate; } catch {}
  }
  return os.homedir();
})();
const CONFIG_DIR = path.join(REAL_HOME, ".codex-relay");
const CONFIG_FILE = path.join(CONFIG_DIR, "config.json");

// Resolve script path (handle relative paths for sudo)
const SCRIPT_PATH = (() => {
  try { return fs.realpathSync(process.argv[1]); } catch { return process.argv[1]; }
})();

// ═══════════════════════════════════════════════════════════════════════════
// helpers
// ═══════════════════════════════════════════════════════════════════════════

function die(msg) {
  console.error(`error: ${msg}`);
  process.exit(1);
}
function info(msg) {
  console.error(`[${NAME}] ${msg}`);
}

function loadConfig() {
  try {
    return JSON.parse(fs.readFileSync(CONFIG_FILE, "utf8"));
  } catch (e) {
    if (e.code === "ENOENT") return {};
    die(`invalid config file ${CONFIG_FILE}: ${e.message}`);
  }
}
function saveConfig(cfg) {
  fs.mkdirSync(CONFIG_DIR, { recursive: true, mode: 0o700 });
  try { fs.chmodSync(CONFIG_DIR, 0o700); } catch {}
  fs.writeFileSync(CONFIG_FILE, JSON.stringify(cfg, null, 2), { mode: 0o600 });
  try { fs.chmodSync(CONFIG_FILE, 0o600); } catch {}
}

function findCodex() {
  try { return execFileSync("which", ["codex"], { encoding: "utf8" }).trim(); } catch { return null; }
}
function codexVersion() {
  const bin = findCodex();
  if (!bin) return null;
  try { return execFileSync(bin, ["--version"], { encoding: "utf8", timeout: 5000 }).trim(); } catch { return null; }
}

function shutil(name) {
  try { execFileSync("which", [name], { encoding: "utf8", stdio: "ignore" }); return true; } catch { return false; }
}

function redactUrl(value) {
  if (!value) return value;
  try {
    const u = new URL(value);
    if (u.username || u.password) {
      u.username = "***";
      u.password = "";
    }
    return u.toString().replace("%2A%2A%2A", "***");
  } catch {
    return String(value).replace(/\/\/[^/@\s]+@/, "//***@");
  }
}

function resolveProxy(cfg = loadConfig(), env = process.env) {
  return env.HTTPS_PROXY || env.https_proxy ||
         env.HTTP_PROXY || env.http_proxy ||
         cfg.https || cfg.http || "";
}

function withProxyEnv(env, proxyUrl) {
  if (!proxyUrl) return env;
  const noProxy = "localhost,127.0.0.1,::1,.local";
  return {
    ...env,
    HTTP_PROXY: proxyUrl,
    HTTPS_PROXY: proxyUrl,
    http_proxy: proxyUrl,
    https_proxy: proxyUrl,
    WS_PROXY: proxyUrl,
    WSS_PROXY: proxyUrl,
    NO_PROXY: noProxy,
    no_proxy: noProxy,
  };
}

function runChecked(bin, args, opts = {}) {
  return execFileSync(bin, args, { encoding: "utf8", stdio: "pipe", ...opts });
}

function waitForClose(proc) {
  return new Promise((resolve, reject) => {
    proc.on("error", reject);
    proc.on("close", (code) => {
      if (code === 0) resolve();
      else reject(new Error(`command exited with code ${code}`));
    });
  });
}

function curlMs(value) {
  const seconds = Number(value);
  if (!Number.isFinite(seconds) || seconds < 0) return null;
  return Math.round(seconds * 1000);
}

function parseCurlTimings(out) {
  const values = {};
  for (const line of String(out).trim().split(/\r?\n/)) {
    const idx = line.indexOf("=");
    if (idx <= 0) continue;
    values[line.slice(0, idx)] = line.slice(idx + 1);
  }
  return {
    code: parseInt(values.http_code || "", 10),
    connectMs: curlMs(values.time_connect),
    appconnectMs: curlMs(values.time_appconnect),
    starttransferMs: curlMs(values.time_starttransfer),
    totalMs: curlMs(values.time_total),
  };
}

function formatCurlTimings(timing, fallbackMs) {
  const parts = [];
  const total = timing.totalMs ?? fallbackMs;
  if (total != null) parts.push(`${total}ms total`);
  if (timing.connectMs != null) parts.push(`${timing.connectMs}ms tcp-to-proxy`);
  if (timing.appconnectMs != null) parts.push(`${timing.appconnectMs}ms tls-ready`);
  if (timing.starttransferMs != null) parts.push(`${timing.starttransferMs}ms first-byte`);
  return parts.join(", ");
}

// Detect the shell config file for PATH setup.
function detectShellRc() {
  let shell = process.env.SHELL || "";
  let home = os.homedir();

  if (SUDO_USER) {
    for (const prefix of ["/Users", "/home"]) {
      const candidate = path.join(prefix, SUDO_USER);
      try { if (fs.statSync(candidate).isDirectory()) { home = candidate; break; } } catch {}
    }
    try {
      if (process.platform === "darwin") {
        const out = execFileSync("dscl", [".", "-read", `/Users/${SUDO_USER}`, "UserShell"], { encoding: "utf8", timeout: 2000, stdio: ["ignore", "pipe", "ignore"] });
        const m = out.match(/UserShell:\s*(\S+)/);
        if (m) shell = m[1];
      } else {
        const passwd = execFileSync("getent", ["passwd", SUDO_USER], { encoding: "utf8", timeout: 2000, stdio: ["ignore", "pipe", "ignore"] });
        shell = (passwd.split(":")[6] || "").trim() || shell;
      }
    } catch {}
  }

  const isBash = shell.includes("bash");
  const isZsh = shell.includes("zsh");
  if (isZsh) return { rc: path.join(home, ".zshrc"), name: "~/.zshrc", home };
  if (isBash) {
    const bashProfile = path.join(home, ".bash_profile");
    if (fs.existsSync(bashProfile) || process.platform === "darwin") {
      return { rc: bashProfile, name: "~/.bash_profile", home };
    }
    return { rc: path.join(home, ".bashrc"), name: "~/.bashrc", home };
  }
  return { rc: path.join(home, ".profile"), name: "~/.profile", home };
}

// ═══════════════════════════════════════════════════════════════════════════
// CLI: proxy
// ═══════════════════════════════════════════════════════════════════════════

function cmdProxySet(url) {
  if (!url) die(`usage: ${NAME} proxy set <url>`);
  const cfg = loadConfig();
  cfg.http = url;
  cfg.https = url;
  saveConfig(cfg);
  info(`proxy set to: ${redactUrl(url)}`);
}

function cmdProxyShow() {
  const cfg = loadConfig();
  const envProxy = process.env.HTTPS_PROXY || process.env.https_proxy ||
                   process.env.HTTP_PROXY || process.env.http_proxy;
  const configProxy = cfg.https || cfg.http;
  const effective = resolveProxy(cfg);
  if (envProxy) console.log(`env proxy:       ${redactUrl(envProxy)}`);
  if (configProxy) console.log(`config proxy:    ${redactUrl(configProxy)}`);
  if (effective) {
    console.log(`effective proxy: ${redactUrl(effective)}`);
  } else {
    console.log("effective proxy: none");
  }
}

function cmdProxyUnset() {
  const cfg = loadConfig();
  delete cfg.http;
  delete cfg.https;
  saveConfig(cfg);
  info("proxy configuration cleared.");
}

function cmdProxyCheck(opts = {}) {
  const testUrl = opts.url || "https://api.openai.com";
  const timeout = Number(opts.timeout || 10);
  if (!Number.isFinite(timeout) || timeout <= 0) die("--timeout must be a positive number");

  const issues = [];
  const ok = [];

  const check = (label, condition, detail) => {
    if (condition) ok.push(label + (detail ? ` (${detail})` : ""));
    else issues.push(label + (detail ? ` — ${detail}` : ""));
  };

  const cfg = loadConfig();
  const proxyUrl = resolveProxy(cfg);
  check("proxy config", !!proxyUrl, redactUrl(proxyUrl) || "not configured — run: proxy set <url>");

  const haveCurl = !!shutil("curl");
  check("curl", haveCurl, haveCurl ? "available" : "not found — required for proxy check");

  if (proxyUrl && haveCurl) {
    const start = Date.now();
    try {
      const out = runChecked("curl", [
        "-s",
        "-o", "/dev/null",
        "-w", [
          "http_code=%{http_code}",
          "time_connect=%{time_connect}",
          "time_appconnect=%{time_appconnect}",
          "time_starttransfer=%{time_starttransfer}",
          "time_total=%{time_total}",
        ].join("\\n"),
        "--proxy", proxyUrl,
        "--connect-timeout", String(timeout),
        "--max-time", String(timeout),
        testUrl,
      ], { timeout: (timeout + 5) * 1000 }).trim();
      const latency = Date.now() - start;
      const timing = parseCurlTimings(out);
      const timingDetail = formatCurlTimings(timing, latency);
      check("proxy connectivity", timing.code >= 200 && timing.code < 500, `HTTP ${timing.code || "000"}, ${timingDetail} → ${testUrl}`);
    } catch {
      check("proxy connectivity", false, `connection failed → ${testUrl}`);
    }
  } else if (!haveCurl) {
    check("proxy connectivity", false, "curl not available");
  } else {
    check("proxy connectivity", false, "no proxy configured");
  }

  const haveNpm = !!shutil("npm");
  check("npm", haveNpm, haveNpm ? "available" : "not found — needed for codex install");

  const codexBin = findCodex();
  check("codex CLI", !!codexBin, codexBin ? codexVersion() : "not installed — run: install");

  // 6. VPS forwarder status (if configured)
  if (cfg.vps?.ssh) {
    try {
      const out = _vpsExecNoFail("ss -tlnp | grep 8443");
      check("vps forwarder", !!out.trim(), out.trim() || "not running — run: codex-relay vps start");
    } catch {
      check("vps forwarder", false, "SSH unreachable");
    }
  }

  console.log("codex-relay proxy check\n");
  for (const item of ok) console.log(`  ✓ ${item}`);
  if (issues.length > 0) {
    console.log("");
    for (const item of issues) console.log(`  ✗ ${item}`);
  }
  console.log("");
  console.log(`${ok.length} OK, ${issues.length} issue${issues.length !== 1 ? "s" : ""}`);
  if (issues.length > 0) process.exit(1);
}

// ═══════════════════════════════════════════════════════════════════════════
// CLI: install
// ═══════════════════════════════════════════════════════════════════════════

async function cmdInstallSelf(opts = {}) {
  const isRoot = process.getuid && process.getuid() === 0;

  const candidates = [
    "/usr/local/bin",
    ...(isRoot ? ["/usr/local/sbin"] : []),
    path.join(os.homedir(), ".local", "bin"),
    path.join(os.homedir(), "bin"),
  ];

  let binDir = null;
  let dest = null;

  for (const dir of candidates) {
    dest = path.join(dir, NAME);
    try {
      fs.mkdirSync(dir, { recursive: true });
      const testFile = path.join(dir, `.${NAME}.write-test`);
      fs.writeFileSync(testFile, "", { mode: 0o644 });
      fs.unlinkSync(testFile);
      binDir = dir;
      break;
    } catch { continue; }
  }

  if (!binDir) {
    throw new Error(
      `no writable bin directory found. Tried: ${candidates.join(", ")}.\n` +
      `  Run with sudo or create a directory: mkdir -p ~/.local/bin && export PATH="$HOME/.local/bin:$PATH"`
    );
  }

  let scriptContent;
  if (opts.url) {
    info(`downloading from ${opts.url} ...`);
    const resp = await fetch(opts.url);
    if (!resp.ok) die(`download failed: ${resp.status}`);
    scriptContent = await resp.text();
  } else {
    scriptContent = fs.readFileSync(SCRIPT_PATH, "utf8");
  }

  if (dest && fs.existsSync(dest) && !opts.force) {
    const readline = require("readline");
    const rl = readline.createInterface({ input: process.stdin, output: process.stderr });
    const answer = await new Promise((res) => {
      rl.question(`  ${NAME} already exists at ${dest}. Overwrite? [y/N] `, (a) => {
        rl.close();
        res(a.trim().toLowerCase());
      });
    });
    if (answer !== "y" && answer !== "yes") { info("skipped."); return; }
  }

  try {
    fs.writeFileSync(dest, scriptContent, { mode: 0o755 });

    // Also install codex-relay-forward if available
    const forwarderSrc = path.join(path.dirname(SCRIPT_PATH), "codex-relay-forward");
    if (fs.existsSync(forwarderSrc)) {
      fs.writeFileSync(path.join(binDir, "codex-relay-forward"), fs.readFileSync(forwarderSrc), { mode: 0o755 });
    }

    const inPath = process.env.PATH.split(":").some((p) => path.resolve(p) === path.resolve(binDir));
    let findable = false;
    try {
      execFileSync("which", [NAME], { encoding: "utf8", timeout: 2000 }).trim();
      findable = true;
    } catch {}

    const { rc, name: shellRc, home } = detectShellRc();

    if (findable && !SUDO_USER) {
      info(`installed to ${dest}`);
      info(`  ✓ on PATH — run: ${NAME} --help`);
    } else if (findable && SUDO_USER) {
      info(`installed to ${dest} (system-wide)`);
    } else if (inPath) {
      info(`installed to ${dest}`);
      info(`  hint: refresh shell cache — run: hash -r`);
    } else {
      const exportLine = `export PATH="${binDir}:\\$PATH"`;
      info(`installed to ${dest}`);
      info(`  bin directory ${binDir} is not on PATH. To add it:`);
      info(``);
      info(`    echo '${exportLine}' >> ${shellRc}`);
      info(`    source ${shellRc}`);
      info(``);
      if (shellRc.endsWith(".bashrc") && !fs.existsSync(rc)) {
        const bp = path.join(home, ".bash_profile");
        if (fs.existsSync(bp)) {
          info(`  note: macOS bash loads ~/.bash_profile. Make sure it sources ~/.bashrc:`);
          info(`    echo '[ -f ~/.bashrc ] && source ~/.bashrc' >> ~/.bash_profile`);
        }
      }
      if (SUDO_USER) info(`  note: the PATH change above applies to user ${SUDO_USER}, not root`);
      if (SUDO_USER) info(`  After setup, run as ${SUDO_USER}: ${NAME} --help`);
      else info(`  Then: ${NAME} --help`);
    }
  } catch (e) { throw e; }
}

async function cmdInstallCodex(env, version) {
  const npm = "npm";
  try { execFileSync("which", ["npm"], { encoding: "utf8" }); } catch { die("npm not found. Install Node.js: https://nodejs.org"); }

  let pkg = "@openai/codex";
  if (version) pkg += `@${version}`;
  info(`installing ${pkg} ...`);
  const proc = spawn(npm, ["install", "-g", pkg], { env, stdio: "inherit" });
  await waitForClose(proc);
  const ver = codexVersion();
  info(`installed: ${ver || "latest"}`);
}

async function cmdUpdateCodex(env) {
  const npm = "npm";
  try { execFileSync("which", ["npm"], { encoding: "utf8" }); } catch { die("npm not found. Install Node.js: https://nodejs.org"); }
  info("updating @openai/codex ...");
  const proc = spawn(npm, ["update", "-g", "@openai/codex"], { env, stdio: "inherit" });
  await waitForClose(proc);
  const ver = codexVersion();
  info(`updated: ${ver || "latest"}`);
}

async function cmdInstall(opts = {}) {
  const cfg = loadConfig();
  const proxyUrl = resolveProxy(cfg);
  const env = withProxyEnv({ ...process.env }, proxyUrl);

  if (opts.update) { await cmdUpdateCodex(env); return; }
  if (opts.version) { await cmdInstallCodex(env, opts.version); return; }

  info("step 1/2: installing codex-relay ...");
  try { await cmdInstallSelf(opts); }
  catch (e) { if (opts.force) die(e.message); info(`codex-relay self-install skipped (${e.message})`); }

  info("step 2/2: checking Codex CLI ...");
  if (findCodex()) info(`codex already installed (${codexVersion() || "unknown"})`);
  else await cmdInstallCodex(env);

  info("install complete.");
}

// ═══════════════════════════════════════════════════════════════════════════
// CLI: run
// ═══════════════════════════════════════════════════════════════════════════

function cmdRun(args) {
  const codexBin = findCodex() || die("'codex' not found. Install with: codex-relay install");

  const cfg = loadConfig();
  const proxyUrl = resolveProxy(cfg);
  const env = withProxyEnv({ ...process.env }, proxyUrl);
  if (proxyUrl) info(`using proxy: ${redactUrl(proxyUrl)}`);

  const proc = spawn(codexBin, args, { env, stdio: "inherit" });
  proc.on("close", (code) => process.exit(code || 0));
  proc.on("error", () => process.exit(1));
}

